# Supabase Configuration
# Copie este arquivo para .env e preencha com suas credenciais

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Service Role Key (NUNCA exponha no frontend - apenas para scripts administrativos)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Playwright E2E (nunca commitar valores reais — use .env.local)
# E2E_PRO_EMAIL=
# E2E_PRO_PASSWORD=
# E2E_PATIENT_EMAIL=
# E2E_PATIENT_PASSWORD=

# Sentry observability (V1.9.209) — opcional em dev, recomendado em prod
# Free tier: 5.000 events/mês. Ativo apenas em PROD com DSN definida.
# Sem DSN = sem Sentry (noop silencioso, nada quebra).
# VITE_SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID
