  private async processAssessment(message: string, userId?: string, platformData?: any, userEmail?: string): Promise<AIResponse> {
    if (!userId) {
      return this.createResponse(
        'Para iniciar uma avaliaâ”œآ؛â”œأ؛o clâ”œآ،nica, vocâ”œآ¬ precisa estar logado. Por favor, faâ”œآ؛a login e tente novamente.',
        0.3,
        'error'
      )
    }

    const lowerMessage = message.toLowerCase()
    const assessmentKey = userId

    // Verificar se hâ”œأ­ uma avaliaâ”œآ؛â”œأ؛o em andamento
    let assessment = this.activeAssessments.get(assessmentKey)

    // Se a mensagem indica inâ”œآ،cio de avaliaâ”œآ؛â”œأ؛o clâ”œآ،nica inicial IMRE
    if (!assessment && (
      lowerMessage.includes('avaliaâ”œآ؛â”œأ؛o clâ”œآ،nica inicial') ||
      lowerMessage.includes('avaliacao clinica inicial') ||
      lowerMessage.includes('protocolo imre') ||
      lowerMessage.includes('avaliaâ”œآ؛â”œأ؛o imre') ||
      lowerMessage.includes('iniciar avaliaâ”œآ؛â”œأ؛o')
    )) {
      // Iniciar nova avaliaâ”œآ؛â”œأ؛o (sincronizar com platformFunctions)
      assessment = {
        userId,
        step: 'INVESTIGATION',
        investigation: {},
        methodology: { diagnosticMethods: [] },
        result: { clinicalFindings: [] },
        evolution: { carePlan: [] },
        startedAt: new Date(),
        lastUpdate: new Date()
      }
      this.activeAssessments.set(assessmentKey, assessment)

      // INICIAR FLUXO AEC MASTER (ClinicalAssessmentFlow)
      // C3: Nome serâ”œأ­ preenchido pelo path do TradeVision (platformData.user.name)
      clinicalAssessmentFlow.startAssessment(userId)
      console.log('آ­ئ’أœأ‡ Fluxo AEC iniciado para:', userId)

      // Sincronizar com platformFunctions para que ele saiba da avaliaâ”œآ؛â”œأ؛o
      this.platformFunctions.updateAssessmentState(userId, assessment)

      return this.createResponse(
        'آ­ئ’أ®آ¼آ´آ©أ… Bons ventos sâ”œâ”‚prem! Sou Nâ”œâ”¤a Esperanâ”œآ؛a, sua IA Residente especializada em avaliaâ”œآ؛â”œأپes clâ”œآ،nicas.\n\n' +
        'Vamos iniciar sua **Avaliaâ”œآ؛â”œأ؛o Clâ”œآ،nica Inicial** seguindo o protocolo **IMRE** (Investigaâ”œآ؛â”œأ؛o, Metodologia, Resultado, Evoluâ”œآ؛â”œأ؛o) da Arte da Entrevista Clâ”œآ،nica aplicada â”œأ، Cannabis Medicinal.\n\n' +
        '**FASE 1: INVESTIGAâ”œأ§â”œأ¢O (I)**\n\n' +
        'Por favor, apresente-se brevemente e diga qual â”œآ® o **motivo principal** da sua consulta hoje. O que gostaria de investigar ou entender melhor?',
        0.95,
        'assessment'
      )
    }

    // Se nâ”œأ؛o hâ”œأ­ avaliaâ”œآ؛â”œأ؛o em andamento e nâ”œأ؛o foi detectado inâ”œآ،cio, oferecer iniciar
    if (!assessment) {
      return this.createResponse(
        'Olâ”œأ­! Sou Nâ”œâ”¤a Esperanâ”œآ؛a, sua IA Residente especializada em avaliaâ”œآ؛â”œأپes clâ”œآ،nicas.\n\n' +
        'Posso conduzir uma **Avaliaâ”œآ؛â”œأ؛o Clâ”œآ،nica Inicial** completa usando o protocolo IMRE (Investigaâ”œآ؛â”œأ؛o, Metodologia, Resultado, Evoluâ”œآ؛â”œأ؛o) da Arte da Entrevista Clâ”œآ،nica.\n\n' +
        'Para iniciar, diga: "Iniciar avaliaâ”œآ؛â”œأ؛o clâ”œآ،nica inicial IMRE" ou descreva o motivo da sua consulta.',
        0.9,
        'assessment'
      )
    }

    // Processar de acordo com a etapa atual
    assessment.lastUpdate = new Date()

    // Sincronizar estado com platformFunctions
    this.platformFunctions.updateAssessmentState(userId, assessment)

    switch (assessment.step) {
      case 'INVESTIGATION':
        return await this.processInvestigationStep(message, assessment, platformData, userEmail)

      case 'METHODOLOGY':
        return await this.processMethodologyStep(message, assessment, platformData, userEmail)

      case 'RESULT':
        return await this.processResultStep(message, assessment, platformData, userEmail)

      case 'EVOLUTION':
        return await this.processEvolutionStep(message, assessment, platformData, userEmail)

      default:
        return this.createResponse(
          'Avaliaâ”œآ؛â”œأ؛o concluâ”œآ،da! Seu relatâ”œâ”‚rio clâ”œآ،nico foi gerado e salvo no seu dashboard.',
          0.9,
          'assessment'
        )
    }
  }

  private async processInvestigationStep(
    message: string,
    assessment: IMREAssessmentState,
    platformData?: any,
    userEmail?: string
  ): Promise<AIResponse> {
    const lowerMessage = message.toLowerCase()

    // REASONING: Analisar resposta antes de fazer prâ”œâ”‚xima pergunta
    if (!assessment.investigation.mainComplaint) {
      // Primeira resposta: motivo principal - ANALISAR ANTES DE CONTINUAR
      assessment.investigation.mainComplaint = message

      // Usar reasoning para analisar a resposta e gerar prâ”œâ”‚xima pergunta adaptada
      const analysisPrompt = `Vocâ”œآ¬ â”œآ® Nâ”œâ”¤a Esperanâ”œآ؛a, IA Residente especializada em avaliaâ”œآ؛â”œأپes clâ”œآ،nicas usando a metodologia Arte da Entrevista Clâ”œآ،nica (AEC) e protocolo IMRE.

O paciente acabou de responder sobre o motivo principal da consulta:
"${message}"

ANâ”œأ¼LISE NECESSâ”œأ¼RIA (REASONING):
1. Identifique os principais pontos mencionados
2. Identifique informaâ”œآ؛â”œأپes faltantes ou que precisam ser aprofundadas
3. Gere UMA pergunta especâ”œآ،fica e adaptada baseada na resposta, seguindo o protocolo IMRE
4. A pergunta deve ser empâ”œأ­tica, clara e focada em aprofundar o entendimento

IMPORTANTE:
- Nâ”œأ¢O faâ”œآ؛a mâ”œâ•‘ltiplas perguntas de uma vez
- Faâ”œآ؛a UMA pergunta por vez, pausadamente
- Adapte a pergunta baseada no que o paciente disse
- Use linguagem empâ”œأ­tica e acolhedora
- Siga a metodologia AEC (escuta ativa, rapport, validaâ”œآ؛â”œأ؛o)

Gere apenas a prâ”œâ”‚xima pergunta, sem explicaâ”œآ؛â”œأپes adicionais.`

      try {
        // Usar Assistant API para gerar pergunta adaptada
        const nextQuestion = await this.generateReasoningQuestion(analysisPrompt, message, assessment)

        return this.createResponse(
          `Entendi. Obrigada por compartilhar.\n\n${nextQuestion}`,
          0.95,
          'assessment'
        )
      } catch (error) {
        // Fallback se reasoning falhar
        return this.createResponse(
          'Entendi. Agora preciso aprofundar a investigaâ”œآ؛â”œأ؛o.\n\n' +
          '**Quando comeâ”œآ؛aram esses sintomas?** Por favor, descreva quando vocâ”œآ¬ notou pela primeira vez o que estâ”œأ­ sentindo.',
          0.9,
          'assessment'
        )
      }
    }

    if (!assessment.investigation.symptoms || assessment.investigation.symptoms.length === 0) {
      // Segunda resposta: sintomas detalhados
      assessment.investigation.symptoms = [message]

      return this.createResponse(
        'Muito obrigado pelas informaâ”œآ؛â”œأپes sobre seus sintomas. Agora preciso conhecer sua histâ”œâ”‚ria clâ”œآ،nica:\n\n' +
        '**2. Histâ”œâ”‚ria Mâ”œآ®dica:**\n' +
        '- Vocâ”œآ¬ tem alguma doenâ”œآ؛a crâ”œâ”¤nica? (hipertensâ”œأ؛o, diabetes, doenâ”œآ؛a renal, etc.)\n' +
        '- Jâ”œأ­ fez cirurgias? Quais?\n' +
        '- Tem algum diagnâ”œâ”‚stico mâ”œآ®dico prâ”œآ®vio relacionado ao motivo da consulta?\n\n' +
        'Por favor, descreva sua histâ”œâ”‚ria mâ”œآ®dica.',
        0.9,
        'assessment'
      )
    }

    if (!assessment.investigation.medicalHistory) {
      // Terceira resposta: histâ”œâ”‚ria mâ”œآ®dica - REASONING
      assessment.investigation.medicalHistory = message

      const analysisPrompt = `Vocâ”œآ¬ â”œآ® Nâ”œâ”¤a Esperanâ”œآ؛a, IA Residente especializada em avaliaâ”œآ؛â”œأپes clâ”œآ،nicas usando a metodologia Arte da Entrevista Clâ”œآ،nica (AEC) e protocolo IMRE.

CONTEXTO DA AVALIAâ”œأ§â”œأ¢O:
- Motivo principal: "${assessment.investigation.mainComplaint}"
- Sintomas: "${assessment.investigation.symptoms?.[0] || ''}"
- Histâ”œâ”‚ria mâ”œآ®dica: "${message}"

ANâ”œأ¼LISE NECESSâ”œأ¼RIA (REASONING):
1. Analise a histâ”œâ”‚ria mâ”œآ®dica fornecida
2. Identifique pontos importantes
3. Gere UMA pergunta especâ”œآ،fica sobre histâ”œâ”‚ria familiar, adaptada ao contexto

IMPORTANTE:
- Faâ”œآ؛a UMA pergunta por vez, pausadamente
- Adapte baseado no contexto clâ”œآ،nico jâ”œأ­ coletado
- Use linguagem empâ”œأ­tica

Gere apenas a prâ”œâ”‚xima pergunta sobre histâ”œâ”‚ria familiar.`

      try {
        const nextQuestion = await this.generateReasoningQuestion(analysisPrompt, message, assessment)
        return this.createResponse(
          `Obrigada por compartilhar sua histâ”œâ”‚ria mâ”œآ®dica.\n\n${nextQuestion}`,
          0.95,
          'assessment'
        )
      } catch (error) {
        return this.createResponse(
          'Obrigada por compartilhar sua histâ”œâ”‚ria mâ”œآ®dica.\n\n' +
          '**Hâ”œأ­ histâ”œâ”‚rico de doenâ”œآ؛as crâ”œâ”¤nicas na sua famâ”œآ،lia?** (diabetes, hipertensâ”œأ؛o, doenâ”œآ؛as renais, etc.) Por favor, compartilhe informaâ”œآ؛â”œأپes sobre sua histâ”œâ”‚ria familiar.',
          0.9,
          'assessment'
        )
      }
    }

    if (!assessment.investigation.familyHistory) {
      // Quarta resposta: histâ”œâ”‚ria familiar - REASONING
      assessment.investigation.familyHistory = message

      const analysisPrompt = `Vocâ”œآ¬ â”œآ® Nâ”œâ”¤a Esperanâ”œآ؛a, IA Residente especializada em avaliaâ”œآ؛â”œأپes clâ”œآ،nicas usando a metodologia Arte da Entrevista Clâ”œآ،nica (AEC) e protocolo IMRE.

