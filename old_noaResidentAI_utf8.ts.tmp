  // Mâ”œآ®todos auxiliares privados
  private getAxisDetails(axisKey: string) {
    const axes: any = {
      'admin': { key: 'admin', label: 'Administraâ”œآ؛â”œأ؛o', summary: 'Visâ”œأ؛o geral do sistema e gestâ”œأ؛o de recursos.', knowledgeQuery: 'gestâ”œأ؛o administraâ”œآ؛â”œأ؛o sistema' },
      'clinica': { key: 'clinica', label: 'Clâ”œآ،nica', summary: 'Atendimento a pacientes e gestâ”œأ؛o clâ”œآ،nica.', knowledgeQuery: 'protocolos clâ”œآ،nicos tratamento' },
      'ensino': { key: 'ensino', label: 'Ensino', summary: 'Cursos, treinamentos e material educativo.', knowledgeQuery: 'educaâ”œآ؛â”œأ؛o cursos treinamento' },
      'pesquisa': { key: 'pesquisa', label: 'Pesquisa', summary: 'Estudos, dados e evidâ”œآ¬ncias cientâ”œآ،ficas.', knowledgeQuery: 'pesquisa cientâ”œآ،fica estudos' }
    }
    return axes[axisKey] || axes['clinica']
  }

  private resolveAxisFromPath(path?: string): string {
    if (!path) return 'clinica'
    if (path.includes('admin')) return 'admin'
    if (path.includes('ensino')) return 'ensino'
    if (path.includes('pesquisa')) return 'pesquisa'
    return 'clinica'
  }

  private getAvailableAxesForUser(userType: string = 'student'): string[] {
    // Permissâ”œأ؛o baseada APENAS no tipo de usuâ”œأ­rio do Supabase
    if (userType === 'admin') return ['admin', 'clinica', 'ensino', 'pesquisa']
    if (userType === 'professional') return ['clinica', 'ensino', 'pesquisa']
    return ['ensino']
  }

  private formatAxisMenu(axes: string[]): string {
    return axes.map(axis => {
      const details = this.getAxisDetails(axis)
      return `  - **${details.label}**: ${details.summary}`
    }).join('\n')
  }

  // Mâ”œآ®todos de sanitizaâ”œآ؛â”œأ؛o removidos conforme Protocolo de Seguranâ”œآ؛a (Phase 5)
  // Texto clâ”œآ،nico deve ser preservado integralmente.

  private buildPlatformActionContext(intent: any, result: any): string {
    if (!result.success) return `Aâ”œآ؛â”œأ؛o falhou: ${result.error}`

    let context = `Aâ”œآ؛â”œأ؛o executada: ${intent.type}\n`
    if (result.data) {
      context += `Dados resultantes: ${JSON.stringify(result.data, null, 2)}`
    }
    return context
  }

  private async processTradeVisionRequest(
    userMessage: string,
    intent: string,
    platformData: any,
    userEmail?: string,
    uiContext?: any,
    platformIntentType: string = 'NONE'
  ): Promise<AIResponse> {
    try {
      console.log('آ­ئ’آھأ  [TradeVision Cloud] Conectando ao Core via Supabase Edge Functions...')

      const withTimeout = async <T,>(
        promise: PromiseLike<T>,
        ms: number,
        timeoutMessage: string
      ): Promise<T> => {
        let timeoutId: ReturnType<typeof setTimeout> | undefined
        const timeoutPromise = new Promise<never>((_, reject) => {
          timeoutId = setTimeout(() => reject(new Error(timeoutMessage)), ms)
        })

        try {
          return (await Promise.race([promise, timeoutPromise])) as T
        } finally {
          if (timeoutId) clearTimeout(timeoutId)
        }
      }

      // Obter fase do ClinicalAssessmentFlow (AEC 001) para controle de estado
      let currentPhase = undefined
      let nextQuestionHint = undefined

      // ASSESSMENT_START na 1â”¬آ¬ mensagem deve iniciar o AEC local; antes "NONE" sâ”œâ”‚ bloqueava o fluxo.
      const platformAllowsAec =
        platformIntentType === 'NONE' ||
        !platformIntentType ||
        platformIntentType === 'ASSESSMENT_START'

      const shouldHandleAecFlow =
        intent === 'CLâ”œأ¬NICA' &&
        platformData?.user?.id &&
        platformAllowsAec

      if (shouldHandleAecFlow) {
        await clinicalAssessmentFlow.ensureLoaded(platformData.user.id)
        let flowState = clinicalAssessmentFlow.getState(platformData.user.id)

        if (!flowState && platformIntentType === 'ASSESSMENT_START') {
          // C3: Auto-preencher nome do perfil
          const patientName = platformData?.user?.name || platformData?.user?.full_name || undefined
          clinicalAssessmentFlow.startAssessment(platformData.user.id, patientName)
          flowState = clinicalAssessmentFlow.getState(platformData.user.id)
          console.log('آ­ئ’أœأ‡ AEC: fluxo iniciado a partir de ASSESSMENT_START (TradeVision path) | Nome:', patientName || '(auto)')
        }

        // Se existe fluxo ativo, processar a resposta do usuâ”œأ­rio para avanâ”œآ؛ar
        if (flowState) {
          try {
            // Sâ”œâ”‚ processa se nâ”œأ؛o for o comando de iniciar (que jâ”œأ­ foi tratado no processAssessment)
            const isStartCommand = userMessage.toLowerCase().includes('iniciar') || userMessage.toLowerCase().includes('avaliaâ”œآ؛â”œأ؛o')

            if (!isStartCommand) {
              const stepResult = clinicalAssessmentFlow.processResponse(platformData.user.id, userMessage)
              console.log(`أ”آ£أ  Fluxo AEC avanâ”œآ؛ou para: ${stepResult.phase}`)
              nextQuestionHint = stepResult.nextQuestion

              // Se a avaliaâ”œآ؛â”œأ؛o foi concluâ”œآ،da, gerar relatâ”œâ”‚rio automaticamente
              if (stepResult.phase === 'COMPLETED' && stepResult.isComplete) {
                console.log('آ­ئ’أ„آ» Avaliaâ”œآ؛â”œأ؛o concluâ”œآ،da! Gerando relatâ”œâ”‚rio automâ”œأ­tico...')
                try {
                  const reportId = await clinicalAssessmentFlow.generateReport(
                    platformData.user.id,
                    platformData.user.id // patientId = userId para agora
                  )
                  if (reportId) {
                    console.log(`أ”آ£أ  Relatâ”œâ”‚rio gerado e salvo: ${reportId}`)
                    console.log('آ­ئ’أ´أ¨ Disponâ”œآ،vel no dashboard do paciente e mâ”œآ®dico')
                  }
                } catch (err) {
                  console.error('أ”أکأ® Erro ao gerar relatâ”œâ”‚rio automâ”œأ­tico:', err)
                }
              }

              // TRIGGER EXPLICITO SOLICITADO
              if (stepResult.phase === 'COMPLETED') {
                console.log('[ClinicalFlow] Assessment completed أ”أ¥أ† session finalized')
              }

              // Persistir estado
              await clinicalAssessmentFlow.persist(platformData.user.id)
            }

            // Recarrega estado atualizado
            flowState = clinicalAssessmentFlow.getState(platformData.user.id)
            if (flowState) {
              currentPhase = flowState.phase
            }
          } catch (e) {
            console.warn('Erro ao processar fluxo AEC:', e)
          }
        }
      }

      // آ­ئ’آ؛أ، CARREGAR HISTâ”œأ´RICO DE CONVERSAS (Memâ”œâ”‚ria de Contexto)
      let conversationHistory: Array<{ role: string, content: string }> = []

      if (platformData?.user?.id) {
        try {
          const historyQuery = supabase
            .from('ai_chat_interactions')
            .select('user_message, ai_response, created_at')
            .eq('user_id', platformData.user.id)
            .order('created_at', { ascending: false })
            .limit(10) // â”œأœltimas 10 interaâ”œآ؛â”œأپes

          const { data: historyData, error: historyError } = await withTimeout(
            historyQuery as unknown as PromiseLike<{
              data: Array<{ user_message: string; ai_response: string; created_at: string }> | null
              error: any
            }>,
            8000,
            'Timeout ao carregar histâ”œâ”‚rico da conversa (ai_chat_interactions).'
          )

          if (!historyError && historyData && historyData.length > 0) {
            // Reverter para ordem cronolâ”œâ”‚gica e formatar para OpenAI
            conversationHistory = historyData.reverse().flatMap((h: { user_message: string; ai_response: string }) => [
              { role: 'user', content: h.user_message },
              { role: 'assistant', content: h.ai_response }
            ])
            console.log(`آ­ئ’آ؛أ، Histâ”œâ”‚rico carregado: ${historyData.length} interaâ”œآ؛â”œأپes anteriores`)
          }
        } catch (e) {
          console.warn('أ”أœأ،آ´آ©أ… Erro ao carregar histâ”œâ”‚rico:', e)
        }
      }

      const payload = {
        message: userMessage,
        conversationHistory, // أ”أ¥أ‰ NOVO: Histâ”œâ”‚rico para contexto
        assessmentPhase: currentPhase,
        nextQuestionHint,
        ui_context: uiContext,
        patientData: {
          ...platformData,
          intent,
          userEmail,
          assessmentContext: platformData?.user?.id ? this.activeAssessments.get(platformData.user.id) : undefined
        }
      }

      // آ­ئ’أœأ‡ Chamada oficial para a Nuvem (Fase 2)
      const invokePromise = supabase.functions.invoke('tradevision-core', {
        body: payload
      })

      const { data, error } = await withTimeout(
        invokePromise,
        45000,
        'Timeout ao chamar tradevision-core. O Core demorou mais que o esperado para responder.'
      )

      if (error) throw error
      if (data?.error) throw new Error(data.error)
      if (!data?.text) throw new Error('Resposta da IA veio vazia do Core Cloud.')

      const appCommandsFromCore = Array.isArray((data as { app_commands?: unknown[] }).app_commands)
        ? (data as { app_commands: unknown[] }).app_commands
        : []
      if (appCommandsFromCore.length > 0) {
        console.log('آ­ئ’أ´أ¯ [Core] app_commands no body:', appCommandsFromCore.length, appCommandsFromCore)
      }

      let aiContent = data.text

      let isCompleted = false
      if (aiContent.includes('[ASSESSMENT_COMPLETED]')) {
        isCompleted = true
        console.log('آ­ئ’أ„آ» Tag [ASSESSMENT_COMPLETED] detectada no output da IA')
        aiContent = aiContent.replace('[ASSESSMENT_COMPLETED]', '').trim()

        // SEMPRE gerar relatâ”œâ”‚rio quando [ASSESSMENT_COMPLETED] â”œآ® detectado.
        // O Core (Edge Function) agora extrai dados via GPT da conversa real
        // se o content do cliente vier vazio/dessincronizado.
        if (platformData?.user?.id) {
          console.log('آ­ئ’آ؛أ، [GPT Extraction] Tag detectada. Enviando para Edge Function extrair dados da conversa...')

          const flowState = clinicalAssessmentFlow.getState(platformData.user.id)

          // Marcar como completed localmente
          if (flowState && flowState.phase !== 'COMPLETED') {
            clinicalAssessmentFlow.completeAssessment(platformData.user.id)
          }

          // Enviar dados locais (podem ser parciais/dessincronizados).
          // O Core detecta se sâ”œأ؛o vazios e extrai via GPT do histâ”œâ”‚rico.
          const localData = flowState?.data
          const contentPayload = localData ? {
            identificacao: { nome: localData.patientName, apresentacao: localData.patientPresentation },
            lista_indiciaria: localData.complaintList || [],
            queixa_principal: localData.mainComplaint || null,
            desenvolvimento_queixa: {
              localizacao: localData.complaintLocation,
              inicio: localData.complaintOnset,
              descricao: localData.complaintDescription,
              sintomas_associados: localData.complaintAssociatedSymptoms || [],
              fatores_melhora: localData.complaintImprovements || [],
              fatores_piora: localData.complaintWorsening || []
            },
            historia_patologica_pregressa: localData.medicalHistory || [],
            historia_familiar: {
              lado_materno: localData.familyHistoryMother || [],
              lado_paterno: localData.familyHistoryFather || []
            },
            habitos_vida: localData.lifestyleHabits || [],
            perguntas_objetivas: {
              alergias: localData.allergies,
              medicacoes_regulares: localData.regularMedications,
              medicacoes_esporadicas: localData.sporadicMedications
            },
            consenso: {
              aceito: localData.consensusAgreed ?? false,
              revisoes_realizadas: localData.consensusRevisions ?? 0
            }
          } : {} // Content vazio أ”أ¥أ† Core vai extrair via GPT

          console.log(`آ­ئ’أ´أ¨ Dados locais: ${localData?.complaintList?.length || 0} queixas, queixa principal: ${localData?.mainComplaint || 'N/A (GPT vai extrair)'}`)

          // Chamar Edge Function para salvar (com fallback GPT extraction)
          const { supabase } = await import('./supabase')
          supabase.functions.invoke('tradevision-core', {
            body: {
              action: 'finalize_assessment',
              message: 'Finalizing Assessment',
              assessmentData: {
                patient_id: platformData.user.id,
                content: contentPayload,
                scores: { anamnese: 100, detalhamento: 100, consenso: 100 },
                risk_level: 'medium'
              }
            }
          })
            .then(({ data: resp }) => {
              if (resp?.success) {
                console.log(`أ”آ£أ  [SUCESSO] Relatâ”œâ”‚rio salvo. ID: ${resp.report_id} | Mâ”œآ®todo: ${resp.extraction_method}`)
              } else {
                console.error('أ”أکأ® [ERRO] Edge Function retornou erro:', resp?.error)
              }
            })
            .catch(e => console.error('أ”أکأ® [ERRO] Falha na chamada â”œأ، Edge Function:', e))

          // Limpar estado local
          clinicalAssessmentFlow.resetAssessment(platformData.user.id)
        }
      }

      // Usuâ”œأ­rio nunca vâ”œآ¬ nenhum token: remover todos antes de devolver ao hook
      aiContent = stripInvisibleTokensFromResponse(aiContent)

      // Injetar comandos de navegaâ”œآ؛â”œأ؛o pâ”œâ”‚s-AEC para guiar o paciente (botâ”œأپes, sem auto-navigate)
      const postAecCommands: unknown[] = []
      if (isCompleted) {
        postAecCommands.push(
          {
            kind: 'noa_command',
            autoExecute: false,
            command: {
              type: 'navigate-route',
              target: '/app/clinica/paciente/dashboard?section=relatorio',
              label: 'آ­ئ’أ´أ¯ Ver Meu Relatâ”œâ”‚rio'
            }
          },
          {
            kind: 'noa_command',
            autoExecute: false,
            command: {
              type: 'navigate-route',
              target: '/app/clinica/paciente/agendamentos',
              label: 'آ­ئ’أ´أ  Agendar Consulta'
            }
          }
        )
      }

      const mergedAppCommands = [
        ...(appCommandsFromCore.length > 0 ? appCommandsFromCore : (data.app_commands ?? [])),
        ...postAecCommands
      ]

      return {
        id: `tv_${Date.now()}`,
        content: aiContent,
        confidence: 0.98,
        reasoning: 'TradeVision Cloud Master Engine',
        timestamp: new Date(),
        type: 'text',
        metadata: {
          ...data.metadata,
          assessmentCompleted: isCompleted,
          intent: data.metadata?.intent || intent,
          professionalId: data.metadata?.professionalId,
          audited: data.metadata?.audited,
          system: data.metadata?.system,
          app_commands: mergedAppCommands
        }
      }
    } catch (err) {
      const errMsg =
        err instanceof Error
          ? err.message
          : (() => {
            try {
              return JSON.stringify(err)
            } catch {
              return String(err)
            }
          })()

      console.error('أ”أکأ® [TradeVision Cloud] Erro de execuâ”œآ؛â”œأ؛o:', errMsg)

      // Importante: nâ”œأ؛o cair em fallback clâ”œآ،nico/AEC por causa de contexto injetado.
      return this.createResponse(
        'Estou com instabilidade ao conectar ao Core agora. Pode tentar novamente em alguns segundos?\n\n' +
        'Se persistir, me diga qual aâ”œآ؛â”œأ؛o vocâ”œآ¬ estava tentando (ex.: أ”أ‡آ£agendar com Dr. Ricardoأ”أ‡أک) que eu te guio pelo caminho mais curto.',
        0.2,
        'error',
        { source: 'tradevision-core', error: errMsg }
      )
    }
  }

  private async getAssistantResponse(
    userMessage: string,
    intent: string,
    platformData?: any,
    userEmail?: string,
    uiContext?: any,
    platformIntentType: string = 'NONE'
  ): Promise<AIResponse> {
    // آ­ئ’آھأ  [TradeVision Cloud] Todas as requisiâ”œآ؛â”œأپes agora sâ”œأ؛o processadas pelo Core na Nuvem
    return this.processTradeVisionRequest(userMessage, intent, platformData, userEmail, uiContext, platformIntentType);
  }

  private async generateReasoningQuestion(
    prompt: string,
    userResponse: string,
    assessmentContext: IMREAssessmentState
  ): Promise<string> {
    try {
      // Usar a integraâ”œآ؛â”œأ؛o com o Assistant para gerar a pergunta de reasoning
      // Aqui usamos um thread separado ou o mesmo thread contexto "reasoning"
      const response = await this.assistantIntegration.sendMessage(
        prompt,
        'system_reasoning', // Contexto especâ”œآ،fico para reasoning
        `reasoning_${assessmentContext.userId}`
      )

      if (response && response.content) {
        // Limpar possâ”œآ،veis prefixos que o LLM adiciona
        return response.content.replace(/^Pergunta sugerida: /i, '').replace(/^Nâ”œâ”¤a: /i, '').trim()
      }

      throw new Error('Falha ao gerar pergunta via AI')
    } catch (error) {
      console.error('Erro no reasoning:', error)
      // Fallback genâ”œآ®rico caso a IA falhe
      return 'Pode me dar mais detalhes sobre isso?'
    }
  }

  /**
   * Processar etapa METODOLOGIA (M)
   */
  private async processMethodologyStep(
    message: string,
    assessment: IMREAssessmentState,
    platformData: any,
    userEmail?: string
  ): Promise<AIResponse> {
    // 1. Analisar resposta do usuâ”œأ­rio
    assessment.methodology.diagnosticMethods.push(message)

    // 2. Verificar se precisa de mais informaâ”œآ؛â”œأپes (simplificado)
    const needsMore = message.length < 20 && !message.toLowerCase().includes('nâ”œأ؛o')

    if (needsMore) {
      // Gerar pergunta de aprofundamento
      const reasoningQuestion = await this.generateReasoningQuestion(
        `O paciente estâ”œأ­ descrevendo exames/mâ”œآ®todos: "${message}". Gere uma pergunta curta para saber se ele tem resultados de exames recentes.`,
        message,
        assessment
      )
      return this.createResponse(reasoningQuestion, 0.7, 'assessment')
    }

    // 3. Avanâ”œآ؛ar para RESULTADO
    assessment.step = 'RESULT'
    this.platformFunctions.updateAssessmentState(assessment.userId, assessment)

    return this.createResponse(
      'Entendi. Agora vamos para os RESULTADOS. Como vocâ”œآ¬ tem se sentido com o tratamento atual? Houve melhoras ou pioras recentes?',
      0.8,
      'assessment'
    )
  }

  /**
   * Processar etapa RESULTADO (R)
   */
  private async processResultStep(
    message: string,
    assessment: IMREAssessmentState,
    platformData: any,
    userEmail?: string
  ): Promise<AIResponse> {
    // 1. Registrar resultados reportados
    assessment.result.clinicalFindings.push(message)

    // 2. Avanâ”œآ؛ar para EVOLUâ”œأ§â”œأ¢O
    assessment.step = 'EVOLUTION'
    this.platformFunctions.updateAssessmentState(assessment.userId, assessment)

    return this.createResponse(
      'Certo. Para finalizar com a EVOLUâ”œأ§â”œأ¢O: Quais sâ”œأ؛o suas metas principais para os prâ”œâ”‚ximos meses? O que vocâ”œآ¬ espera alcanâ”œآ؛ar?',
      0.8,
      'assessment'
    )
  }

  /**
   * Processar etapa EVOLUâ”œأ§â”œأ¢O (E)
   */
  private async processEvolutionStep(
    message: string,
    assessment: IMREAssessmentState,
    platformData: any,
    userEmail?: string
  ): Promise<AIResponse> {
    // 1. Registrar plano/expectativas
    assessment.evolution.carePlan.push(message)

    // 2. Finalizar avaliaâ”œآ؛â”œأ؛o
    assessment.status = 'completed'
    this.platformFunctions.updateAssessmentState(assessment.userId, assessment)

    // 3. Gerar e salvar relatâ”œâ”‚rio (assâ”œآ،ncrono para nâ”œأ؛o travar)
    this.generateAndSaveReport(assessment).catch(err => console.error('Erro ao salvar relatâ”œâ”‚rio:', err))

    return this.createResponse(
      'Avaliaâ”œآ؛â”œأ؛o completa! أ”آ£آ؟\n\nGerei um relatâ”œâ”‚rio clâ”œآ،nico detalhado com base na nossa conversa. Vou encaminhâ”œأ­-lo para anâ”œأ­lise do Dr. Ricardo Valenâ”œآ؛a.\n\nVocâ”œآ¬ pode visualizar o resumo no seu dashboard. Posso ajudar em algo mais hoje?',
      1.0,
      'assessment'
    )
  }

  private async generateAndSaveReport(assessment: IMREAssessmentState): Promise<void> {
    try {
      const summary = await this.generateClinicalSummary(assessment.userId)
      console.log('آ­ئ’أ´أک Relatâ”œâ”‚rio gerado:', summary)
    } catch (error) {
      console.error('Erro ao gerar relatâ”œâ”‚rio:', error)
    }
  }
}
