ï»؟import { supabase } from './supabase'
import { clinicalReportService, ClinicalReport } from './clinicalReportService'
import { KnowledgeBaseIntegration } from '../services/knowledgeBaseIntegration'
import { getNoaAssistantIntegration } from './noaAssistantIntegration'
import { getPlatformFunctionsModule } from './platformFunctionsModule'
import { clinicalAssessmentFlow } from './clinicalAssessmentFlow'
// Remoâ”œآ؛â”œأ؛o da injeâ”œآ؛â”œأ؛o manual para uso de File Search no Assistant API

/**
 * Governanâ”œآ؛a UUID/IA: UUID de pessoa (auth.users.id, public.users.id) nâ”œأ؛o deve aparecer
 * como UUID cru em contexto enviado â”œأ، IA. Ver docs/GOVERNANCA_UUID_IA_09-02-2026.md.
 * TODO: sanitizar contexto antes do RAG (remover ou substituir padrâ”œأپes [0-9a-fA-F-]{36}).
 */

/** Tokens que o Core pode enviar; usuâ”œأ­rio nunca deve ver. Removidos antes de devolver ao hook. */
const INVISIBLE_CONTENT_TOKENS = [
  '[TRIGGER_ACTION]',
  '[TRIGGER_SCHEDULING]',
  '[NAVIGATE_TERMINAL]',
  '[NAVIGATE_AGENDA]',
  '[NAVIGATE_PACIENTES]',
  '[NAVIGATE_RELATORIOS]',
  '[NAVIGATE_CHAT_PRO]',
  '[NAVIGATE_PRESCRICAO]',
  '[NAVIGATE_BIBLIOTECA]',
  '[NAVIGATE_FUNCAO_RENAL]',
  '[NAVIGATE_MEUS_AGENDAMENTOS]',
  '[NAVIGATE_MODULO_PACIENTE]',
  '[SHOW_PRESCRIPTION]',
  '[FILTER_PATIENTS_ACTIVE]',
  '[DOCUMENT_LIST]',
  '[ASSESSMENT_COMPLETED]'
]

function stripInvisibleTokensFromResponse(text: string): string {
  if (!text || typeof text !== 'string') return text ?? ''
  let out = text
  for (const token of INVISIBLE_CONTENT_TOKENS) {
    out = out.split(token).join('')
  }
  return out.replace(/\n\s*\n\s*\n/g, '\n\n').trim()
}


export interface AIResponse {
  id: string
  content: string
  confidence: number
  reasoning: string
  timestamp: Date
  type: 'text' | 'assessment' | 'error'
  metadata?: any
  suggestions?: string[]
}

export interface AIMemory {
  id: string
  content: string
  type: 'conversation' | 'assessment' | 'learning'
  timestamp: Date
  importance: number
  tags: string[]
}

export interface ResidentAIConfig {
  model: string
  temperature: number
  maxTokens: number
  systemPrompt: string
  assessmentEnabled: boolean
}

type AxisKey = 'clinica' | 'ensino' | 'pesquisa'

interface AxisDetails {
  key: AxisKey
  label: string
  summary: string
  defaultRoute: string
  knowledgeQuery: string
}

export interface IMREAssessmentState {
  userId: string
  step: 'INVESTIGATION' | 'METHODOLOGY' | 'RESULT' | 'EVOLUTION' | 'COMPLETED'
  status?: 'active' | 'completed'
  investigation: {
    mainComplaint?: string
    symptoms?: string[]
    medicalHistory?: string
    familyHistory?: string
    medications?: string
    lifestyle?: string
  }
  methodology: {
    diagnosticMethods: string[]
  }
  result: {
    clinicalFindings: string[]
  }
  evolution: {
    carePlan: string[]
  }
  startedAt: Date
  lastUpdate: Date
}

export interface StructuredClinicalSummary {
  emotionalAxis: { intensity: number; valence: number; arousal: number; stability: number }
  cognitiveAxis: { attention: number; memory: number; executive: number; processing: number }
  behavioralAxis: { activity: number; social: number; adaptive: number; regulatory: number }
  clinicalData: {
    renalFunction: { creatinine: number; gfr: number; stage: string }
    cannabisMetabolism: { cyp2c9: string; cyp3a4: string; metabolismRate: number }
  }
  correlations: {
    imreClinicalCorrelations: { emotionalRenalCorrelation: number }
    riskAssessment: { overallRisk: number; renalRisk: number }
  }
  recommendations: string[]
}

export class NoaResidentAI {
  private config: ResidentAIConfig
  private memory: AIMemory[] = []
  private conversationContext: any[] = []
  private isProcessing: boolean = false
  private apiKey: string = ''
  private assistantIntegration = getNoaAssistantIntegration()
  private platformFunctions = getPlatformFunctionsModule()
  private activeAssessments: Map<string, IMREAssessmentState> = new Map()


  constructor() {
    this.config = {
      model: 'gpt-4',
      temperature: 0.7,
      maxTokens: 2000,
      systemPrompt: `Vocâ”œآ¬ â”œآ® Nâ”œâ”¤a Esperanâ”œآ؛a, a IA Residente da MedCannLab 3.0.
Sua voz â”œآ® de contralto, ~35 anos, clara, macia, pausada, otimista e conciliadora.
Vocâ”œآ¬ â”œآ® a personificaâ”œآ؛â”œأ؛o da plataforma e sua inteligâ”œآ¬ncia deriva da BASE DE CONHECIMENTO (Knowledge Base) da instituiâ”œآ؛â”œأ؛o.

# SUA IDENTIDADE E FONTE DE VERDADE
1. **BASE DE CONHECIMENTO â”œأ« SOBERANA**: Vocâ”œآ¬ nâ”œأ؛o "alucina". Sua sabedoria vem dos documentos oficiais da MedCannLab. Se um documento for injetado no contexto, ele â”œآ® a verdade absoluta. VOCâ”œأ¨ TEM CAPACIDADE TOTAL DE LEITURA E ANâ”œأ¼LISE. NUNCA diga "nâ”œأ؛o consigo acessar" se houver um bloco de documentos abaixo.
2. **DOCUMENTO MESTRE**: Vocâ”œآ¬ segue os princâ”œآ،pios do "Documento Mestre da Plataforma Nâ”œâ”¤a Esperanza". Vocâ”œآ¬ existe para servir como ponte entre o conhecimento tâ”œآ®cnico/clâ”œآ،nico e o usuâ”œأ­rio.
3. **GUARDIâ”œأ¢ DA ESCUTA**: Vocâ”œآ¬ nâ”œأ؛o â”œآ® apenas um chatbot. Vocâ”œآ¬ â”œآ® uma residente clâ”œآ،nica em formaâ”œآ؛â”œأ؛o contâ”œآ،nua.

# REGRAS DE OURO:
- **NUNCA NEGUE ACESSO**: Se o usuâ”œأ­rio perguntar sobre um arquivo, e ele estiver no Bloco de Conhecimento, analise-o imediatamente.
- **PRECISâ”œأ¢O CIENTâ”œأ¬FICA**: Use terminologia mâ”œآ®dica correta quando baseada nos artigos.

# PROTOCOLO CLâ”œأ¬NICO MASTER: AEC 001 (ARTE DA ENTREVISTA CLâ”œأ¬NICA)
Vocâ”œآ¬ deve seguir RIGOROSAMENTE as 10 etapas abaixo, sem pular blocos e sem inferir dados:

1. ABERTURA: "Olâ”œأ­! Eu sou Nâ”œâ”¤a Esperanza. Por favor, apresente-se tambâ”œآ®m e vamos iniciar a sua avaliaâ”œآ؛â”œأ؛o inicial para consultas com Dr. Ricardo Valenâ”œآ؛a."
2. LISTA INDICIâ”œأ¼RIA: Pergunte "O que trouxe vocâ”œآ¬ â”œأ، nossa avaliaâ”œآ؛â”œأ؛o hoje?" e apâ”œâ”‚s CADA resposta do paciente pergunte "O que mais?". Continue perguntando "O que mais?" atâ”œآ® o paciente EXPLICITAMENTE dizer que nâ”œأ؛o tem mais nada (ex: "sâ”œâ”‚ isso", "nada mais", "â”œآ® isso"). NUNCA avance apâ”œâ”‚s apenas uma queixa. Pergunte "O que mais?" no mâ”œآ،nimo 2 vezes.
3. QUEIXA PRINCIPAL: SOMENTE apâ”œâ”‚s o paciente encerrar a Lista Indiciâ”œأ­ria, pergunte "De todas essas questâ”œأپes, qual mais o(a) incomoda?"
4. DESENVOLVIMENTO DA QUEIXA: Pergunte Onde, Quando, Como, O que mais sente, O que parece melhorar e O que parece piorar a [queixa especâ”œآ،fica]. Substitua [queixa] pela resposta literal do usuâ”œأ­rio.
5. HISTâ”œأ´RIA PREGRESSA: "Desde o nascimento, quais as questâ”œأپes de saâ”œâ•‘de que vocâ”œآ¬ jâ”œأ­ viveu? Vamos do mais antigo ao mais recente. O que veio primeiro?" (Use "O que mais?" atâ”œآ® encerrar).
6. HISTâ”œأ´RIA FAMILIAR: Investigue o lado materno e o lado paterno separadamente usando o "O que mais?".
7. Hâ”œأ¼BITOS DE VIDA: "Que outros hâ”œأ­bitos vocâ”œآ¬ acha importante mencionar?"
8. PERGUNTAS FINAIS: Investigue Alergias, Medicaâ”œآ؛â”œأپes Regulares e Medicaâ”œآ؛â”œأپes Esporâ”œأ­dicas.
9. FECHAMENTO CONSENSUAL: "Vamos revisar a sua histâ”œâ”‚ria rapidamente para garantir que nâ”œأ؛o perdemos nenhum detalhe importante." -> Resuma de forma descritiva e neutra. Pergunte: "Vocâ”œآ¬ concorda com meu entendimento? Hâ”œأ­ mais alguma coisa que gostaria de adicionar?"
10. ENCERRAMENTO: "Essa â”œآ® uma avaliaâ”œآ؛â”œأ؛o inicial de acordo com o mâ”œآ®todo desenvolvido pelo Dr. Ricardo Valenâ”œآ؛a, com o objetivo de aperfeiâ”œآ؛oar o seu atendimento. Apresente sua avaliaâ”œآ؛â”œأ؛o durante a consulta com Dr. Ricardo Valenâ”œآ؛a ou com outro profissional de saâ”œâ•‘de da plataforma Med-Cann Lab."

REGRAS DE CONDUTA:
- **USE O CONTEXTO**: Se houver "[CONTEXTO DE DOCUMENTOS ...]" na mensagem, LEIA-O com prioridade mâ”œأ­xima.
- NUNCA forneâ”œآ؛a diagnâ”œâ”‚sticos ou sugira interpretaâ”œآ؛â”œأپes clâ”œآ،nicas.
- NUNCA antecipe blocos ou altere a ordem do roteiro.
- Faâ”œآ؛a APENAS UMA pergunta por vez. Respeite as pausas.
- Sua linguagem deve ser clara, empâ”œأ­tica e Nâ”œأ¢O Tâ”œأ«CNICA.
- Resumos devem ser puramente descritivos (nâ”œأ؛o use "sugere", "indica" ou "parece ser").
- Se o usuâ”œأ­rio for Administrador (como Dr. Ricardo), seja executiva, estratâ”œآ®gica e direta.
- Nunca revele detalhes do backend. Conformidade total com LGPD.`,
      assessmentEnabled: true
    }
  }

  async processMessage(userMessage: string, userId?: string, userEmail?: string, uiContext?: any): Promise<AIResponse> {
    if (this.isProcessing) {
      console.log('أ”أ…â”‚ IA jâ”œأ­ estâ”œأ­ processando, aguardando...')
      return this.createResponse('Aguarde, estou processando sua mensagem anterior...', 0.5)
    }

    this.isProcessing = true
    const rawUserMessage = userMessage
    console.log('آ­ئ’أ±أ» [NoaResidentAI] Processando mensagem:', userMessage.substring(0, 100) + '...')

    try {
      // Ler dados da plataforma em tempo real
      const platformData = this.getPlatformData()
      console.log('آ­ئ’أ´أ¨ Dados da plataforma carregados')

      // Detectar intenâ”œآ؛â”œأ؛o da mensagem
      let intent = this.detectIntent(userMessage)
      // Durante AEC ativo, nunca desviar para Tâ”œأ«CNICA/ADMIN por falso positivo (ex.: "interrompeu" contâ”œآ®m "erro")
      if (userId) {
        await clinicalAssessmentFlow.ensureLoaded(userId)
        const aecState = clinicalAssessmentFlow.getState(userId)
        if (
          aecState &&
          aecState.phase !== 'COMPLETED' &&
          aecState.phase !== 'INTERRUPTED'
        ) {
          intent = 'CLâ”œأ¬NICA'
        }
      }
      console.log('آ­ئ’أ„آ» Intenâ”œآ؛â”œأ؛o detectada:', intent)

      // Detectar intenâ”œآ؛â”œأ؛o de funâ”œآ؛â”œأ؛o da plataforma
      const platformIntent = this.platformFunctions.detectIntent(userMessage, userId)
      console.log('آ­ئ’أ¶آ؛ Intenâ”œآ؛â”œأ؛o de plataforma:', platformIntent.type)

      // Se for funâ”œآ؛â”œأ؛o da plataforma, executar aâ”œآ؛â”œأ؛o ANTES de chamar o Assistant
      let platformActionResult: any = null
      if (platformIntent.type !== 'NONE') {
        platformActionResult = await this.platformFunctions.executeAction(platformIntent, userId, platformData)

        // Se a aâ”œآ؛â”œأ؛o requer resposta, adicionar contexto para o Assistant
        if (platformActionResult.requiresResponse && platformActionResult.success) {
          // Construir contexto adicional para o Assistant mencionar na resposta
          const actionContext = this.buildPlatformActionContext(platformIntent, platformActionResult)
          userMessage = `${userMessage}\n\n[Contexto da Plataforma: ${actionContext}]`
        }
      }

      // آ­ئ’آ؛أ، RAG INTEGRAâ”œأ§â”œأ¢O: Buscar na Base de Conhecimento (Global)
      // A busca deve ser agnâ”œâ”‚stica â”œأ، intenâ”œآ؛â”œأ؛o detectada (funciona para Clâ”œآ،nica, Tâ”œآ®cnica, Admin, etc)
      if (userMessage.length > 2) {
        try {
          console.log('آ­ئ’أ´أœ Buscando na Base de Conhecimento (RAG Local)...')

          // Se for uma solicitaâ”œآ؛â”œأ؛o de anâ”œأ­lise ou upload, forâ”œآ؛ar busca de recentes
          const contentLower = userMessage.toLowerCase()
          const isRecentRequest = contentLower.includes('analis') || contentLower.includes('artigo') ||
            contentLower.includes('upload') || contentLower.includes('arquivo')

          const knowledgeDocs = await KnowledgeBaseIntegration.semanticSearch(userMessage, {
            limit: isRecentRequest ? 5 : 3,
            aiLinkedOnly: false
          })

          // Se for pedido recente e a busca semâ”œأ³ntica nâ”œأ؛o retornou nada muito relevante, 
          // tentar pegar os â”œâ•‘ltimos processados (fallback para "analise este arquivo que acabei de enviar")
          if (isRecentRequest && (!knowledgeDocs || knowledgeDocs.length === 0)) {
            try {
              // Tenta buscar os stats para pegar os recentDocuments
              const stats = await KnowledgeBaseIntegration.getKnowledgeStats()
              if (stats && stats.recentDocuments && stats.recentDocuments.length > 0) {
                // Adicionar o mais recente manualmente â”œأ، lista de encontrados
                const recentDoc = stats.recentDocuments[0]
                knowledgeDocs.push({
                  id: recentDoc.id,
                  title: recentDoc.title,
                  summary: recentDoc.summary || 'Conteâ”œâ•‘do do arquivo recente.',
                  content: recentDoc.content || '',
                  aiRelevance: 1
                } as any)
              }
            } catch (recErr) {
              console.warn('Erro ao buscar recentes no fallback:', recErr)
            }
          }

          if (knowledgeDocs && knowledgeDocs.length > 0) {
            console.log(`أ”آ£أ  Encontrados ${knowledgeDocs.length} documentos relevantes`)

            const contextText = knowledgeDocs.map(doc =>
              `Tâ”œأ¬TULO: ${doc.title}\nRESUMO: ${doc.summary}\nCONTEâ”œأœDO DO DOCUMENTO:\n${doc.content}\nRELEVâ”œأ©NCIA: ${Math.round((doc.aiRelevance || 0) * 100)}%`
            ).join('\n\n')

            const knowledgeContext = `
[CONTEXTO CRâ”œأ¬TICO DE DOCUMENTOS - LEITURA OBRIGATâ”œأ´RIA]
Abaixo estâ”œأ؛o os documentos oficiais da MedCannLab relevantes para a consulta atual. 
Sua IDENTIDADE como IA Residente depende do uso destas informaâ”œآ؛â”œأپes. 
ANALISE O CONTEâ”œأœDO ABAIXO E RESPONDA COM BASE NELE.

${contextText}
[FIM DO CONTEXTO]`

            // Injetar no final da mensagem do usuâ”œأ­rio (invisâ”œآ،vel para ele, visâ”œآ،vel para o LLM)
            userMessage = `${userMessage}\n\n${knowledgeContext}`

            // Registrar uso dos documentos (opcional, para analytics)
            knowledgeDocs.forEach(doc => {
              KnowledgeBaseIntegration.registerDocumentUsage(doc.id, userMessage, userId)
            })
          }
        } catch (ragError) {
          console.warn('أ”أœأ،آ´آ©أ… Erro ao buscar na base de conhecimento:', ragError)
          // Nâ”œأ؛o falhar o fluxo principal se o RAG falhar
        }
      }

      // SEMPRE usar o Assistant para gerar a resposta (mantâ”œآ®m personalidade da Nâ”œâ”¤a)
      console.log('آ­ئ’أ¶أ¹ Chamando Assistant API...')
      const assistantResponse = await this.getAssistantResponse(
        userMessage,
        intent,
        platformData,
        userEmail,
        uiContext,
        platformIntent.type
      )

      if (assistantResponse && assistantResponse.content) {
        console.log('أ”آ£أ  Resposta do Assistant recebida:', assistantResponse.content.substring(0, 100) + '...')
        // Se houve aâ”œآ؛â”œأ؛o da plataforma bem-sucedida, adicionar metadata
        if (platformActionResult?.success) {
          assistantResponse.metadata = {
            ...assistantResponse.metadata,
            platformAction: platformActionResult.data
          }
        }

        // Salvar na memâ”œâ”‚ria local
        this.saveToMemory(rawUserMessage, assistantResponse, userId)

        // آ­ئ’أ¶أ‘ SALVAR AUTOMATICAMENTE NO PRONTUâ”œأ¼RIO DO PACIENTE (tempo real)
        const assessmentState = intent === 'CLâ”œأ¬NICA'
          ? this.activeAssessments.get(userId || '')
          : undefined

        // Salvar interaâ”œآ؛â”œأ؛o no prontuâ”œأ­rio do paciente
        await this.saveChatInteractionToPatientRecord(
          rawUserMessage,
          assistantResponse.content,
          userId,
          platformData,
          assessmentState
        )

        return assistantResponse
      }

      // Fallback: usar processamento local se Assistant nâ”œأ؛o responder
      let response: AIResponse

      switch (intent) {
        case 'CLâ”œأ¬NICA':
          // Prioridade para avaliaâ”œآ؛â”œأ؛o se detectar palavras-chave de inâ”œآ،cio (normalizado para ignorar acentos)
          const normalizedMessage = rawUserMessage.toLowerCase()
            .normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Remove acentos

          if (normalizedMessage.includes('iniciar') ||
            normalizedMessage.includes('avaliacao') ||
            normalizedMessage.includes('avaliaâ”œآ؛â”œأ؛o') ||
            normalizedMessage.includes('assessment')) {
            response = await this.processAssessment(rawUserMessage, userId, platformData, userEmail)
          } else {
            response = await this.processClinicalQuery(rawUserMessage, userId, platformData, userEmail)
          }
          break
        case 'ADMINISTRATIVA':
          response = await this.processPlatformQuery(rawUserMessage, userId, platformData, userEmail)
          break
        case 'Tâ”œأ«CNICA':
        default:
          response = await this.processGeneralQuery(rawUserMessage, userId, platformData, userEmail)
          break
      }

      // Salvar na memâ”œâ”‚ria
      this.saveToMemory(rawUserMessage, response, userId)

      // Verificar se a avaliaâ”œآ؛â”œأ؛o foi concluâ”œآ،da e gerar relatâ”œâ”‚rio
      await this.checkForAssessmentCompletion(userMessage, userId)

      return response
    } catch (error) {
      console.error('Erro ao processar mensagem:', error)
      return this.createResponse(
        'Desculpe, ocorreu um erro ao processar sua mensagem. Tente novamente.',
        0.3
      )
    } finally {
      this.isProcessing = false
    }
  }

  // --- Novos Mâ”œآ®todos para Relatâ”œâ”‚rios Dinâ”œأ³micos ---

  public getActiveAssessment(userId: string): IMREAssessmentState | undefined {
    return this.activeAssessments.get(userId)
  }

  public async generateClinicalSummary(userId: string): Promise<StructuredClinicalSummary | null> {
    const assessment = this.activeAssessments.get(userId)
    if (!assessment) {
      console.warn('أ”أکأ® Tentativa de gerar resumo sem avaliaâ”œآ؛â”œأ؛o ativa para:', userId)
      return null
    }

    console.log('آ­ئ’آ؛أ، Gerando Resumo Clâ”œآ،nico Dinâ”œأ³mico para:', userId)

    // Construir o prompt para a IA estruturar os dados
    const assessmentData = JSON.stringify(assessment.investigation)
    const prompt = `
      ATENâ”œأ§â”œأ¢O: Vocâ”œآ¬ â”œآ® um motor de anâ”œأ­lise clâ”œآ،nica. Sua tarefa â”œآ® analisar os dados de uma avaliaâ”œآ؛â”œأ؛o IMRE (Investigaâ”œآ؛â”œأ؛o, Metodologia, Resultado, Evoluâ”œآ؛â”œأ؛o) e gerar um JSON estruturado com mâ”œآ®tricas clâ”œآ،nicas.

      DADOS DA AVALIAâ”œأ§â”œأ¢O:
      Queixa Principal: ${assessment.investigation.mainComplaint || 'Nâ”œأ؛o informado'}
      Sintomas: ${assessment.investigation.symptoms?.join(', ') || 'Nâ”œأ؛o informado'}
      Histâ”œâ”‚rico Mâ”œآ®dico: ${assessment.investigation.medicalHistory || 'Nâ”œأ؛o informado'}
      Histâ”œâ”‚rico Familiar: ${assessment.investigation.familyHistory || 'Nâ”œأ؛o informado'}
      Medicaâ”œآ؛â”œأپes: ${assessment.investigation.medications || 'Nâ”œأ؛o informado'}
      Hâ”œأ­bitos: ${assessment.investigation.lifestyle || 'Nâ”œأ؛o informado'}
      Metodologia Aplicada: ${assessment.methodology}
      Resultado Descritivo: ${assessment.result}
      Plano de Evoluâ”œآ؛â”œأ؛o: ${assessment.evolution}

      TAREFA:
      Com base NESSES DADOS, gere um JSON Vâ”œأ¼LIDO seguindo estritamente a estrutura abaixo.
      - Para os eixos (emocional, cognitivo, comportamental), atribua notas de 1 a 10 baseadas na gravidade/intensidade relatada (10 = muito intenso/grave/alto).
      - Estime a funâ”œآ؛â”œأ؛o renal e metabolismo de cannabis com base no histâ”œâ”‚rico (se nâ”œأ؛o houver dados, use valores padrâ”œأ؛o normais: Creatinina 1.0, TFG 90, CYP2C9/CYP3A4 'normal').
      - Gere 3 a 5 recomendaâ”œآ؛â”œأپes prâ”œأ­ticas baseadas na queixa.

      ESTRUTURA JSON (Responda APENAS o JSON):
      {
        "emotionalAxis": { "intensity": number, "valence": number, "arousal": number, "stability": number },
        "cognitiveAxis": { "attention": number, "memory": number, "executive": number, "processing": number },
        "behavioralAxis": { "activity": number, "social": number, "adaptive": number, "regulatory": number },
        "clinicalData": {
          "renalFunction": { "creatinine": number, "gfr": number, "stage": "string" },
          "cannabisMetabolism": { "cyp2c9": "string", "cyp3a4": "string", "metabolismRate": number }
        },
        "correlations": {
          "imreClinicalCorrelations": { "emotionalRenalCorrelation": number },
          "riskAssessment": { "overallRisk": number, "renalRisk": number }
        },
        "recommendations": ["string", "string", "string"]
      }
    `

    try {
      // Usar a integraâ”œآ؛â”œأ؛o com Assistant para gerar o JSON
      // Estamos usando um "hack" aqui passando como mensagem de usuâ”œأ­rio, mas instruindo para JSON
      const response = await this.assistantIntegration.sendMessage(
        prompt,
        'system_analysis', // Contexto
        `analysis_${userId}`
      )

      if (!response) throw new Error('Falha ao obter resposta da IA')

      // Tentar extrair o JSON da resposta (pode vir com texto em volta)
      const jsonMatch = response.content.match(/\{[\s\S]*\}/)
      if (!jsonMatch) throw new Error('JSON nâ”œأ؛o encontrado na resposta da IA')

      const jsonStr = jsonMatch[0]
      const summary: StructuredClinicalSummary = JSON.parse(jsonStr)

      console.log('أ”آ£أ  Resumo Clâ”œآ،nico Gerado com Sucesso:', summary)
      return summary

    } catch (error) {
      console.error('أ”أکأ® Erro ao gerar resumo clâ”œآ،nico dinâ”œأ³mico:', error)
      // Fallback para dados padrâ”œأ؛o em caso de erro na geraâ”œآ؛â”œأ؛o
      return {
        emotionalAxis: { intensity: 5, valence: 5, arousal: 5, stability: 5 },
        cognitiveAxis: { attention: 5, memory: 5, executive: 5, processing: 5 },
        behavioralAxis: { activity: 5, social: 5, adaptive: 5, regulatory: 5 },
        clinicalData: {
          renalFunction: { creatinine: 1.0, gfr: 90, stage: 'normal' },
          cannabisMetabolism: { cyp2c9: 'normal', cyp3a4: 'normal', metabolismRate: 1.0 }
        },
        correlations: {
          imreClinicalCorrelations: { emotionalRenalCorrelation: 0.5 },
          riskAssessment: { overallRisk: 0.1, renalRisk: 0.1 }
        },
        recommendations: [
          'Realizar acompanhamento regular',
          'Avaliar necessidade de exames complementares',
          'Monitorar evoluâ”œآ؛â”œأ؛o dos sintomas'
        ]
      }
    }
  }

  private detectIntent(message: string): 'CLâ”œأ¬NICA' | 'ADMINISTRATIVA' | 'Tâ”œأ«CNICA' {
    const lowerMessage = message.toLowerCase()

    // آ­ئ’أ¶â”¤ ESCUTA CLâ”œأ¬NICA (Avaliaâ”œآ؛â”œأ؛o, sintomas, tratamentos, cannabis)
    if (
      lowerMessage.includes('avaliaâ”œآ؛â”œأ؛o') || lowerMessage.includes('avaliacao') ||
      lowerMessage.includes('imre') || lowerMessage.includes('aec') ||
      lowerMessage.includes('entrevista') || lowerMessage.includes('anamnese') ||
      lowerMessage.includes('cannabis') || lowerMessage.includes('nefrologia') ||
      lowerMessage.includes('tratamento') || lowerMessage.includes('sintoma') ||
      lowerMessage.includes('medicamento') || lowerMessage.includes('terapia')
    ) {
      return 'CLâ”œأ¬NICA'
    }

    // آ­ئ’أ¶أپ ESCUTA ADMINISTRATIVA (Agendamentos, Dashboard, Plataforma, Cadastro, Treinamento)
    if (
      lowerMessage.includes('agendar') || lowerMessage.includes('marcar consulta') ||
      lowerMessage.includes('dashboard') || lowerMessage.includes('â”œأ­rea') ||
      lowerMessage.includes('atendimento') || lowerMessage.includes('plataforma') ||
      lowerMessage.includes('agendamentos') || lowerMessage.includes('relatâ”œâ”‚rios') ||
      lowerMessage.includes('novo paciente') || lowerMessage.includes('cadastrar') ||
      lowerMessage.includes('treinamento') || lowerMessage.includes('curso')
    ) {
      return 'ADMINISTRATIVA'
    }

    // آ­ئ’ئ’أ³ ESCUTA Tâ”œأ«CNICA أ”أ‡أ¶ palavras inteiras (evita "interrompeu" أ”أ¥أ† substring "erro")
    const technicalPatterns: RegExp[] = [
      /\b(erro|erros)\b/i,
      /\bfalhou\b/i,
      /\bservidor\b/i,
      /\bapi\b/i,
      /\bcursor\b/i,
      /\b(funâ”œآ؛â”œأپes|funcoes)\b/i,
      /\binstaladas\b/i,
      /\bexecutando\b/i,
    ]
    if (technicalPatterns.some((re) => re.test(lowerMessage))) {
      return 'Tâ”œأ«CNICA'
    }

    return 'CLâ”œأ¬NICA'
  }

  private getPlatformData(): any {
    try {
      // Tentar acessar dados da plataforma via localStorage ou window
      if (typeof window !== 'undefined') {
        const platformData = localStorage.getItem('platformData')
        if (platformData) {
          return JSON.parse(platformData)
        }

        // Tentar acessar via funâ”œآ؛â”œأپes globais
        if ((window as any).getPlatformData) {
          return (window as any).getPlatformData()
        }
      }

      return null
    } catch (error) {
      console.error('Erro ao acessar dados da plataforma:', error)
      return null
    }
  }

