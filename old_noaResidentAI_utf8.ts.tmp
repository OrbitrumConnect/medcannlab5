  private async processTrainingQuery(message: string, userId?: string, platformData?: any, userEmail?: string): Promise<AIResponse> {
    const lowerMessage = message.toLowerCase()

    // Detectar contexto do curso Jardins de Cura
    const isJardinsDeCuraContext = lowerMessage.includes('jardins de cura') ||
      lowerMessage.includes('jardins-de-cura') ||
      lowerMessage.includes('curso jardins') ||
      lowerMessage.includes('projeto jardins') ||
      platformData?.currentRoute?.includes('jardins-de-cura') ||
      platformData?.currentRoute?.includes('jardins-de-cura')

    // Detectar contexto especâ”œآ،fico de dengue/ACS
    const isDengueACSContext = lowerMessage.includes('dengue') ||
      lowerMessage.includes('acs') ||
      lowerMessage.includes('agente comunitâ”œأ­rio') ||
      lowerMessage.includes('prevenâ”œآ؛â”œأ؛o dengue')

    if (isJardinsDeCuraContext || isDengueACSContext) {
      return this.createResponse(
        'Estou aqui para apoiâ”œأ­-lo no **Programa de Formaâ”œآ؛â”œأ؛o para Agentes Comunitâ”œأ­rios de Saâ”œâ•‘de** do projeto **Jardins de Cura**.\n\n' +
        '**Sobre o Curso:**\n' +
        'أ”أ‡أ³ Programa de 40 horas / 5 semanas\n' +
        'أ”أ‡أ³ 9 mâ”œâ”‚dulos focados em Prevenâ”œآ؛â”œأ؛o e Cuidado de Dengue\n' +
        'أ”أ‡أ³ Integrado com a metodologia Arte da Entrevista Clâ”œآ،nica (AEC)\n' +
        'أ”أ‡أ³ Alinhado com as Diretrizes Nacionais para Prevenâ”œآ؛â”œأ؛o e Controle de Dengue\n\n' +
        '**Como posso ajudar:**\n' +
        'أ”أ‡أ³ Explicar mâ”œâ”‚dulos e conteâ”œâ•‘dos do curso\n' +
        'أ”أ‡أ³ Simular entrevistas clâ”œآ،nicas com pacientes\n' +
        'أ”أ‡أ³ Orientar sobre protocolos de prevenâ”œآ؛â”œأ؛o de dengue\n' +
        'أ”أ‡أ³ Aplicar tâ”œآ®cnicas da AEC em cenâ”œأ­rios prâ”œأ­ticos\n' +
        'أ”أ‡أ³ Responder dâ”œâ•‘vidas sobre o projeto Jardins de Cura\n\n' +
        'Em que posso ajudâ”œأ­-lo hoje?',
        0.95,
        'text'
      )
    }

    // Implementar treinamento especializado geral
    return this.createResponse(
      'Estou aqui para treinâ”œأ­-lo em metodologias clâ”œآ،nicas avanâ”œآ؛adas, incluindo a Arte da Entrevista Clâ”œآ،nica, protocolos de cannabis medicinal e prâ”œأ­ticas de nefrologia sustentâ”œأ­vel. Qual â”œأ­rea vocâ”œآ¬ gostaria de aprofundar?',
      0.9,
      'text'
    )
  }

  private isAdminUser(email?: string, userType?: string): boolean {
    if (!email && !userType) return false
    const adminEmails = ['ricardo.valenca@medcannlab.com.br', 'admin@medcannlab.com.br', 'phpg69@gmail.com', 'phpg69@hotmail.com'] // Example list
    return userType === 'admin' || (email ? adminEmails.includes(email) : false)
  }

  private extractKnowledgeQuery(message: string, context: string): string {
