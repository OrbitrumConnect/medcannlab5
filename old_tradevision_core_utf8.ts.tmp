п»ҝ// TRADEVISION CORE: VERSв”ңГўO MASTER (PRODUв”ңГ§в”ңГўO)
// Deno.serve() Г”ГҮГ¶ API nativa do runtime (recomendado pela documentaв”ңВәв”ңГәo Supabase)
import { createClient } from "https://esm.sh/@supabase/supabase-js@2"
import OpenAI from "https://esm.sh/openai@4"
import { COS, COS_Context } from "./cos_kernel.ts"

const corsHeaders = {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

// Contrato institucional (IMUTв”ңГјVEL): token base de agendamento
const TRIGGER_SCHEDULING_TOKEN = '[TRIGGER_SCHEDULING]'
// Token universal de aв”ңВәв”ңГәo governada (app_commands/metadata) Г”ГҮГ¶ sinal visual para o front; nв”ңГәo dispara execuв”ңВәв”ңГәo por si sв”ңв”Ӯ
const TRIGGER_ACTION_TOKEN = '[TRIGGER_ACTION]'

// Triggers semв”ңГіnticos emitidos pelo GPT (modelo correto: GPT decide Г”ГҘГҶ Core governa Г”ГҘГҶ app_commands a partir do trigger).
// Alinhamento: avaliaв”ңВәв”ңГәo clв”ңВЎnica e agendamento sв”ңГәo modelos selados (nв”ңГәo editar). Todo o resto (terminal, abas, navegaв”ңВәв”ңГәo, documentos)
// usa a mesma lв”ңв”Ӯgica Г”ГҮГ¶ GPT emite tag Г”ГҘГҶ parseTriggersFromGPTResponse Г”ГҘГҶ stripGPTTriggerTags Г”ГҘГҶ filterAppCommandsByRole. Um fluxo, vв”ңГӯrios triggers.
const GPT_TRIGGERS = {
    NAVIGATE_TERMINAL: '[NAVIGATE_TERMINAL]',
    NAVIGATE_AGENDA: '[NAVIGATE_AGENDA]',
    NAVIGATE_PACIENTES: '[NAVIGATE_PACIENTES]',
    NAVIGATE_RELATORIOS: '[NAVIGATE_RELATORIOS]',
    NAVIGATE_CHAT_PRO: '[NAVIGATE_CHAT_PRO]',
    NAVIGATE_PRESCRICAO: '[NAVIGATE_PRESCRICAO]',
    NAVIGATE_BIBLIOTECA: '[NAVIGATE_BIBLIOTECA]',
    NAVIGATE_FUNCAO_RENAL: '[NAVIGATE_FUNCAO_RENAL]',
    NAVIGATE_MEUS_AGENDAMENTOS: '[NAVIGATE_MEUS_AGENDAMENTOS]',
    NAVIGATE_MODULO_PACIENTE: '[NAVIGATE_MODULO_PACIENTE]',
    SHOW_PRESCRIPTION: '[SHOW_PRESCRIPTION]',
    FILTER_PATIENTS_ACTIVE: '[FILTER_PATIENTS_ACTIVE]',
    DOCUMENT_LIST: '[DOCUMENT_LIST]',
    SIGN_DOCUMENT: '[SIGN_DOCUMENT]',
    CHECK_CERTIFICATE: '[CHECK_CERTIFICATE]',
} as const

const PROFESSIONAL_DASHBOARD_ROUTE = '/app/clinica/profissional/dashboard'

/** Gera app_commands A PARTIR dos triggers emitidos pelo GPT (modelo selado). */
function parseTriggersFromGPTResponse(aiResponse: string): AppCommandV1[] {
    const commands: AppCommandV1[] = []
    if (!aiResponse || typeof aiResponse !== 'string') return commands
    const text = aiResponse
    if (text.includes(GPT_TRIGGERS.NAVIGATE_TERMINAL)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'atendimento', label: 'Atendimento', fallbackRoute: PROFESSIONAL_DASHBOARD_ROUTE }, reason: 'gpt_trigger_navigate_terminal' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_AGENDA)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'agendamentos', label: 'Agenda', fallbackRoute: '/app/clinica/profissional/agendamentos' }, reason: 'gpt_trigger_navigate_agenda' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_PACIENTES)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'pacientes', label: 'Pacientes', fallbackRoute: '/app/clinica/profissional/pacientes' }, reason: 'gpt_trigger_navigate_pacientes' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_RELATORIOS)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'relatorios-clinicos', label: 'Relatв”ңв”Ӯrios', fallbackRoute: '/app/clinica/profissional/relatorios' }, reason: 'gpt_trigger_navigate_relatorios' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_CHAT_PRO)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'chat-profissionais', label: 'Chat Profissionais', fallbackRoute: '/app/clinica/profissional/chat-profissionais' }, reason: 'gpt_trigger_navigate_chat_pro' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_PRESCRICAO)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'prescricao-rapida', label: 'Prescrever', fallbackRoute: '/app/clinica/prescricoes' }, reason: 'gpt_trigger_navigate_prescription' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_BIBLIOTECA)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'admin-upload', label: 'Biblioteca', fallbackRoute: '/app/library' }, reason: 'gpt_trigger_navigate_biblioteca' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_FUNCAO_RENAL)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-section', target: 'admin-renal', label: 'Funв”ңВәв”ңГәo Renal', fallbackRoute: PROFESSIONAL_DASHBOARD_ROUTE }, reason: 'gpt_trigger_navigate_renal' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_MEUS_AGENDAMENTOS)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-route', target: '/app/clinica/paciente/agendamentos', label: 'Meus agendamentos', fallbackRoute: '/app/clinica/paciente/agendamentos' }, reason: 'gpt_trigger_meus_agendamentos' })
    }
    if (text.includes(GPT_TRIGGERS.NAVIGATE_MODULO_PACIENTE)) {
        commands.push({ kind: 'noa_command', command: { type: 'navigate-route', target: '/app/clinica/paciente/dashboard?section=analytics', label: 'Mв”ңв”Ӯdulo Paciente', fallbackRoute: '/app/clinica/paciente/dashboard?section=analytics' }, reason: 'gpt_trigger_modulo_paciente' })
    }
    if (text.includes(GPT_TRIGGERS.SHOW_PRESCRIPTION)) {
        commands.push({ kind: 'noa_command', command: { type: 'show-prescription', target: 'latest', label: 'Mostrar prescriв”ңВәв”ңГәo' }, reason: 'gpt_trigger_show_prescription' })
    }
    if (text.includes(GPT_TRIGGERS.FILTER_PATIENTS_ACTIVE)) {
        commands.push({ kind: 'noa_command', command: { type: 'filter-patients', target: 'active', label: 'Filtrar pacientes ativos', payload: { filter: 'active' } }, reason: 'gpt_trigger_filter_patients' })
    }
    if (text.includes(GPT_TRIGGERS.DOCUMENT_LIST)) {
        commands.push({ kind: 'noa_command', command: { type: 'document-list', label: 'Lista de documentos' }, reason: 'gpt_trigger_document_list' })
    }
    if (text.includes(GPT_TRIGGERS.SIGN_DOCUMENT)) {
        commands.push({ kind: 'noa_command', command: { type: 'sign-document', label: 'Assinar documento digitalmente' }, reason: 'gpt_trigger_sign_document' })
    }
    if (text.includes(GPT_TRIGGERS.CHECK_CERTIFICATE)) {
        commands.push({ kind: 'noa_command', command: { type: 'check-certificate', label: 'Verificar certificado digital' }, reason: 'gpt_trigger_check_certificate' })
    }
    return commands
}

/** Remove todos os triggers emitidos pelo GPT do texto (usuв”ңГӯrio nunca vв”ңВ¬). */
function stripGPTTriggerTags(text: string): string {
    if (!text || typeof text !== 'string') return text || ''
    let out = text
    for (const tag of Object.values(GPT_TRIGGERS)) {
        out = out.replace(new RegExp(tag.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), '')
    }
    return out.replace(/\n\s*\n\s*\n/g, '\n\n').trim()
}

/** Anexa TRIGGER_ACTION ao texto quando hв”ңГӯ app_commands, para sinalizar aв”ңВәв”ңГҒes disponв”ңВЎveis (UX consistente). */
function textWithActionToken(text: string, app_commands?: unknown[]): string {
    if (!text || !app_commands?.length) return text || ''
    const trimmed = (text || '').trim()
    return trimmed.endsWith(TRIGGER_ACTION_TOKEN) ? trimmed : `${trimmed} ${TRIGGER_ACTION_TOKEN}`
}

type NoaUiCommand =
    | { type: 'navigate-section'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'navigate-route'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'show-prescription'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'filter-patients'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'open-document'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'show-document-inline'; target: string; label?: string; fallbackRoute?: string; payload?: Record<string, unknown> }
    | { type: 'document-list'; target?: string; label?: string; payload?: Record<string, unknown> }
    | { type: 'sign-document'; target?: string; label?: string; payload?: Record<string, unknown> }
    | { type: 'sign-document'; target?: string; label?: string; payload?: Record<string, unknown> }
    | { type: 'check-certificate'; target?: string; label?: string; payload?: Record<string, unknown> }

type AppCommandV1 = {
    kind: 'noa_command'
    command: NoaUiCommand
    requires_confirmation?: boolean
    reason?: string
}

type PendingActionCandidate = {
    document_id: string
    title: string
    summary?: string
    content?: string
    audience?: string[]
    category?: string | null
    score?: number
}

const DOC_PENDING_KIND = 'DOC_OPEN_CONFIRMATION'

const normalizeRole = (value: unknown): 'admin' | 'professional' | 'student' | 'patient' | 'master' | 'unknown' => {
    const raw = typeof value === 'string' ? value : ''
    const norm = normalizePt(raw)
    if (norm.includes('master')) return 'master'
    if (norm.includes('admin')) return 'admin'
    if (norm.includes('profissional') || norm.includes('professional')) return 'professional'
    if (norm.includes('aluno') || norm.includes('student')) return 'student'
    if (norm.includes('paciente') || norm.includes('patient')) return 'patient'
    return 'unknown'
}

const parseConfirmationSelection = (norm: string): { kind: 'number'; value: number } | { kind: 'cancel' } | null => {
    // Aceita "1", "2", "abrir 1", "abre o 2", "opcao 3", "o 2", "doc 2", "documento 2", "quero o 1", "cancelar"
    // Sв”ңв”Ӯ palavras explв”ңВЎcitas de cancelamento (evitar falso positivo: "nв”ңГәo vejo o agendamento" nв”ңГәo deve cancelar doc)
    if (/\b(cancelar|cancela|cancel)\b/.test(norm)) return { kind: 'cancel' }

    const direct = norm.trim().match(/^(\d{1,2})$/)
    if (direct) {
        const n = parseInt(direct[1], 10)
        if (Number.isFinite(n)) return { kind: 'number', value: n }
    }

    const embedded = norm.match(/\b(abrir|abre|opcao|opв”ңВәв”ңГәo|numero|n[в”ңв•‘u]mero)\s*(\d{1,2})\b/)
    if (embedded) {
        const n = parseInt(embedded[2], 10)
        if (Number.isFinite(n)) return { kind: 'number', value: n }
    }

    // "o 2", "doc 2", "documento 2", "abrir o 2", "quero o 2"
    const oDoc = norm.match(/\b(o|doc|documento)\s*(\d{1,2})\b/)
    if (oDoc) {
        const n = parseInt(oDoc[2], 10)
        if (Number.isFinite(n)) return { kind: 'number', value: n }
    }
    const queroO = norm.match(/\b(quero|queria)\s+(o\s+)?(\d{1,2})\b/)
    if (queroO) {
        const n = parseInt(queroO[3], 10)
        if (Number.isFinite(n)) return { kind: 'number', value: n }
    }

    return null
}

const detectDocumentRequest = (norm: string): boolean => {
    // Detecв”ңВәв”ңГәo conservadora (fail-closed): sв”ңв”Ӯ ativa com verbos/nomes explв”ңВЎcitos de documento
    const wantsOpen = /\b(abrir|abre|ver|mostrar|mostra|acessar|acesso|ler|consultar|buscar|trazer|traga|quero\s+ver|gostaria\s+de\s+ver|preciso\s+ver|me\s+traga|me\s+traz)\b/.test(norm)
    const mentionsDoc = /\b(documento|documentos|doc|docs|protocolo|diretriz|guideline|manual|aula|material|conteudo|conteв”ңв•‘do|pdf)\b/.test(norm)
    return wantsOpen && mentionsDoc
}

const detectDocumentListRequest = (norm: string): boolean => {
    // Pedidos de listagem/visв”ңГәo geral Г”ГҮГ¶ ainda в”ңВ® Г”ГҮВЈetapa 1Г”ГҮГҳ (lista curta + confirmaв”ңВәв”ңГәo)
    // Ex.: "quais documentos vocв”ңВ¬ vв”ңВ¬", "listar documentos", "que documentos tem", "me mostre os documentos"
    const asksList =
        /\b(listar|lista|ver|mostrar|mostra|quais|que|me\s+mostre|me\s+mostra|trazer|traga|me\s+traga|me\s+traz)\b/.test(norm) &&
        /\b(documentos|documento|docs|doc)\b/.test(norm)
    const asksWhatYouSee =
        /\b(quais|que)\b/.test(norm) && /\b(voce|vocв”ңВ¬)\b/.test(norm) && /\b(ve|vв”ңВ¬|tem|consegue)\b/.test(norm)
    const asksWhatExists = /\b(que\s+documentos|quais\s+materiais|tem\s+algum\s+documento)\b/.test(norm)
    return asksList || asksWhatYouSee || asksWhatExists
}

/** Pedido de total/quantidade de documentos na base (ex.: "quantos documentos temos", "listagem do total") */
const detectDocumentCountRequest = (norm: string): boolean => {
    return (
        /\b(quantos|quanto|total|totais|listagem\s+do\s+total|quantidade)\b/.test(norm) &&
        /\b(documentos|documento|docs|doc|temos|tem\s+na\s+base)\b/.test(norm)
    )
}

/** Detecta pedido de avaliaв”ңВәв”ңГәo clв”ңВЎnica / DRC / nefro / renal */
const detectClinicalAssessmentRequest = (norm: string): boolean => {
    const evalTerms = /\b(avaliacao|avaliar|avaliacao clinica)\b/
    const renalTerms = /\b(renal|nefro|nefrolog|rim|rins|funcao renal|drc|doenca renal)\b/
    const drcDirect = /\b(drc|doenca renal cronica|estagio renal|estadiamento renal)\b/
    return (evalTerms.test(norm) && renalTerms.test(norm)) || drcDirect.test(norm)
}

/** Pedido para ver os prв”ңв”Ӯximos 5 documentos (ex.: "listar mais", "prв”ңв”Ӯximos 5", "outros 5") */
const detectListMoreRequest = (norm: string): boolean => {
    return /\b(listar\s+mais|proximos\s+5|outros\s+5|mais\s+5|ver\s+mais\s+documentos|mais\s+documentos)\b/.test(norm)
}

/** Heurв”ңВЎstica para detectar intenв”ңВәв”ңГәo de assinar documento */
function detectSignIntent(norm: string): boolean {
    return /(assinar|assinatura|certificado|icp|brasil|assinatura digital|certificado digital|assinar prescriв”ңВәв”ңГәo|assinar receita|assinar atestado|assinar laudo|assinatura icp)/i.test(norm)
}

/** Determina nв”ңВЎvel do documento baseado no tipo e perfil do usuв”ңГӯrio */
function determineDocumentLevel(
    documentType: string | undefined,
    userRole: string
): 'level_1' | 'level_2' | 'level_3' {
    // Nв”ңВЎvel 3: Documentos legais (CFM) - requerem certificado ICP-Brasil
    if (['prescription', 'prescriв”ңВәв”ңГәo', 'receita', 'atestado', 'laudo', 'cfm_prescriptions'].includes(documentType?.toLowerCase() || '')) {
        return 'level_3'
    }
    // Nв”ңВЎvel 2: Documentos administrativos simples
    if (['declaracao', 'declaraв”ңВәв”ңГәo', 'relatorio_informativo', 'relatв”ңв”Ӯrio informativo'].includes(documentType?.toLowerCase() || '')) {
        return 'level_2'
    }
    // Nв”ңВЎvel 1: Documentos clв”ңВЎnicos internos (padrв”ңГәo)
    return 'level_1'
}

const buildCandidatesListText = (candidates: PendingActionCandidate[]) => {
    const lines = candidates.map((c, i) => `${i + 1}) ${c.title}${c.category ? ` Г”ГҮГ¶ (${c.category})` : ''}`)
    return `Vocв”ңВ¬ deseja abrir qual documento?\n\n${lines.join('\n')}\n\nResponda com o nв”ңв•‘mero (1-${candidates.length}) ou diga "cancelar".`
}

/** Fluxo documental governado por trigger: quando o GPT emite [DOCUMENT_LIST], busca lista + pending e devolve texto para injetar. Se sв”ңв”Ӯ houver 1 doc, devolve singleDoc para abrir direto no chat. */
async function runDocumentListFlowFromTrigger(
    supabaseClient: ReturnType<typeof createClient>,
    userId: string,
    userRole: string,
    searchTerm: string,
    _currentIntent: string
): Promise<{ listText: string; singleDoc?: { document_id: string; title: string; summary?: string; content?: string; category?: string | null } } | null> {
    try {
        let baseQuery = supabaseClient
            .from('documents')
            .select('id, title, summary, category, target_audience, is_published, aiRelevance, file_url, file_type, created_at, updated_at')
            .limit(200)

        if (!searchTerm.trim()) {
            baseQuery = baseQuery.order('created_at', { ascending: false }).order('aiRelevance', { ascending: false })
        } else {
            baseQuery = baseQuery.or(`title.ilike.*${searchTerm}*,summary.ilike.*${searchTerm}*`)
        }

        const { data: docs } = await baseQuery
        const listRaw = (docs || [])
            .filter((d: any) => !!d?.id && !!d?.title)
            .filter((d: any) => {
                if (userRole === 'patient' || userRole === 'student') {
                    const aud = Array.isArray(d.target_audience) ? d.target_audience : []
                    const allowed = aud.includes(userRole) || aud.includes('all')
                    const published = d.is_published === true
                    return allowed && published
                }
                return true
            })
            .sort((a: any, b: any) => {
                const af = a.file_url ? 1 : 0
                const bf = b.file_url ? 1 : 0
                if (bf !== af) return bf - af
                const r = Number(b.aiRelevance || 0) - Number(a.aiRelevance || 0)
                if (r !== 0) return r
                const at = new Date(a.updated_at || a.created_at || 0).getTime()
                const bt = new Date(b.updated_at || b.created_at || 0).getTime()
                return bt - at
            })

        const seen = new Set<string>()
        const list = listRaw.filter((d: any) => {
            const key = String(d.title || '').trim().toLowerCase()
            if (!key) return false
            if (seen.has(key)) return false
            seen.add(key)
            return true
        }).slice(0, 5)

        if (list.length === 0) return null

        // Fetch content only for the 5 selected docs
        const docIds = list.map((d: any) => d.id)
        const { data: contentDocs } = await supabaseClient
            .from('documents')
            .select('id, content')
            .in('id', docIds)
        const contentMap = new Map((contentDocs || []).map((d: any) => [d.id, d.content]))

        const candidates: PendingActionCandidate[] = list.map((d: any, idx: number) => ({
            document_id: d.id,
            title: d.title,
            summary: d.summary,
            content: contentMap.get(d.id) || null,
            audience: Array.isArray(d.target_audience) ? d.target_audience : [],
            category: d.category ?? null,
            score: (d.aiRelevance ?? 0) * 10 + (d.file_url ? 3 : 0) + (5 - idx)
        }))

        const expiresAt = new Date(Date.now() + 3 * 60 * 1000).toISOString()
        await supabaseClient.from('noa_pending_actions').insert({
            user_id: userId,
            kind: DOC_PENDING_KIND,
            status: 'pending',
            candidates,
            context: { role: userRole, term: searchTerm, list_offset: 0 },
            expires_at: expiresAt
        })

        const listText = buildCandidatesListText(candidates)
        const singleDoc = candidates.length === 1 && searchTerm.trim()
            ? {
                document_id: candidates[0].document_id,
                title: candidates[0].title,
                summary: candidates[0].summary,
                content: candidates[0].content,
                category: candidates[0].category
            }
            : undefined
        return { listText, singleDoc }
    } catch (e) {
        console.warn('Г”ГңГЎВҙВ©Г… [DOC FLOW] runDocumentListFlowFromTrigger:', e)
        return null
    }
}

const sanitizeSearchTerm = (value: string) => {
    return (value || '')
        .replace(/\r?\n+/g, ' ')
        .replace(/[,*()]/g, ' ')
        .replace(/["'\\]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim()
        .slice(0, 80)
}

/** Extrai termo de documento da resposta do GPT quando ela diz que vai "abrir o documento X" mas nв”ңГәo emitiu [DOCUMENT_LIST]. */
function extractDocumentTermFromGPTResponse(aiResponse: string): string | null {
    if (!aiResponse || typeof aiResponse !== 'string') return null
    const norm = aiResponse.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    const hasOpenDoc = /\b(abrir|vou abrir|abrindo)\s+(o\s+)?documento\b/.test(norm) || /\bdocumento\s+["']([^"']+)["']/.test(norm)
    if (!hasOpenDoc) return null
    // Tв”ңВЎtulo entre aspas: "documento 'Prв”ңв”Ӯximos Passos'" ou "documento \"X\""
    const quoted = aiResponse.match(/documento\s+["']([^"']+)["']/i) || aiResponse.match(/abrir\s+(?:o\s+)?documento\s+["']?([^"'.!\n]+)["']?/i)
    if (quoted?.[1]) return sanitizeSearchTerm(quoted[1])
    // в”ңГңltima frase apв”ңв”Ӯs "documento" como fallback (palavras atв”ңВ® ponto/vв”ңВЎrgula)
    const afterDoc = aiResponse.split(/\bdocumento\b/i).pop()?.trim()
    if (afterDoc) {
        const firstPhrase = afterDoc.replace(/^[\s"']+/, '').split(/[.,;!?\n]/)[0]?.trim()
        if (firstPhrase && firstPhrase.length >= 2 && firstPhrase.length <= 80) return sanitizeSearchTerm(firstPhrase)
    }
    return null
}

const normalizePt = (value: string) =>
    value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "")

const stripInjectedContext = (value: string) => {
    // Objetivo: garantir que heurв”ңВЎsticas (intent/triggers/app_commands) derivem APENAS do input humano.
    // O frontend pode injetar blocos como "[contexto_da_plataforma]:" e RAG pode injetar "[CONTEXTO ...]".
    const raw = value || ""
    const lowered = raw.toLowerCase()

    const markers = [
        "[contexto da plataforma",
        "[contexto_da_plataforma]",
        "[contexto_da_plataforma]:",
        "[contexto crв”ңВЎtico",
        "[contexto critico",
        "[fim do contexto]"
    ]

    let cut = raw.length
    for (const marker of markers) {
        const idx = lowered.indexOf(marker)
        if (idx >= 0 && idx < cut) cut = idx
    }
    return raw.slice(0, cut).trim()
}

const clampInt = (value: number, min: number, max: number) => {
    const n = Number.isFinite(value) ? Math.trunc(value) : 0
    return Math.max(min, Math.min(max, n))
}

type InteractionSignal = {
    score: number
    signals: string[]
    traits: Record<string, boolean>
    suggestedDelta: number
}

// CAS (Estado de Interaв”ңВәв”ңГәo): heurв”ңВЎstica determinв”ңВЎstica (nв”ңГәo-diagnв”ңв”Ӯstica)
const deriveInteractionSignals = (norm: string): InteractionSignal => {
    const signals: string[] = []

    const metaCognitive = [
        'sou o jogo',
        'sou o processo',
        'tudo depende de mim',
        'estado desperto',
        'lucidez',
        'observacao',
        'observacao interna',
        'existencia',
        'limite humano'
    ]

    for (const s of metaCognitive) {
        if (norm.includes(s)) signals.push(s)
    }

    const score = signals.length
    const traits: Record<string, boolean> = {
        meta_cognitive_language: score >= 2,
        explicit_limits: norm.includes('limite') || norm.includes('nao consigo') || norm.includes('nв”ңГәo consigo'),
        urgency_language: norm.includes('urgente') || norm.includes('agora') || norm.includes('socorro')
    }

    // Delta pequeno, sempre conservador (fail-closed)
    const suggestedDelta = score >= 2 ? 10 : score === 1 ? 5 : 0

    return { score, signals, traits, suggestedDelta }
}

/**
 * Governanв”ңВәa por perfil (PROTOCOLO / PLANO_MESTRE): filtra quais comandos o perfil pode executar.
 * REGRA: Nв”ңГўO remove nenhuma lв”ңв”Ӯgica nem palavras que acionam os triggers.
 * deriveAppCommandsV1 continua com TODAS as frases/triggers; esta funв”ңВәв”ңГәo sв”ңв”Ӯ esconde comandos
 * que o perfil nв”ңГәo tem permissв”ңГәo (ex.: paciente nв”ңГәo recebe "abrir agenda" de profissional).
 */
function filterAppCommandsByRole(commands: AppCommandV1[], role: string): AppCommandV1[] {
    const r = role === 'master' ? 'admin' : role
    // Admin: todos os comandos
    if (r === 'admin') return commands
    // Profissional: tudo exceto rotas exclusivas de admin (ex.: funв”ңВәв”ңГәo renal se restrito)
    if (r === 'professional') {
        return commands.filter(cmd => {
            const t = cmd.command.type
            const target = (cmd.command as { target?: string }).target || ''
            const fallback = (cmd.command as { fallbackRoute?: string }).fallbackRoute || ''
            // admin-renal: sв”ңв”Ӯ admin (conservador)
            if (t === 'navigate-section' && target === 'admin-renal') return false
            return true
        })
    }
    // Paciente: sв”ңв”Ӯ aв”ңВәв”ңГҒes de paciente Г”ГҮГ¶ meus agendamentos, biblioteca (navegaв”ңВәв”ңГәo), lista de documentos; NUNCA terminal pro, prescriв”ңВәв”ңГәo, filtro pacientes
    if (r === 'patient') {
        return commands.filter(cmd => {
            const t = cmd.command.type
            const target = (cmd.command as { target?: string }).target || ''
            const fallback = (cmd.command as { fallbackRoute?: string }).fallbackRoute || ''
            if (t === 'document-list' || t === 'show-document-inline') return true
            if (t === 'show-prescription' || t === 'filter-patients') return false
            if (t === 'navigate-section') {
                if (target === 'admin-upload' || fallback.includes('/app/library')) return true
                return false
            }
            if (t === 'navigate-route') {
                if (target.startsWith('/app/clinica/paciente/')) return true
                if (target.startsWith('/app/library')) return true
                return false
            }
            return false
        })
    }
    // Aluno: igual paciente para navegaв”ңВәв”ңГәo segura; sem comandos de pro; pode ver lista de documentos e abrir doc no chat
    if (r === 'student') {
        return commands.filter(cmd => {
            const t = cmd.command.type
            const target = (cmd.command as { target?: string }).target || ''
            const fallback = (cmd.command as { fallbackRoute?: string }).fallbackRoute || ''
            if (t === 'document-list' || t === 'show-document-inline') return true
            if (t === 'show-prescription' || t === 'filter-patients') return false
            if (t === 'navigate-section') {
                if (target === 'admin-upload' || (fallback && fallback.includes('/app/library'))) return true
                return false
            }
            if (t === 'navigate-route') {
                if (target.startsWith('/app/library')) return true
                return false
            }
            return false
        })
    }
    // unknown / nв”ңГәo mapeado: FAIL-CLOSED Г”ГҮГ¶ nв”ңГәo devolver comandos privilegiados (PLANO_MESTRE S9)
    console.warn(`[SECURITY] filterAppCommandsByRole: role desconhecida "${role}" Г”ГҮГ¶ retornando lista vazia (fail-closed).`)
    return []
}

const deriveAppCommandsV1 = (message: string, ui_context?: any, userRole?: string): AppCommandV1[] => {
    // Seguranв”ңВәa: app_commands deve ser derivado APENAS da fala do usuв”ңГӯrio, nв”ңГәo de blocos injetados (RAG/contexto).
    const safeMessage = stripInjectedContext(message || "")
    const norm = normalizePt(safeMessage)

    const commands: AppCommandV1[] = []

    // Rotas canв”ңв”Өnicas do Terminal (fallback quando nв”ңГәo houver listener ativo)
    const PROFESSIONAL_DASHBOARD_ROUTE = '/app/clinica/profissional/dashboard'

    // Terminal de Atendimento (MVP) Г”ГҮГ¶ comandos seguros (UI/read-only)
    if (/(terminal de atendimento|abrir atendimento|area de atendimento|в”ңГӯrea de atendimento|ir para atendimento)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'atendimento',
                label: 'Atendimento',
                fallbackRoute: PROFESSIONAL_DASHBOARD_ROUTE
            },
            reason: 'user_requested_attendance_terminal'
        })
    }

    // LUGAR = ir para a aba/calendв”ңГӯrio (nв”ңГәo card). Inclui "ver agendamento", "me levar para agendamento", "agendamento".
    if (/(abrir agenda|minha agenda|agenda clinica|agenda da clinica|agenda da minha clinica|minha clinica|ver agenda|ver agendamento|me levar para agendamento|levar para agendamento|quero ver agendamento|ir para agendamento|terminal de agendamento|terminal de agendamentos|area de agendamento|в”ңГӯrea de agendamento)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'agendamentos',
                label: 'Agenda',
                fallbackRoute: '/app/clinica/profissional/agendamentos'
            },
            reason: 'user_requested_schedule_section'
        })
    }

    if (/(pacientes|abrir pacientes|gestao de pacientes|gestв”ңГәo de pacientes|lista de pacientes)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'pacientes',
                label: 'Pacientes',
                fallbackRoute: '/app/clinica/profissional/pacientes'
            },
            reason: 'user_requested_patients_section'
        })
    }

    if (/(relatorios|relatв”ңв”Ӯrios|relatorio clinico|relatв”ңв”Ӯrio clв”ңВЎnico|abrir relatorios)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'relatorios-clinicos',
                label: 'Relatв”ңв”Ӯrios Clв”ңВЎnicos',
                fallbackRoute: '/app/clinica/profissional/relatorios'
            },
            reason: 'user_requested_reports_section'
        })
    }

    if (/(chat profissionais|chat com profissionais|abrir chat profissionais|suporte profissional)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'chat-profissionais',
                label: 'Chat Profissionais',
                fallbackRoute: '/app/clinica/profissional/chat-profissionais'
            },
            reason: 'user_requested_professional_chat_section'
        })
    }

    // Heurв”ңВЎstica para detectar intenв”ңВәв”ңГәo de assinar documento
    // NOTA: aiResponse nв”ңГәo estв”ңГӯ disponв”ңВЎvel neste escopo, entв”ңГәo sв”ңв”Ӯ verificamos detectSignIntent
    if (detectSignIntent(norm)) {
        // Determinar documento atual (do contexto)
        const currentDocument = ui_context?.current_document || ui_context?.document_in_chat

        if (currentDocument) {
            const documentLevel = determineDocumentLevel(
                currentDocument.type || 'prescription',
                userRole || 'unknown'
            )

            commands.push({
                kind: 'noa_command',
                command: {
                    type: 'sign-document',
                    label: 'Assinar documento digitalmente',
                    payload: {
                        document_id: currentDocument.id,
                        document_level: documentLevel,
                        requires_certificate: documentLevel === 'level_3'
                    }
                },
                reason: 'user_requested_digital_signature'
            })
        } else {
            // Sem documento especв”ңВЎfico no contexto, mas usuв”ңГӯrio quer assinar
            commands.push({
                kind: 'noa_command',
                command: {
                    type: 'sign-document',
                    label: 'Assinar documento digitalmente',
                    payload: {
                        document_level: 'level_3', // Padrв”ңГәo para prescriв”ңВәв”ңГҒes
                        requires_certificate: true
                    }
                },
                reason: 'user_requested_digital_signature'
            })
        }
    }

    if (/(prescrever|nova prescricao|nova prescriв”ңВәв”ңГәo|prescricao rapida|prescriв”ңВәв”ңГәo rв”ңГӯpida)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'prescricao-rapida',
                label: 'Prescrever',
                fallbackRoute: '/app/clinica/prescricoes'
            },
            reason: 'user_requested_quick_prescription'
        })
    }

    if (/(base de conhecimento|abrir biblioteca|acessar biblioteca|biblioteca compartilhada)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'admin-upload',
                label: 'Biblioteca Compartilhada',
                fallbackRoute: '/app/library'
            },
            reason: 'user_requested_library'
        })
    }

    if (/(funcao renal|funв”ңВәв”ңГәo renal|abrir funcao renal|abrir funв”ңВәв”ңГәo renal)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-section',
                target: 'admin-renal',
                label: 'Funв”ңВәв”ңГәo Renal',
                fallbackRoute: PROFESSIONAL_DASHBOARD_ROUTE
            },
            reason: 'user_requested_renal_section'
        })
    }

    if (/(mostrar prescric|abrir prescric|ver prescric|mostrar protocolo)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'show-prescription',
                target: 'latest',
                label: 'Mostrar в”ңв•‘ltima prescriв”ңВәв”ңГәo'
            },
            reason: 'user_requested_prescription'
        })
    }

    if (/(pacientes ativos|listar pacientes ativos|filtrar pacientes ativos|pacientes em atendimento)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'filter-patients',
                target: 'active',
                label: 'Filtrar pacientes ativos',
                payload: { filter: 'active' }
            },
            reason: 'user_requested_active_patients_filter'
        })
    }

    // Mв”ңв”Ӯdulo Paciente (view-as / acesso ao dashboard do paciente)
    if (/(modulo paciente|mв”ңв”Ӯdulo paciente|modo paciente|ver como paciente|dashboard paciente)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-route',
                target: '/app/clinica/paciente/dashboard?section=analytics',
                label: 'Mв”ңв”Ӯdulo Paciente',
                fallbackRoute: '/app/clinica/paciente/dashboard?section=analytics'
            },
            reason: 'user_requested_patient_module'
        })
    }

    // Paciente: LUGAR = ir para a aba Meus agendamentos (ver agendamento, me levar para agendamento, agendamento, etc.)
    if (/(meus agendamentos|minhas consultas|consultas agendadas|ver agendamentos|abrir agendamentos|ver agendamento|me levar para agendamento|levar para agendamento|quero ver agendamento|ir para agendamento|agenda do paciente|agenda paciente|agendamentos do paciente)/.test(norm)) {
        commands.push({
            kind: 'noa_command',
            command: {
                type: 'navigate-route',
                target: '/app/clinica/paciente/agendamentos',
                label: 'Meus agendamentos',
                fallbackRoute: '/app/clinica/paciente/agendamentos'
            },
            reason: 'user_requested_patient_appointments'
        })
    }

    return commands
}

Deno.serve(async (req: Request) => {
    // Handle CORS preflight
    if (req.method === 'OPTIONS') {
        return new Response('ok', { headers: corsHeaders })
    }

    try {
        // [TITAN 3.2] Geraв”ңВәв”ңГәo de ID в”ңГңnico para Rastreabilidade Atв”ңв”Өmica
        const interaction_id = crypto.randomUUID();

        // 1. Validar Variв”ңГӯveis de Ambiente
        const supabaseUrl = Deno.env.get('SUPABASE_URL')
        const supabaseServiceKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')
        const openaiApiKey = Deno.env.get('OPENAI_API_KEY')

        if (!supabaseUrl || !supabaseServiceKey || !openaiApiKey) {
            throw new Error('Variв”ңГӯveis de ambiente (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY) nв”ңГәo configuradas.')
        }

        // Variв”ңГӯveis de Modelo Globais (CCOS Feature Flag)
        const MODEL_NAME = Deno.env.get('AI_MODEL_NAME_RISK') || "gpt-4o"
        const CHAT_MODEL = Deno.env.get('AI_MODEL_NAME_CHAT') || "gpt-4o"

        // 2. Inicializar Clientes
        const supabaseClient = createClient(supabaseUrl, supabaseServiceKey)
        const openai = new OpenAI({ apiKey: openaiApiKey })

        // Г”Г¶ГҮГ”Г¶ГҮ S4 FIX: VALIDAв”ңГ§в”ңГўO JWT OBRIGATв”ңГҙRIA (PLANO_MESTRE) Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ
        // Rejeitar qualquer request sem Authorization header vв”ңГӯlido.
        // Backward-compat REMOVIDO Г”ГҮГ¶ produв”ңВәв”ңГәo exige autenticaв”ңВәв”ңГәo.
        const authHeader = req.headers.get('Authorization')
        if (!authHeader?.startsWith('Bearer ')) {
            console.error('[SECURITY] Requisiв”ңВәв”ңГәo sem Authorization header Г”ГҮГ¶ REJEITADA (401)')
            return new Response(JSON.stringify({ error: 'Unauthorized', message: 'Token de autenticaв”ңВәв”ңГәo obrigatв”ңв”Ӯrio.' }), {
                status: 401,
                headers: { ...corsHeaders, 'Content-Type': 'application/json' }
            })
        }

        let jwtUserId: string | null = null
        try {
            const anonKey = Deno.env.get('SUPABASE_ANON_KEY') || supabaseServiceKey
            const anonClient = createClient(supabaseUrl, anonKey, {
                global: { headers: { Authorization: authHeader } }
            })
            const token = authHeader.replace('Bearer ', '')
            const { data: claimsData, error: claimsError } = await anonClient.auth.getClaims(token)
            if (!claimsError && claimsData?.claims?.sub) {
                jwtUserId = claimsData.claims.sub as string
            } else {
                console.error(`[SECURITY] JWT invв”ңГӯlido ou expirado: ${claimsError?.message}`)
                return new Response(JSON.stringify({ error: 'Unauthorized', message: 'Token invв”ңГӯlido ou expirado.' }), {
                    status: 401,
                    headers: { ...corsHeaders, 'Content-Type': 'application/json' }
                })
            }
        } catch (jwtErr) {
            console.error('[SECURITY] Falha ao validar JWT:', jwtErr)
            return new Response(JSON.stringify({ error: 'Unauthorized', message: 'Erro na validaв”ңВәв”ңГәo do token.' }), {
                status: 401,
                headers: { ...corsHeaders, 'Content-Type': 'application/json' }
            })
        }

        // 3. Autenticaв”ңВәв”ңГәo e Verificaв”ңВәв”ңГәo de Kill Switch (CCOS Governanв”ңВәa)
        const { data: config } = await supabaseClient
            .from('system_config')
            .select('value')
            .eq('key', 'ai_mode')
            .single()

        const aiMode = config?.value?.mode || 'FULL'

        // Parse do Body (Necessв”ңГӯrio para o contexto do COS)
        const body = await req.json()
        const {
            message,
            conversationHistory: convFromBody,
            patientData: patFromBody,
            assessmentPhase,
            nextQuestionHint: nextQuestionHintFromBody,
            action,
            assessmentData,
            appointmentData,
            ui_context
        } = body
        let nextQuestionHint = nextQuestionHintFromBody
        // Compat: noaEngine e clientes antigos enviam `history` e `context`
        const conversationHistory = convFromBody ?? body.history ?? []
        const patientData = patFromBody ?? body.context ?? {}
        const professionalId = appointmentData?.professional_id || patientData?.professional_id || 'system-global'

        // Г”Г¶ГҮГ”Г¶ГҮ S4 FIX: Amarrar identidade JWT ao userId operado Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ
        // Se JWT foi validado, FORв”ңГ§AR que o userId operado seja o do token
        // (impede impersonaв”ңВәв”ңГәo via body). Log de discrepв”ңГіncia para auditoria.
        const bodyUserId = patientData?.user?.id
        if (jwtUserId && bodyUserId && jwtUserId !== bodyUserId) {
            console.warn(`[SECURITY] JWT sub (${jwtUserId}) Г”Г«ГЎ body user.id (${bodyUserId}) Г”ГҮГ¶ usando JWT como fonte de verdade`)
        }
        const authenticatedUserId = jwtUserId || bodyUserId || null

        // Perfil do usuв”ңГӯrio (fonte canв”ңв”Өnica para governanв”ңВәa de app_commands) Г”ГҮГ¶ conforme PLANO_MESTRE / PROTOCOLO
        const userRole =
            normalizeRole(patientData?.user?.user_type) ||
            normalizeRole(patientData?.user?.type) ||
            normalizeRole(patientData?.user?.role)
        // Tipo real do usuв”ңГӯrio (sem "ver como") Г”ГҮГ¶ usado para governanв”ңВәa documental
        const realUserRole =
            normalizeRole(patientData?.user?.real_type) || userRole

        // --- ВӯЖ’Г®ГҰ COS v1.0: CAMADA IV - PROTOCOLO DE TRAUMA (SOBREVIVв”ңГЁNCIA) ---
        const { data: trauma } = await supabaseClient
            .from('institutional_trauma_log')
            .select('*')
            .eq('restricted_mode_active', true)
            .gt('recovery_estimated_at', new Date().toISOString())
            .maybeSingle()

        // --- ВӯЖ’В®В© COS v1.0: CAMADA III - METABOLISMO COGNITIVO (REGULAв”ңГ§в”ңГўO) ---
        const { data: metabolism } = await supabaseClient
            .from('cognitive_metabolism')
            .select('*')
            .eq('professional_id', professionalId)
            .maybeSingle()

        // ======================================================
        // ВӯЖ’ВәГЎ INTENT Г”ГҮГ¶ DEFINIDO UMA в”ңГңNICA VEZ (ANTES DO COS)
        // ======================================================
        let currentIntent: "CLINICA" | "ADMIN" | "ENSINO" = "CLINICA"
        // Seguranв”ңВәa: intent/triggers devem derivar APENAS da fala do usuв”ңГӯrio (sem blocos injetados).
        const msg = stripInjectedContext(message || "").toLowerCase()
        const norm = msg.normalize("NFD").replace(/[\u0300-\u036f]/g, "")

        // ======================================================
        // ВӯЖ’ВәГЎ CAS Г”ГҮГ¶ Estado de Interaв”ңВәв”ңГәo (tom/profundidade/estilo)
        // ======================================================
        // - Nв”ңГәo в”ңВ® diagnв”ңв”Ӯstico / nв”ңГәo в”ңВ® saв”ңв•‘de mental
        // - Apenas modula linguagem e aumenta observabilidade
        // - Fail-closed: se falhar, nв”ңГәo afeta o funcionamento do app
        let interactionDepthLevel = 0
        let interactionTraits: Record<string, boolean> = {}
        let interactionSignals: string[] = []

        const interactionSignal = deriveInteractionSignals(norm)
        if (interactionSignal.score > 0 && patientData?.user?.id) {
            interactionSignals = interactionSignal.signals
            interactionTraits = interactionSignal.traits
        }

        if (patientData?.user?.id) {
            try {
                const { data: existingState, error: stateReadError } = await supabaseClient
                    .from('cognitive_interaction_state')
                    .select('depth_level, traits')
                    .eq('user_id', patientData.user.id)
                    .maybeSingle()

                if (!stateReadError && existingState) {
                    interactionDepthLevel = clampInt(existingState.depth_level ?? 0, 0, 100)
                    interactionTraits = { ...(existingState.traits ?? {}), ...interactionTraits }
                }

                // Atualizar state somente quando houver sinal (append-only via event + update state)
                if (interactionSignal.suggestedDelta > 0) {
                    const nextLevel = clampInt(interactionDepthLevel + interactionSignal.suggestedDelta, 0, 100)
                    interactionDepthLevel = nextLevel

                    // Non-blocking audit pulse
                    try {
                        await supabaseClient.from('cognitive_events').insert({
                            intent: currentIntent,
                            action: 'INTERACTION_STATE_SIGNAL',
                            decision_result: 'SIGNAL',
                            source: 'SMART_TRIGGER',
                            metadata: {
                                user_id: patientData.user.id,
                                score: interactionSignal.score,
                                signals: interactionSignals,
                                suggested_delta: interactionSignal.suggestedDelta,
                                next_level: nextLevel,
                                traits: interactionTraits
                            }
                        })
                    } catch (e) {
                        console.warn('Г”ГңГЎВҙВ©Г… [CEP NON-BLOCKING] Falha ao registrar INTERACTION_STATE_SIGNAL:', e)
                    }

                    // Upsert state (non-blocking)
                    try {
                        await supabaseClient
                            .from('cognitive_interaction_state')
                            .upsert({
                                user_id: patientData.user.id,
                                depth_level: nextLevel,
                                traits: interactionTraits,
                                last_shift_at: new Date().toISOString()
                            }, { onConflict: 'user_id' })
                    } catch (e) {
                        console.warn('Г”ГңГЎВҙВ©Г… [CAS NON-BLOCKING] Falha ao upsert cognitive_interaction_state:', e)
                    }
                }
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [CAS NON-BLOCKING] Falha ao ler/atualizar cognitive_interaction_state:', e)
            }
        }

        if (norm.includes("nivelamento") || norm.includes("simulacao") || norm.includes("prova")) {
            currentIntent = "ENSINO"
        } else if (
            norm.includes("agendar") ||
            norm.includes("marcar") ||
            norm.includes("consulta") ||
            norm.includes("horario") ||
            norm.includes("disponibilidade") ||
            norm.includes("medico") ||
            norm.includes("doutor") ||
            action === "predict_scheduling_risk"
        ) {
            currentIntent = "ADMIN"
        }

        // ======================================================
        // ВӯЖ’ГҙГӨ ATIVAв”ңГ§в”ңГўO DOCUMENTAL (append-only, fail-closed)
        // - Nв”ңГәo interfere em scheduling
        // - Sв”ңв”Ӯ executa abertura de documento apв”ңв”Ӯs confirmaв”ңВәв”ңГәo humana (nв”ңв•‘mero/cancelar)
        // - Derivaв”ңВәв”ңГәo apenas do INPUT HUMANO (message, sem blocos injetados)
        // ======================================================
        const selection = parseConfirmationSelection(norm)
        const isDocRequest = detectDocumentRequest(norm)
        const isDocListRequest = detectDocumentListRequest(norm)
        const isDocCountRequest = detectDocumentCountRequest(norm)
        // Pedido de analisar/avaliar o documento jв”ңГӯ aberto no chat Г”ГҘГҶ nв”ңГәo devolver lista; deixar o GPT analisar (com document_in_chat no prompt)
        const isAnalyzeOpenDocRequest = !!(ui_context?.document_in_chat?.title && /\b(analis(e|ar)|avali(ar|e)|resum(a|ir)|comente|o que acha|interpretar)\b/i.test(norm))

        console.log(`ВӯЖ’ГҙГӨ [DOC DETECT] isDocRequest=${isDocRequest}, isDocListRequest=${isDocListRequest}, isAnalyzeOpen=${isAnalyzeOpenDocRequest}, userId=${!!patientData?.user?.id}, realUserRole=${realUserRole}, userRole=${userRole}, normSnippet="${norm.substring(0, 80)}"`)


        // 0) Total de documentos na base (ex.: "quantos documentos temos?")
        if (isDocCountRequest) {
            try {
                let countQuery = supabaseClient.from('documents').select('*', { count: 'exact', head: true })
                if (realUserRole === 'patient' || realUserRole === 'student') {
                    countQuery = countQuery.eq('is_published', true)
                }
                const { count, error: countErr } = await countQuery
                if (!countErr && typeof count === 'number') {
                    return new Response(JSON.stringify({
                        text: `Temos atualmente **${count}** documento(s) na base. Vocв”ңВ¬ pode pedir pelo nв”ңв•‘mero (ex.: 1, 2, 3), pelo nome do documento, ou dizer "listar documentos" para eu mostrar os primeiros 5 Г”ГҮГ¶ e depois "listar mais" para ver os prв”ңв”Ӯximos 5.`,
                        metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                    }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                }
            } catch (_) { }
        }

        // 1b) "Listar mais" Г”ГҮГ¶ prв”ңв”Ӯximos 5 documentos (quando jв”ңГӯ hв”ңГӯ lista pendente)
        const isListMoreRequest = detectListMoreRequest(norm)
        if (isListMoreRequest && patientData?.user?.id) {
            try {
                const { data: pending } = await supabaseClient
                    .from('noa_pending_actions')
                    .select('id, context')
                    .eq('user_id', patientData.user.id)
                    .eq('kind', DOC_PENDING_KIND)
                    .eq('status', 'pending')
                    .gt('expires_at', new Date().toISOString())
                    .order('created_at', { ascending: false })
                    .limit(1)
                    .maybeSingle()
                if (pending?.id) {
                    const ctx = (pending.context || {}) as { term?: string; list_offset?: number }
                    const term = String(ctx.term || '').trim()
                    const listOffset = Math.max(0, Number(ctx.list_offset) || 0)
                    const nextOffset = listOffset + 5

                    let baseQuery = supabaseClient
                        .from('documents')
                        .select('id, title, summary, category, target_audience, is_published, aiRelevance, file_url, file_type, created_at, updated_at')
                        .limit(500)
                    if (!term) {
                        baseQuery = baseQuery.order('created_at', { ascending: false }).order('aiRelevance', { ascending: false })
                    } else {
                        baseQuery = baseQuery.or(`title.ilike.*${term}*,summary.ilike.*${term}*`)
                    }
                    const { data: docs } = await baseQuery
                    const listRaw = (docs || [])
                        .filter((d: any) => !!d?.id && !!d?.title)
                        .filter((d: any) => {
                            if (realUserRole === 'patient' || realUserRole === 'student') {
                                const aud = Array.isArray(d.target_audience) ? d.target_audience : []
                                const allowed = aud.includes(userRole) || aud.includes('all')
                                const published = d.is_published === true
                                return allowed && published
                            }
                            return true
                        })
                        .sort((a: any, b: any) => {
                            const af = a.file_url ? 1 : 0
                            const bf = b.file_url ? 1 : 0
                            if (bf !== af) return bf - af
                            const r = Number(b.aiRelevance || 0) - Number(a.aiRelevance || 0)
                            if (r !== 0) return r
                            const at = new Date(a.updated_at || a.created_at || 0).getTime()
                            const bt = new Date(b.updated_at || b.created_at || 0).getTime()
                            return bt - at
                        })
                    const seen = new Set<string>()
                    const fullList = listRaw.filter((d: any) => {
                        const key = String(d.title || '').trim().toLowerCase()
                        if (!key) return false
                        if (seen.has(key)) return false
                        seen.add(key)
                        return true
                    })
                    const nextFive = fullList.slice(nextOffset, nextOffset + 5)
                    if (nextFive.length === 0) {
                        return new Response(JSON.stringify({
                            text: 'Nв”ңГәo hв”ңГӯ mais documentos nesta lista. Vocв”ңВ¬ pode pedir pelo nв”ңв•‘mero da lista anterior (ex.: 1, 2) ou dizer "listar documentos" para recomeв”ңВәar.',
                            metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                        }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                    }
                    // Fetch content only for these 5 docs
                    const nextDocIds = nextFive.map((d: any) => d.id)
                    const { data: nextContentDocs } = await supabaseClient
                        .from('documents')
                        .select('id, content')
                        .in('id', nextDocIds)
                    const nextContentMap = new Map((nextContentDocs || []).map((d: any) => [d.id, d.content]))

                    const candidates: PendingActionCandidate[] = nextFive.map((d: any, idx: number) => ({
                        document_id: d.id,
                        title: d.title,
                        summary: d.summary,
                        content: nextContentMap.get(d.id) || null,
                        audience: Array.isArray(d.target_audience) ? d.target_audience : [],
                        category: d.category ?? null,
                        score: (d.aiRelevance ?? 0) * 10 + (d.file_url ? 3 : 0) + (5 - idx)
                    }))
                    await supabaseClient
                        .from('noa_pending_actions')
                        .update({
                            candidates,
                            context: { ...ctx, list_offset: nextOffset },
                            expires_at: new Date(Date.now() + 3 * 60 * 1000).toISOString()
                        })
                        .eq('id', pending.id)
                    const listText = buildCandidatesListText(candidates) + "\n\nDiga \"listar mais\" para ver os prв”ңв”Ӯximos 5."
                    return new Response(JSON.stringify({
                        text: listText,
                        metadata: {
                            intent: currentIntent,
                            system: 'TradeVision Core V2',
                            audited: true,
                            documents_total: fullList.length,
                            documents_block_size: 5
                        }
                    }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                }
            } catch (_) { }
        }

        // 1) Confirmaв”ңВәв”ңГәo (etapa 2): usuв”ңГӯrio responde "1/2/3", "o 2", "doc 2" ou "cancelar"
        if (selection && patientData?.user?.id) {
            try {
                const { data: pending } = await supabaseClient
                    .from('noa_pending_actions')
                    .select('id, candidates, expires_at, status')
                    .eq('user_id', patientData.user.id)
                    .eq('kind', DOC_PENDING_KIND)
                    .eq('status', 'pending')
                    .gt('expires_at', new Date().toISOString())
                    .order('created_at', { ascending: false })
                    .limit(1)
                    .maybeSingle()

                if (!pending) {
                    // Sem lista de documentos pendente: sв”ңв”Ӯ devolver fallback se usuв”ңГӯrio tentou nв”ңв•‘mero (ex.: "2" com lista expirada).
                    // Se disse sв”ңв”Ӯ "cancelar" (ex.: "cancelar minha consulta"), nв”ңГәo responder aqui Г”ГҮГ¶ deixar o GPT tratar.
                    if (selection.kind === 'cancel') {
                        // Nв”ңГәo retornar; fluxo segue para o GPT (agendamento, consulta, etc.)
                    } else {
                        return new Response(JSON.stringify({
                            text: 'Entendi. Para abrir um documento, me diga qual documento vocв”ңВ¬ quer (nome/tema) e eu te mostro as opв”ңВәв”ңГҒes para confirmar.',
                            metadata: {
                                intent: currentIntent,
                                system: 'TradeVision Core V2',
                                audited: true
                            }
                        }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                    }
                } else if (selection.kind === 'cancel') {
                    await supabaseClient
                        .from('noa_pending_actions')
                        .update({ status: 'cancelled' })
                        .eq('id', pending.id)

                    // CEP (non-blocking)
                    try {
                        await supabaseClient.from('cognitive_events').insert({
                            intent: currentIntent,
                            action: 'DOC_OPEN_CANCELLED',
                            decision_result: 'CANCELLED',
                            source: 'USER_CONFIRMATION',
                            metadata: { pending_action_id: pending.id }
                        })
                    } catch (_) { }

                    return new Response(JSON.stringify({
                        text: 'Perfeito Г”ГҮГ¶ cancelado.',
                        metadata: {
                            intent: currentIntent,
                            system: 'TradeVision Core V2',
                            audited: true
                        }
                    }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                } else {
                    // Temos pending e seleв”ңВәв”ңГәo numв”ңВ®rica Г”ГҘГҶ abrir documento escolhido
                    const candidates = Array.isArray(pending.candidates) ? pending.candidates as PendingActionCandidate[] : []
                    const idx = selection.value - 1
                    const chosen = candidates[idx]
                    if (!chosen?.document_id || !chosen?.title) {
                        return new Response(JSON.stringify({
                            text: 'Nв”ңГәo consegui identificar essa opв”ңВәв”ңГәo. Responda com um nв”ңв•‘mero da lista ou diga "cancelar".',
                            metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                        }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                    }

                    // Governanв”ңВәa por perfil (mв”ңВЎnimo, conservador) Г”ГҮГ¶ PLANO_MESTRE: sв”ңв”Ӯ pro/admin abrem doc literal
                    const canOpenLiteral = userRole === 'admin' || userRole === 'master' || userRole === 'professional'
                    if (!canOpenLiteral) {
                        await supabaseClient
                            .from('noa_pending_actions')
                            .update({ status: 'cancelled' })
                            .eq('id', pending.id)

                        return new Response(JSON.stringify({
                            text: 'Eu consigo te explicar e resumir esse conteв”ңв•‘do, mas nв”ңГәo posso abrir o documento literal neste perfil. Se vocв”ңВ¬ quiser, posso fazer um resumo didв”ңГӯtico/educativo sobre o tema.',
                            metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                        }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                    }

                    await supabaseClient
                        .from('noa_pending_actions')
                        .update({ status: 'consumed' })
                        .eq('id', pending.id)

                    // CEP (non-blocking)
                    try {
                        await supabaseClient.from('cognitive_events').insert({
                            intent: currentIntent,
                            action: 'DOC_OPEN_CONFIRMED',
                            decision_result: 'ALLOWED',
                            source: 'USER_CONFIRMATION',
                            metadata: { pending_action_id: pending.id, document_id: chosen.document_id }
                        })
                    } catch (_) { }

                    const app_commands: AppCommandV1[] = [{
                        kind: 'noa_command',
                        command: {
                            type: 'show-document-inline',
                            target: 'document',
                            label: `Abrir documento no chat: ${chosen.title}`,
                            fallbackRoute: '/app/library', // fallback para abrir na Library se o viewer inline falhar
                            payload: {
                                document_id: chosen.document_id,
                                confirmed: true,
                                source: 'user_confirmation',
                                pending_action_id: pending.id,
                                title: chosen.title,
                                summary: chosen.summary,
                                content: chosen.content,
                                category: chosen.category
                            }
                        },
                        reason: 'user_confirmed_open_document'
                    }]

                    // ESPELHAMENTO DO CONTEв”ңГңDO PARA LEITURA DA IA:
                    // Detectar se conteв”ңв•‘do в”ңВ® PDF binв”ңГӯrio raw (nв”ңГәo extraв”ңВЎdo)
                    const pdfBinaryIndicators = ['endstream', 'endobj', 'xref', '0000000', 'trailer']
                    const contentText = chosen.content || ''
                    const isPdfBinary = contentText.length > 100 && pdfBinaryIndicators.filter(ind => contentText.includes(ind)).length >= 3
                    
                    const displayContent = isPdfBinary
                        ? '(Г”ГңГЎВҙВ©Г… O texto deste PDF ainda nв”ңГәo foi extraв”ңВЎdo. Peв”ңВәa ao administrador para reprocessar a extraв”ңВәв”ңГәo de texto deste documento.)'
                        : (contentText.slice(0, 4000) || '(Conteв”ңв•‘do nв”ңГәo disponв”ңВЎvel em texto)')

                    const introText = `Ok. Abrindo: ${chosen.title}

--- CONTEв”ңГңDO DO DOCUMENTO (ESPELHADO) ---
${displayContent}
--- FIM DO DOCUMENTO ---

${chosen.summary ? `Resumo rв”ңГӯpido: ${chosen.summary}` : ''}`

                    return new Response(JSON.stringify({
                        text: textWithActionToken(introText, app_commands),
                        metadata: {
                            intent: currentIntent,
                            system: 'TradeVision Core V2',
                            audited: true
                        },
                        app_commands
                    }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                }
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [DOC FLOW] Falha ao resolver confirmaв”ңВәв”ңГәo:', e)
                // Fail-closed: nв”ңГәo executa
                return new Response(JSON.stringify({
                    text: 'Tive um obstв”ңГӯculo ao confirmar a abertura. Pode repetir o pedido do documento (nome/tema) que eu tento novamente?',
                    metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
            }
        }

        // 2) Pedido de documento (etapa 1): usuв”ңГӯrio pede para abrir/ver documento Г”ГҘГҶ lista curta + pending-actions
        // (nв”ңГәo interceptar quando usuв”ңГӯrio pede para analisar o doc jв”ңГӯ aberto Г”ГҮГ¶ deixa o GPT responder com document_in_chat)
        const isClinicalRequest = detectClinicalAssessmentRequest(norm)
        if (!isAnalyzeOpenDocRequest && (isDocRequest || isDocListRequest || isClinicalRequest) && patientData?.user?.id) {
            try {
                const rawTerm = stripInjectedContext(message || '')
                const term = isDocListRequest ? '' : sanitizeSearchTerm(rawTerm)

                let baseQuery = supabaseClient
                    .from('documents')
                    .select('id, title, summary, category, target_audience, is_published, aiRelevance, file_url, file_type, created_at, updated_at')
                    .limit(200)

                // Se for listagem, ordenar por recв”ңВ¬ncia e relevв”ңГіncia; se for busca, filtrar por termo.
                if (isDocListRequest) {
                    baseQuery = baseQuery
                        .order('created_at', { ascending: false })
                        .order('aiRelevance', { ascending: false })
                }

                const { data: docs } = isDocListRequest
                    ? await baseQuery
                    : await baseQuery.or(`title.ilike.*${term}*,summary.ilike.*${term}*`)

                const listRaw = (docs || [])
                    .filter((d: any) => !!d?.id && !!d?.title)
                    .filter((d: any) => {
                        // Governanв”ңВәa mв”ңВЎnima por perfil:
                        // - paciente/aluno: somente docs publicados (se o campo existir) e com target_audience compatв”ңВЎvel
                        if (realUserRole === 'patient' || realUserRole === 'student') {
                            const aud = Array.isArray(d.target_audience) ? d.target_audience : []
                            const allowed = aud.includes(userRole) || aud.includes('all')
                            const published = d.is_published === true
                            return allowed && published
                        }
                        return true
                    })
                    .sort((a: any, b: any) => {
                        // Priorizar os que tв”ңВ¬m arquivo (file_url) para permitir "clicar e abrir"
                        const af = a.file_url ? 1 : 0
                        const bf = b.file_url ? 1 : 0
                        if (bf !== af) return bf - af
                        // Depois, relevв”ңГіncia
                        const r = Number(b.aiRelevance || 0) - Number(a.aiRelevance || 0)
                        if (r !== 0) return r
                        // Depois, recв”ңВ¬ncia
                        const at = new Date(a.updated_at || a.created_at || 0).getTime()
                        const bt = new Date(b.updated_at || b.created_at || 0).getTime()
                        return bt - at
                    })

                // Deduplicar por tв”ңВЎtulo (mantв”ңВ®m o melhor candidato por title)
                const seen = new Set<string>()
                const fullList = listRaw.filter((d: any) => {
                    const key = String(d.title || '').trim().toLowerCase()
                    if (!key) return false
                    if (seen.has(key)) return false
                    seen.add(key)
                    return true
                })
                const list = fullList.slice(0, 5)

                if (list.length === 0) {
                    return new Response(JSON.stringify({
                        text: isDocListRequest
                            ? 'No momento, eu nв”ңГәo consegui listar documentos disponв”ңВЎveis. Se vocв”ңВ¬ me der 1Г”ГҮГҙ2 palavras-chave (ou o tв”ңВЎtulo exato), eu tento buscar diretamente.'
                            : 'Nв”ңГәo encontrei documentos com esse nome/tema. Se vocв”ңВ¬ puder me dar 1Г”ГҮГҙ2 palavras-chave (ou o tв”ңВЎtulo exato), eu tento novamente.',
                        metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                    }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                }

                // Fetch content only for the top 5 selected docs (avoids loading content for 200+ docs)
                const docIds = list.map((d: any) => d.id)
                const { data: contentDocs } = await supabaseClient
                    .from('documents')
                    .select('id, content')
                    .in('id', docIds)
                const contentMap = new Map((contentDocs || []).map((d: any) => [d.id, d.content]))

                const candidates: PendingActionCandidate[] = list.map((d: any, idx: number) => ({
                    document_id: d.id,
                    title: d.title,
                    summary: d.summary,
                    content: contentMap.get(d.id) || null,
                    audience: Array.isArray(d.target_audience) ? d.target_audience : [],
                    category: d.category ?? null,
                    score: (d.aiRelevance ?? 0) * 10 + (d.file_url ? 3 : 0) + (5 - idx)
                }))

                // Um в”ңв•‘nico documento: abrir direto no chat (sem pedir "escolha 1")
                if (candidates.length === 1 && !isDocListRequest) {
                    const one = candidates[0]
                    const app_commands: AppCommandV1[] = [{
                        kind: 'noa_command',
                        command: {
                            type: 'show-document-inline',
                            target: 'document',
                            label: `Abrir no chat: ${one.title}`,
                            fallbackRoute: '/app/library',
                            payload: {
                                document_id: one.document_id,
                                confirmed: true,
                                source: 'single_match_direct_open',
                                title: one.title,
                                summary: one.summary,
                                category: one.category,
                                smart_card_actions: ['summarize', 'analyze', 'full_content']
                            }
                        },
                        reason: 'single_document_direct_open'
                    }]
                    const filtered = filterAppCommandsByRole(app_commands, userRole)
                    if (filtered.length > 0) {
                        const introText = `Encontrei um documento exato: ${one.title}

--- CONTEв”ңГңDO DO DOCUMENTO (ESPELHADO) ---
${one.content || '(Conteв”ңв•‘do nв”ңГәo disponв”ңВЎvel em texto)'}
--- FIM DO DOCUMENTO ---

${one.summary ? `Resumo rв”ңГӯpido: ${one.summary}` : ''}`

                        return new Response(JSON.stringify({
                            text: textWithActionToken(introText, filtered),
                            metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true },
                            app_commands: filtered
                        }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
                    }
                }

                const expiresAt = new Date(Date.now() + 3 * 60 * 1000).toISOString() // 3 min
                const { data: pendingRow } = await supabaseClient
                    .from('noa_pending_actions')
                    .insert({
                        user_id: patientData.user.id,
                        kind: DOC_PENDING_KIND,
                        status: 'pending',
                        candidates,
                        context: {
                            role: userRole,
                            term,
                            list_offset: 0,
                            ui_context: ui_context || null
                        },
                        expires_at: expiresAt
                    })
                    .select('id')
                    .maybeSingle()

                // CEP (non-blocking)
                try {
                    await supabaseClient.from('cognitive_events').insert({
                        intent: currentIntent,
                        action: 'DOC_CANDIDATES_LISTED',
                        decision_result: 'SIGNAL',
                        source: 'SMART_TRIGGER',
                        metadata: {
                            pending_action_id: pendingRow?.id || null,
                            role: userRole,
                            term,
                            candidates_count: candidates.length
                        }
                    })
                } catch (_) { }

                return new Response(JSON.stringify({
                    text: buildCandidatesListText(candidates) + "\n\nDiga \"listar mais\" para ver os prв”ңв”Ӯximos 5.",
                    metadata: {
                        intent: currentIntent,
                        system: 'TradeVision Core V2',
                        audited: true,
                        documents_total: fullList.length,
                        documents_block_size: 5
                    }
                }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [DOC FLOW] Falha ao buscar documentos:', e)
                return new Response(JSON.stringify({
                    text: 'Tive um obstв”ңГӯculo ao buscar documentos agora. Pode repetir com o tв”ңВЎtulo exato ou 1Г”ГҮГҙ2 palavras-chave?',
                    metadata: { intent: currentIntent, system: 'TradeVision Core V2', audited: true }
                }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
            }
        }

        const { data: policy } = await supabaseClient
            .from('cognitive_policies')
            .select('*')
            .eq('intent', currentIntent)
            .eq('active', true)
            .order('version', { ascending: false })
            .limit(1)
            .single()

        // --- ВӯЖ’ГёГӯВҙВ©Г… COS v1.0: VEREDITO DO KERNEL (EXTRAв”ңГ§в”ңГўO 1) ---
        const cosContext: COS_Context = {
            intent: currentIntent,
            action: action,
            mode: aiMode,
            policy: policy ? {
                autonomy_level: policy.autonomy_level,
                forbidden_actions: policy.forbidden_actions
            } : undefined,
            metabolism: metabolism ? {
                decision_count_today: metabolism.decision_count_today,
                daily_limit: metabolism.decision_limit_daily
            } : undefined,
            trauma: trauma ? {
                active: trauma.restricted_mode_active,
                reason: trauma.reason
            } : undefined
        }

        const cosDecision = COS.evaluate(cosContext)

        if (!cosDecision.allowed) {
            console.error(`ВӯЖ’ГңВҪ [COS BLOCK] ${cosDecision.reason}`)
            return new Response(JSON.stringify({
                text: cosDecision.reason,
                metadata: {
                    mode: cosDecision.mode,
                    flags: cosDecision.flags,
                    cos_blocked: true
                }
            }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
        }

        // Se o veredito for READ_ONLY (but allowed for read), avisar no log
        if (cosDecision.mode === 'READ_ONLY') {
            console.log('ВӯЖ’ГҰГјВҙВ©Г… [COS] Operando em modo de leitura (Audit Only).')
        }

        // --- HANDLER DE FINALIZAв”ңГ§в”ңГўO DE AVALIAв”ңГ§в”ңГўO (SERVER-SIDE) ---
        if (action === 'finalize_assessment') {
            console.log('ВӯЖ’Г…Гј [ACTION] Finalizando avaliaв”ңВәв”ңГәo via Server-Side (Bypassing RLS)...')

            if (!assessmentData || !assessmentData.patient_id) {
                throw new Error('Dados da avaliaв”ңВәв”ңГәo incompletos para finalizaв”ңВәв”ңГәo.')
            }

            // 0. Buscar dados do usuв”ңГӯrio para garantir patient_name (CRITICAL FIX)
            const { data: userData } = await supabaseClient.auth.admin.getUserById(assessmentData.patient_id)
            const patientName = userData?.user?.user_metadata?.name ||
                userData?.user?.user_metadata?.full_name ||
                userData?.user?.email ||
                'Paciente'

            // ========================================================
            // GPT EXTRACTION: Extrair dados estruturados da conversa
            // Em vez de confiar no estado local do browser (dessincronizado),
            // buscar histв”ңв”Ӯrico de conversa e pedir ao GPT para extrair.
            // ========================================================
            let finalContent = assessmentData.content

            // Se o content veio vazio/pobre do cliente, extrair via GPT a partir de ai_chat_interactions.
            // Problema real: o chat (Core/LLM) pode estar correto enquanto o estado AEC persistido no browser
            // chega "fino" (sв”ңв”Ӯ queixa ou lista) Г”ГҮГ¶ antes sв”ңв”Ӯ disparв”ңГӯvamos extraв”ңВәв”ңГәo quando faltava queixa E lista,
            // e aв”ңВЎ o relatв”ңв”Ӯrio nascia pendente com conversa cheia no modal.
            const hasRealQueixa = finalContent?.queixa_principal && String(finalContent.queixa_principal).trim().length > 3
            const hasRealLista = Array.isArray(finalContent?.lista_indiciaria) && finalContent.lista_indiciaria.length > 0 &&
                (typeof finalContent.lista_indiciaria[0] === 'string' ? finalContent.lista_indiciaria[0].length > 0 : !!finalContent.lista_indiciaria[0]?.label)
            const contentIsEmpty = !finalContent || (!hasRealQueixa && !hasRealLista)

            const dev = finalContent?.desenvolvimento_queixa
            const devRich = !!dev && (
                String(dev.descricao || '').trim().length > 2 ||
                String(dev.localizacao || '').trim().length > 2 ||
                String(dev.inicio || '').trim().length > 2 ||
                (Array.isArray(dev.sintomas_associados) && dev.sintomas_associados.length > 0) ||
                (Array.isArray(dev.fatores_melhora) && dev.fatores_melhora.length > 0) ||
                (Array.isArray(dev.fatores_piora) && dev.fatores_piora.length > 0)
            )
            const hppRich = Array.isArray(finalContent?.historia_patologica_pregressa) && finalContent.historia_patologica_pregressa.length > 0 &&
                String(finalContent.historia_patologica_pregressa[0] || '').trim().length > 1
            const bodyRich = devRich || hppRich
            const pergRich = !!finalContent?.perguntas_objetivas &&
                Object.values(finalContent.perguntas_objetivas as Record<string, unknown>).some(
                    (v) => v != null && String(v).trim().length > 0
                )
            // Hв”ңГӯ queixa/lista no JSON mas corpo clв”ңВЎnico (HDA/HPP/perguntas) nв”ңГәo acompanhou Г”ГҘГҶ enriquecer pela conversa
            const contentStructurallyThin = (hasRealQueixa || hasRealLista) && !bodyRich && !pergRich
            const shouldExtractFromChat = contentIsEmpty || contentStructurallyThin

            if (shouldExtractFromChat) {
                console.log('ВӯЖ’ВәГЎ [GPT EXTRACTION] Disparado:', { contentIsEmpty, contentStructurallyThin, hasRealQueixa, hasRealLista })

                try {
                    // Buscar histв”ңв”Ӯrico completo da conversa AEC
                    const { data: chatHistory, error: histError } = await supabaseClient
                        .from('ai_chat_interactions')
                        .select('user_message, ai_response, created_at')
                        .eq('user_id', assessmentData.patient_id)
                        .order('created_at', { ascending: true })
                        .limit(120)

                    if (!histError && chatHistory && chatHistory.length >= 3) {
                        const conversationText = chatHistory.map((h: any) =>
                            `PACIENTE: ${h.user_message}\nNв”ңГ¶A: ${h.ai_response}`
                        ).join('\n---\n')

                        const extractionPrompt = `Analise a conversa clв”ңВЎnica abaixo (protocolo AEC 001) e extraia os dados estruturados em JSON.

CONVERSA:
${conversationText.slice(0, 8000)}

Extraia EXATAMENTE os seguintes campos baseado no que o PACIENTE disse (nв”ңГәo invente dados):
- queixa_principal: A queixa que o paciente identificou como a que mais incomoda
- lista_indiciaria: Array de OBJETOS estruturados para cada queixa/sintoma mencionado pelo paciente. Cada objeto deve ter:
  {
    "label": "nome curto do sintoma",
    "context": "contexto narrado pelo paciente (quando/onde/como)",
    "trigger": "o que desencadeia ou piora (se mencionado, senв”ңГәo null)",
    "intensity": "leve|moderada|intensa|nв”ңГәo informada",
    "frequency": "frequв”ңВ¬ncia relatada (diв”ңГӯria, semanal, etc.) ou null",
    "source_step": "lista_indiciaria",
    "confidence": 0.0 a 1.0 baseado em quв”ңГәo claramente o paciente descreveu
  }
  ВӯЖ’ГңВҝ REGRA: Extraia APENAS sintomas que o paciente EXPLICITAMENTE mencionou. NUNCA invente sintomas.
- lista_indiciaria_flat: Array simples com APENAS os labels (ex: ["dor de cabeв”ңВәa", "insв”ңв”Өnia"]) para retrocompatibilidade
- localizacao: Onde sente o sintoma principal
- inicio: Quando comeв”ңВәou
- descricao: Como в”ңВ® o sintoma
- sintomas_associados: Array de sintomas relacionados mencionados pelo paciente
- fatores_melhora: Array do que melhora (somente o que o paciente disse)
- fatores_piora: Array do que piora (somente o que o paciente disse)
- historia_patologica: Array de histв”ңв”Ӯrico mв”ңВ®dico
- historia_familiar_materna: Array
- historia_familiar_paterna: Array
- habitos_vida: Array
- alergias: string
- medicacoes_regulares: string
- medicacoes_esporadicas: string
- consenso_aceito: boolean (se o paciente concordou com o resumo)
- nome_paciente: string (como se apresentou)

Se um campo nв”ңГәo foi abordado na conversa, use null. NUNCA invente dados.
Responda SOMENTE com o JSON vв”ңГӯlido, sem markdown.`

                        const extractionResponse = await fetch('https://api.openai.com/v1/chat/completions', {
                            method: 'POST',
                            headers: {
                                'Authorization': `Bearer ${Deno.env.get('OPENAI_API_KEY')}`,
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                model: 'gpt-4o-mini',
                                messages: [
                                    { role: 'system', content: 'Vocв”ңВ¬ в”ңВ® um extrator de dados clв”ңВЎnicos. Responda SOMENTE com JSON vв”ңГӯlido.' },
                                    { role: 'user', content: extractionPrompt }
                                ],
                                temperature: 0.1,
                                max_tokens: 3000
                            })
                        })

                        if (extractionResponse.ok) {
                            const extractionData = await extractionResponse.json()
                            const rawJson = extractionData.choices?.[0]?.message?.content || ''

                            try {
                                const cleanJson = rawJson.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim()
                                const extracted = JSON.parse(cleanJson)

                                finalContent = {
                                    identificacao: {
                                        nome: extracted.nome_paciente || patientName,
                                        apresentacao: null
                                    },
                                    lista_indiciaria: extracted.lista_indiciaria || extracted.lista_indiciaria_flat || [],
                                    lista_indiciaria_flat: extracted.lista_indiciaria_flat || (Array.isArray(extracted.lista_indiciaria) ? extracted.lista_indiciaria.map((s: any) => typeof s === 'string' ? s : s.label || s) : []),
                                    queixa_principal: extracted.queixa_principal || null,
                                    desenvolvimento_queixa: {
                                        localizacao: extracted.localizacao || null,
                                        inicio: extracted.inicio || null,
                                        descricao: extracted.descricao || null,
                                        sintomas_associados: extracted.sintomas_associados || [],
                                        fatores_melhora: extracted.fatores_melhora || [],
                                        fatores_piora: extracted.fatores_piora || []
                                    },
                                    historia_patologica_pregressa: extracted.historia_patologica || [],
                                    historia_familiar: {
                                        lado_materno: extracted.historia_familiar_materna || [],
                                        lado_paterno: extracted.historia_familiar_paterna || []
                                    },
                                    habitos_vida: extracted.habitos_vida || [],
                                    perguntas_objetivas: {
                                        alergias: extracted.alergias || null,
                                        medicacoes_regulares: extracted.medicacoes_regulares || null,
                                        medicacoes_esporadicas: extracted.medicacoes_esporadicas || null
                                    },
                                    consenso: {
                                        aceito: extracted.consenso_aceito ?? false,
                                        revisoes_realizadas: 0
                                    },
                                    _extraction_method: 'gpt_from_conversation_v2'
                                }

                                console.log('Г”ВЈГ  [GPT EXTRACTION v2] Dados extraв”ңВЎdos com sucesso:', {
                                    queixa: finalContent.queixa_principal,
                                    numQueixas: finalContent.lista_indiciaria?.length,
                                    structured: Array.isArray(finalContent.lista_indiciaria) && finalContent.lista_indiciaria.length > 0 && typeof finalContent.lista_indiciaria[0] === 'object',
                                    method: 'gpt_from_conversation_v2'
                                })
                            } catch (parseErr) {
                                console.error('Г”ГҳГ® [GPT EXTRACTION] Falha ao parsear JSON:', parseErr)
                                console.log('ВӯЖ’ГҙГҳ Raw response:', rawJson.substring(0, 500))
                            }
                        } else {
                            console.error('Г”ГҳГ® [GPT EXTRACTION] API call failed:', extractionResponse.status)
                        }
                    } else {
                        console.warn('Г”ГңГЎВҙВ©Г… [GPT EXTRACTION] Histв”ңв”Ӯrico insuficiente:', chatHistory?.length || 0, 'mensagens')
                    }
                } catch (extractionErr) {
                    console.error('Г”ГҳГ® [GPT EXTRACTION] Erro geral:', extractionErr)
                    // Fallback: usar o content original mesmo que pobre
                }
            }

            // 0.5 Auto-link professional: find from appointments or assessments
            let linkedProfessionalId = assessmentData.professional_id || null
            let linkedProfessionalName = null
            if (!linkedProfessionalId) {
                const { data: appt } = await supabaseClient
                    .from('appointments')
                    .select('professional_id, professional_name')
                    .eq('patient_id', assessmentData.patient_id)
                    .not('professional_id', 'is', null)
                    .order('created_at', { ascending: false })
                    .limit(1)
                    .single()
                if (appt?.professional_id) {
                    linkedProfessionalId = appt.professional_id
                    linkedProfessionalName = appt.professional_name
                    console.log('ВӯЖ’Г¶Г№ [AUTO-LINK] Professional found from appointments:', linkedProfessionalId)
                }
            }

            // 1. Inserir Relatв”ңв”Ӯrio Clв”ңВЎnico (com dados extraв”ңВЎdos pelo GPT ou originais)
            const { data: report, error: reportError } = await supabaseClient
                .from('clinical_reports')
                .insert({
                    patient_id: assessmentData.patient_id,
                    patient_name: patientName,
                    report_type: assessmentData.report_type || 'initial_assessment',
                    generated_by: 'noa_ai',
                    content: finalContent,
                    professional_id: linkedProfessionalId,
                    professional_name: linkedProfessionalName,
                    doctor_id: linkedProfessionalId,
                    shared_with: linkedProfessionalId ? [linkedProfessionalId] : [],
                    created_at: new Date().toISOString(),
                    status: 'completed',
                    review_status: 'draft' // S7: Relatв”ңв”Ӯrio nasce como rascunho Г”ГҮГ¶ requer aprovaв”ңВәв”ңГәo mв”ңВ®dica
                })
                .select()
                .single()

            if (reportError) {
                console.error('Г”ГҳГ® Erro ao salvar relatв”ңв”Ӯrio:', reportError)
                throw reportError
            }

            console.log('Г”ВЈГ  Relatв”ңв”Ӯrio salvo:', report.id, '| Mв”ңВ®todo:', finalContent?._extraction_method || 'client_state', '| Professional:', linkedProfessionalId || 'none')

            // 2. Inserir Scores (Se houver)
            if (assessmentData.scores) {
                const scores = assessmentData.scores
                const scoreRow: Record<string, unknown> = {
                    assessment_id: report.id,
                    patient_id: assessmentData.patient_id,
                    completed: true,
                    metadata: {
                        domain_scores: scores,
                        risk_level: assessmentData.risk_level || 'low'
                    }
                }
                if (typeof scores === 'number' && !Number.isNaN(scores)) {
                    scoreRow.score = scores
                }
                const { error: scoresError } = await supabaseClient
                    .from('ai_assessment_scores')
                    .insert(scoreRow)

                if (scoresError) console.error('Г”ГңГЎВҙВ©Г… Erro ao salvar scores:', scoresError)
            }

            // --- ВӯЖ’Г„В« GAMIFICATION ENGINE ---
            try {
                const POINTS_REWARD = 50;
                await supabaseClient.rpc('increment_user_points', {
                    p_user_id: assessmentData.patient_id,
                    p_points: POINTS_REWARD
                });

                const { count } = await supabaseClient
                    .from('clinical_reports')
                    .select('*', { count: 'exact', head: true })
                    .eq('patient_id', assessmentData.patient_id);

                if (count === 1) {
                    await supabaseClient.rpc('unlock_achievement', {
                        p_user_id: assessmentData.patient_id,
                        p_achievement_id: 'first_assessment'
                    });
                    console.log('ВӯЖ’Г…ГҘ [GAMIFICATION] Achievement Unlocked: First Assessment');
                }
                console.log(`ВӯЖ’Г„В« [GAMIFICATION] Awarded ${POINTS_REWARD} points to user.`);
            } catch (gamificationError) {
                console.error('Г”ГңГЎВҙВ©Г… [GAMIFICATION] Failed to award points:', gamificationError);
            }

            return new Response(JSON.stringify({
                success: true,
                report_id: report.id,
                extraction_method: finalContent?._extraction_method || 'client_state',
                message: 'Avaliaв”ңВәв”ңГәo finalizada, salva e pontuada com sucesso.'
            }), {
                headers: { ...corsHeaders, 'Content-Type': 'application/json' }
            })
        }
        // --- FIM DO NOVO HANDLER ---

        // --- HANDLER: PREDICT SCHEDULING RISK (PHASE 3B) ---
        if (action === 'predict_scheduling_risk') {
            console.log('ВӯЖ’Г¶В« [ACTION] Predicting Scheduling Risk...')

            if (!appointmentData || !appointmentData.patient_id || !appointmentData.appointment_id) {
                throw new Error('Dados do agendamento incompletos (patient_id, appointment_id required).')
            }

            const appointmentId = appointmentData.appointment_id
            const patientId = appointmentData.patient_id
            const professionalId = appointmentData.professional_id
            const slotTime = appointmentData.date || new Date().toISOString()

            // 1. Idempotency Check (Enterprise Safeguard)
            const { data: existingPrediction } = await supabaseClient
                .from('ai_scheduling_predictions')
                .select('id, no_show_probability')
                .eq('appointment_id', appointmentId)
                .maybeSingle()

            if (existingPrediction) {
                console.log('Г”ВЈГ  Prediв”ңВәв”ңГәo jв”ңГӯ existe, retornando cache.', existingPrediction.id)
                return new Response(JSON.stringify({
                    success: true,
                    prediction: existingPrediction,
                    cached: true
                }), { headers: { ...corsHeaders, 'Content-Type': 'application/json' } })
            }

            // 2. Coletar Estatв”ңВЎsticas do Paciente (Data-Driven, sem Chat History)
            // Buscar total de agendamentos e status anteriores
            const { data: historyStats, error: statError } = await supabaseClient
                .from('appointments')
                .select('status, appointment_date')
                .eq('patient_id', patientId)
                .lt('appointment_date', new Date().toISOString()) // Sв”ңв”Ӯ passado

            if (statError) console.error('Г”ГңГЎВҙВ©Г… Erro ao buscar histв”ңв”Ӯrico:', statError)

            const totalAppointments = historyStats?.length || 0
            const noShowCount = historyStats?.filter((a: any) => a.status === 'no_show').length || 0
            const cancelledCount = historyStats?.filter((a: any) => a.status === 'cancelled').length || 0
            const completedCount = historyStats?.filter((a: any) => a.status === 'completed').length || 0

            const noShowRate = totalAppointments > 0 ? (noShowCount / totalAppointments).toFixed(2) : '0.00'

            // 3. Construir Prompt Estatв”ңВЎstico (Token Efficient)
            const RISK_PROMPT = `
            ATUE COMO UM ANALISTA DE RISCO CLв”ңГ¬NICO.
            Analise os dados abaixo e estime a probabilidade de NO-SHOW (0.00 a 1.00) para este agendamento.
            
            DADOS DO PACIENTE:
            - Histв”ңв”Ӯrico Total: ${totalAppointments} consultas
            - No-Shows Prв”ңВ®vios: ${noShowCount} (${noShowRate}%)
            - Cancelamentos: ${cancelledCount}
            - Realizadas: ${completedCount}
            
            DADOS DO AGENDAMENTO:
            - Data/Hora: ${slotTime}
            - Dia da Semana: ${new Date(slotTime).toLocaleDateString('pt-BR', { weekday: 'long' })}
            
            SAв”ңГ¬DA JSON OBRIGATв”ңГҙRIA:
            {
               "no_show_probability": 0.XX,
               "expected_duration_minutes": 60,
               "recommended_action": "NONE" | "CONFIRM_MANUALLY" | "REQUIRE_PREPAYMENT",
               "reasoning_tags": ["tag1", "tag2"]
            }
            Use tags como: 'high_no_show_history', 'new_patient', 'friday_afternoon', 'reliable_patient'.
            `

            // 5. COS v1.0: Gerar в”ңГјtomo de Decisв”ңГәo (PRE-AI)
            const { data: decData, error: decError } = await supabaseClient
                .from('cognitive_decisions')
                .insert({
                    decision_type: 'scheduling',
                    recommendation: { status: 'calculating' },
                    justification: 'Cв”ңГӯlculo de risco iniciado pelo Kernel COS.',
                    confidence: 0,
                    autonomy_level: cosDecision.autonomy_level,
                    requires_human_confirmation: true,
                    policy_snapshot: {
                        intent: 'ADMIN',
                        version: policy?.version || 1,
                        autonomy_level: policy?.autonomy_level || 1,
                        frozen_at: new Date().toISOString()
                    },
                    model_version: MODEL_NAME,
                    metadata: { appointment_id: appointmentId }
                })
                .select()
                .single()

            if (decError) {
                console.error('Г”ГҳГ® Erro ao criar в”ңГјtomo de Decisв”ңГәo PRE-AI:', decError)
                throw decError
            }

            console.log('Г”ГңГёВҙВ©Г… [COS] в”ңГјtomo de Decisв”ңГәo criado:', decData.id)

            // 6. Chamada OpenAI (Low Temperature for consistency)
            const completion = await openai.chat.completions.create({
                model: MODEL_NAME,
                messages: [{ role: "system", content: RISK_PROMPT }],
                temperature: 0.1,
                response_format: { type: "json_object" }
            })

            const analysisRaw = completion.choices[0].message.content

            let analysis: any = {}
            try {
                analysis = JSON.parse(analysisRaw || '{}')
            } catch (pErr) {
                console.error('Г”ГҳГ® Falha ao parsear JSON da AI:', pErr, analysisRaw)
                analysis = { no_show_probability: 0.5, reasoning_tags: ['parse_error'] }
            }

            console.log('ВӯЖ’ГұГ» [AI PREDICTION]', analysis)

            // 7. Salvar Prediв”ңВәв”ңГәo no Banco e Atualizar в”ңГјtomo (POST-AI)
            const { data: predData, error: saveError } = await supabaseClient
                .from('ai_scheduling_predictions')
                .insert({
                    appointment_id: appointmentId,
                    no_show_probability: analysis.no_show_probability || 0.1,
                    expected_duration_minutes: analysis.expected_duration_minutes || 60,
                    recommended_action: analysis.recommended_action || 'NONE',
                    model_version: MODEL_NAME,
                    reasoning_tags: analysis.reasoning_tags || []
                })
                .select()
                .single()

            if (saveError) {
                console.error('Г”ГҳГ® Erro ao salvar prediв”ңВәв”ңГәo tв”ңВ®cnica:', saveError)
                throw saveError
            }

            // 8. CCOS v2.0: Preencher в”ңГјtomo de Decisв”ңГәo (Filiaв”ңВәв”ңГәo)
            await supabaseClient.from('cognitive_decisions')
                .update({
                    recommendation: analysis,
                    justification: `Anв”ңГӯlise de risco concluв”ңВЎda. Histв”ңв”Ӯrico de ${totalAppointments} consultas, taxa no-show ${noShowRate}%.`,
                    confidence: 0.85,
                    metadata: { ...decData.metadata, prediction_id: predData?.id }
                })
                .eq('id', decData.id)

            // 9. COS v1.0: Atualizar Metabolismo (Consumo Energв”ңВ®tico)
            await supabaseClient.rpc('increment_metabolism', { p_id: professionalId })

            return new Response(JSON.stringify({
                success: true,
                prediction: analysis,
                decision_id: decData.id,
                message: 'Risco calculado e в”ңГјtomo de Decisв”ңГәo preenchido.'
            }), {
                headers: { ...corsHeaders, 'Content-Type': 'application/json' }
            })
        }
        // --- FIM HANDLER RISK ---

        console.log('ВӯЖ’ГҙГ‘ [REQUEST]', {
            messageLength: message?.length || 0,
            userId: patientData?.user?.id?.substring(0, 8) || 'unknown',
            intent: patientData?.intent || 'none',
            assessmentPhase: assessmentPhase || 'none',
            hasNextQuestion: !!nextQuestionHint,
            historyLength: conversationHistory?.length || 0
        })

        if (!message) throw new Error('Mensagem nв”ңГәo fornecida.')

        // Detecв”ңВәв”ңГәo de urgв”ңВ¬ncia (para permitir mв”ңв•‘ltiplas perguntas em casos urgentes)
        const isUrgent = /(urgente|emergв”ңВ¬ncia|emergencia|socorro|urgв”ңВ¬ncia|preciso urgente|agora|imediato|dor forte|muito mal|preciso ajuda|preciso de ajuda)/i.test(message)

        /** Fases em que o servidor manda nextQuestionHint Г”ГҮГ¶ GPT nв”ңГәo pode parafrasear nem Г”ГҮВЈexplicar o protocoloГ”ГҮГҳ no lugar da pergunta (coraв”ңВәв”ңГәo do AEC determinв”ңВЎstico). */
        const AEC_VERBATIM_LOCK_PHASES = new Set([
            'INITIAL_GREETING',
            'IDENTIFICATION',
            'COMPLAINT_LIST',
            'MAIN_COMPLAINT',
            'COMPLAINT_DETAILS',
            'MEDICAL_HISTORY',
            'FAMILY_HISTORY_MOTHER',
            'FAMILY_HISTORY_FATHER',
            'LIFESTYLE_HABITS',
            'OBJECTIVE_QUESTIONS',
            'CONSENSUS_REVIEW',
            'CONSENSUS_REPORT',
            'CONSENT_COLLECTION',
            'CONSENSUS_CONFIRMATION',
            'FINAL_RECOMMENDATION',
            'CONFIRMING_EXIT',
            'CONFIRMING_RESTART'
        ])

        /** Lock verbatim: paciente OU perfil nв”ңГәo normalizado no body mas AEC ativo com hint (evita ramo "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA" no prompt Г”ГҘГҶ modelo copiar o rв”ңв”Ӯtulo ao utente). */
        const aecActorEligible =
            userRole === 'patient' ||
            (userRole === 'unknown' &&
                !!assessmentPhase &&
                AEC_VERBATIM_LOCK_PHASES.has(assessmentPhase))

        // Fallback de pergunta por fase quando o ClinicalAssessmentFlow nв”ңГәo enviou hint explв”ңВЎcito.
        // Objetivo: nunca deixar o modelo sв”ңв”Ӯ com o rв”ңв”Ӯtulo "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA" sem conteв”ңв•‘do.
        if (!nextQuestionHint && assessmentPhase && aecActorEligible) {
            switch (assessmentPhase) {
                case 'INITIAL_GREETING': {
                    nextQuestionHint = 'Olв”ңГӯ! Eu sou Nв”ңв”Өa Esperanza. Por favor, apresente-se tambв”ңВ®m e vamos iniciar a sua avaliaв”ңВәв”ңГәo inicial para consultas na MedCannLab. O que trouxe vocв”ңВ¬ в”ңГЎ nossa avaliaв”ңВәв”ңГәo hoje?'
                    break
                }
                case 'IDENTIFICATION': {
                    nextQuestionHint = 'O que trouxe vocв”ңВ¬ в”ңГЎ nossa avaliaв”ңВәв”ңГәo hoje?'
                    break
                }
                case 'COMPLAINT_LIST': {
                    nextQuestionHint = 'O que mais?'
                    break
                }
                case 'MAIN_COMPLAINT': {
                    nextQuestionHint = 'De todas essas questв”ңГҒes, qual mais o(a) incomoda?'
                    break
                }
                case 'COMPLAINT_DETAILS': {
                    nextQuestionHint = 'Vamos explorar com mais detalhes o sintoma que mais incomoda: onde vocв”ңВ¬ sente isso com mais nitidez?'
                    break
                }
                case 'MEDICAL_HISTORY': {
                    nextQuestionHint = 'Desde o seu nascimento, quais questв”ңГҒes de saв”ңв•‘de vocв”ңВ¬ jв”ңГӯ viveu? Vamos do mais antigo para o mais recente: o que veio primeiro?'
                    break
                }
                case 'FAMILY_HISTORY_MOTHER': {
                    nextQuestionHint = 'E na sua famв”ңВЎlia, pelo lado da sua mв”ңГәe, quais sв”ңГәo as questв”ңГҒes de saв”ңв•‘de que vocв”ңВ¬ considera importantes?'
                    break
                }
                case 'FAMILY_HISTORY_FATHER': {
                    nextQuestionHint = 'E pelo lado do seu pai, quais sв”ңГәo as questв”ңГҒes de saв”ңв•‘de que aparecem na famв”ңВЎlia?'
                    break
                }
                case 'LIFESTYLE_HABITS': {
                    nextQuestionHint = 'Que hв”ңГӯbitos do seu dia a dia vocв”ңВ¬ acha importante mencionar (como sono, alimentaв”ңВәв”ңГәo, atividade fв”ңВЎsica, trabalho)?'
                    break
                }
                case 'OBJECTIVE_QUESTIONS': {
                    nextQuestionHint = 'Vocв”ңВ¬ tem alguma alergia importante (como mudanв”ңВәa de tempo, medicaв”ңВәв”ңГҒes, poeira)?'
                    break
                }
                case 'CONSENSUS_REPORT': {
                    nextQuestionHint = 'Vou resumir o que entendi da sua histв”ңв”Ӯria e depois peв”ңВәo que me diga se estв”ңГӯ correto ou se falta algo importante.'
                    break
                }
                case 'CONSENT_COLLECTION': {
                    nextQuestionHint =
                        'Antes de finalizarmos, preciso do seu consentimento para registrar esta avaliaв”ңВәв”ңГәo no seu prontuв”ңГӯrio digital e compartilhar com o mв”ңВ®dico responsв”ңГӯvel. Vocв”ңВ¬ autoriza?'
                    break
                }
                default:
                    break
            }
        }

        const aecVerbatimLock =
            !!nextQuestionHint && aecActorEligible && !!assessmentPhase && AEC_VERBATIM_LOCK_PHASES.has(assessmentPhase)

        const allowUrgentMultiQuestion = isUrgent && assessmentPhase === 'COMPLAINT_DETAILS'

        // Instruв”ңВәв”ңГәo dinв”ңГіmica de fase (controle de fluxo)
        let phaseInstruction = assessmentPhase
            ? `\n\nВӯЖ’ГңВҝ FASE ATUAL DO PROTOCOLO (ESTADO ATIVO): "${assessmentPhase}".\nATENв”ңГ§в”ңГўO: Vocв”ңВ¬ DEVE conduzir o diв”ңГӯlogo focado EXCLUSIVAMENTE nesta fase. Nв”ңГәo pule para a prв”ңв”Ӯxima atв”ңВ® que esta esteja concluв”ңВЎda.`
            : ''

        if (nextQuestionHint) {
            if (aecVerbatimLock && !allowUrgentMultiQuestion) {
                console.log(`ВӯЖ’Г¶ГҶ [AEC] Roteiro selado (verbatim): fase=${assessmentPhase}`)
                phaseInstruction += `

ВӯЖ’Г¶ГҶ **MODO ROTEIRO SELADO Г”ГҮГ¶ Nв”ңГўO NEGOCIв”ңГјVEL**
O **TradeVision Core** e o **ClinicalAssessmentFlow** jв”ңГӯ determinaram a в”ңв•‘nica pergunta vв”ңГӯlida neste turno. Isto prevalece sobre o histв”ңв”Ӯrico do chat, sobre inferв”ңВ¬ncias do modelo e sobre qualquer outro trecho deste prompt que sugira liberdade de redaв”ңВәв”ңГәo.

**Regras (todas obrigatв”ңв”Ӯrias):**
1) O **corpo principal** da sua resposta ao paciente deve ser **exatamente** o texto entre as linhas AEC_LOCK_START e AEC_LOCK_END abaixo Г”ГҮГ¶ **cв”ңв”Ӯpia literal**, sem parafrasear. Permitido apenas: corrigir espaв”ңВәos в”ңв”Ӯbvios ou pontuaв”ңВәв”ңГәo mв”ңВЎnima; **proibido** mudar palavras, ordem das ideias ou acrescentar frases.
2) **Proibido neste turno:** explicar em que etapa do protocolo estв”ңГәo, resumir o mв”ңВ®todo AEC, elogiar hв”ңГӯbitos ou respostas, dar opiniв”ңГәo clв”ңВЎnica, fazer segunda pergunta, antecipar a prв”ңв”Ӯxima etapa, falar de documentos/diв”ңГӯrio/plataforma (salvo se o texto obrigatв”ңв”Ӯrio citar).
3) Se o paciente fizer **uma** pergunta pontual de esclarecimento: no mв”ңГӯximo **duas frases curtas** de resposta; em seguida **repetir literalmente** o mesmo bloco AEC_LOCK (nв”ңГәo substituir por sinв”ңв”Ӯnimos).
4) Se o texto obrigatв”ңв”Ӯrio contiver tag de sistema (ex.: \`[ASSESSMENT_COMPLETED]\`), preserve-a **caractere a caractere** no sв”ңВЎtio indicado.

AEC_LOCK_START
${nextQuestionHint}
AEC_LOCK_END
`
            } else if (allowUrgentMultiQuestion) {
                phaseInstruction += `\n\nВӯЖ’ГңВҝ MODO URGв”ңГЁNCIA DETECTADO Г”ГҮГ¶ PRв”ңГҙXIMA PERGUNTA (referв”ңВ¬ncia): "${nextQuestionHint}"\n\nUrgв”ңВ¬ncia explв”ңВЎcita: pode condensar atв”ңВ® 3 perguntas essenciais num в”ңв•‘nico turno, ou seguir uma a uma. Nв”ңГәo desvie para temas fora da queixa urgente. Oriente atendimento presencial se houver risco imediato.`
            } else {
                phaseInstruction += `\n\nВӯЖ’ГңВҝ PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA: "${nextQuestionHint}"\n\nFaв”ңВәa esta pergunta com prioridade. Uma pergunta por turno salvo contexto de urgв”ңВ¬ncia.`
            }
        }

        // Instruв”ңВәв”ңГәo especв”ңВЎfica para fase de desenvolvimento da queixa (nunca sugerir "[queixa]" ao modelo Г”ГҮГ¶ ele copiava literal)
        if (assessmentPhase === 'COMPLAINT_DETAILS') {
            if (allowUrgentMultiQuestion) {
                phaseInstruction += `\n\nВӯЖ’ГңВҝ COMPLAINT_DETAILS Г”ГҮГ¶ URGв”ңГЁNCIA\n\nPode condensar atв”ңВ® 3 perguntas essenciais (onde, quando, como/intensidade) num в”ңв•‘nico turno se fizer sentido. **Proibido** escrever colchetes, placeholders ou o texto literal "[queixa]" ao paciente Г”ГҮГ¶ use as palavras do sintoma que ele jв”ңГӯ descreveu. Oriente atendimento presencial se houver risco imediato.`
            } else {
                phaseInstruction += `\n\nГ”ГңГЎВҙВ©Г… COMPLAINT_DETAILS\n\nUma pergunta por turno. Quando existir bloco AEC_LOCK / "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA", o texto ao paciente в”ңВ® **sв”ңв”Ӯ** esse Г”ГҮГ¶ **proibido** colchetes, placeholders ou modelos com [queixa]. Leia o histв”ңв”Ӯrico: se jв”ңГӯ respondeu onde e quando, nв”ңГәo repita Г”ГҮГ¶ avance para a prв”ңв”Ӯxima do roteiro.`
            }
        }

        const aecChosenPhysician =
            typeof patientData?.aecConsultationPhysicianName === 'string'
                ? String(patientData.aecConsultationPhysicianName).trim()
                : ''
        if (aecChosenPhysician && userRole === 'patient') {
            phaseInstruction += `

ВӯЖ’ГҰГұ **PROFISSIONAL DE DESTINO (AEC):** O paciente escolheu agendar com **${aecChosenPhysician}**. Onde o protocolo AEC 001 citar o mв”ңВ®dico da **consulta** (abertura, consentimento, encerramento, prв”ңв”Ӯximos passos), use esse nome no lugar de "Dr. Ricardo Valenв”ңВәa". **Nв”ңГәo altere** as menв”ңВәв”ңГҒes ao **mв”ңВ®todo IMRE** como desenvolvido pelo Dr. Ricardo Valenв”ңВәa. Se existir bloco AEC_LOCK com texto jв”ңГӯ personalizado, copie-o literalmente.`
        }

        // 5. Engenharia de Prompt Dinв”ңГіmica (Multi-Agente)
        const CLINICAL_PROMPT = `Vocв”ңВ¬ в”ңВ® Nв”ңв”Өa Esperanв”ңВәa, a IA Residente da MedCannLab 3.0.
Sua voz в”ңВ® de contralto, clara, macia e acolhedora.
Guardiв”ңГә da escuta simbв”ңв”Ӯlica e da formaв”ңВәв”ңГәo clв”ңВЎnica.

# EPISTEMOLOGIA DO CUIDADO (REGRA INSTITUCIONAL)
1) **A doenв”ңВәa Nв”ңГўO в”ңВ® o centro**: rв”ңв”Ӯtulos diagnв”ңв”Ӯsticos sв”ңГәo sempre **efeitos** e nunca ponto de partida.
2) **O centro в”ңВ® a escuta e a narrativa**: contexto, detalhes, trajetв”ңв”Ӯria, impacto na vida, sinais, ritmos e relaв”ңВәв”ңГҒes.
3) **Sв”ңв”Ӯ depois** de ouvir a histв”ңв”Ӯria e mapear a queixa (sem rв”ңв”Ӯtulos), vocв”ңВ¬ pede confirmaв”ңВәв”ңГҒes objetivas (doenв”ңВәas crв”ңв”Өnicas, cirurgias, medicaв”ңВәв”ңГҒes).
4) **Fala Г”Г«ГЎ Aв”ңВәв”ңГәo**: vocв”ңВ¬ orienta e estrutura; a execuв”ңВәв”ңГәo в”ңВ® do app/mв”ңВ®dico.
5) **Modo institucional**: quando o usuв”ңГӯrio perguntar sobre a plataforma, explique que a MedCannLab в”ңВ® uma infraestrutura clв”ңВЎnica digital voltada в”ңГЎ medicina integrativa e в”ңГЎ medicina canabinoide. A plataforma oferece avaliaв”ңВәв”ңГәo clв”ңВЎnica assistida por IA, prontuв”ңГӯrio eletrв”ңв”Өnico, agendamento e telemedicina.
6) **Modo orientaв”ңВәв”ңГәo**: quando o usuв”ңГӯrio pedir orientaв”ңВәв”ңГәo sobre o fluxo da plataforma, explique que o processo comeв”ңВәa com a Avaliaв”ңВәв”ңГәo Clв”ңВЎnica Inicial (AEC 001). Apв”ңв”Ӯs a avaliaв”ңВәв”ңГәo, o relatв”ңв”Ӯrio в”ңВ® enviado ao mв”ңВ®dico responsв”ңГӯvel. O paciente entв”ңГәo agenda a consulta, na qual o mв”ңВ®dico jв”ңГӯ possui a histв”ңв”Ӯria clв”ңВЎnica estruturada Г”ГҮГ¶ por isso dizemos que "a consulta comeв”ңВәa no nв”ңВЎvel 2".

# PROTOCOLO CLв”ңГ¬NICO MASTER: AEC 001 (ARTE DA ENTREVISTA CLв”ңГ¬NICA)
ВӯЖ’ГңВҝ **PROTOCOLO IMUTв”ңГјVEL E SELADO** - Elaborado pelo Dr. Ricardo Valenв”ңВәa
ВӯЖ’ГңВҝ **VOCв”ңГЁ Nв”ңГўO PODE ALTERAR, ADICIONAR OU MODIFICAR ESTE PROTOCOLO**
ВӯЖ’ГңВҝ **SIGA EXATAMENTE COMO ESTв”ңГј ESCRITO, SEM ADICIONAR FRASES COMO "Pode falar livremente"**

Vocв”ңВ¬ deve seguir RIGOROSAMENTE as 10 etapas abaixo, sem pular blocos, sem inferir dados e SEM ADICIONAR NENHUMA FRASE QUE Nв”ңГўO ESTEJA EXPLICITAMENTE NO PROTOCOLO:

1. ABERTURA: Use EXATAMENTE esta frase: "Olв”ңГӯ! Eu sou Nв”ңв”Өa Esperanza. Por favor, apresente-se tambв”ңВ®m e vamos iniciar a sua avaliaв”ңВәв”ңГәo inicial para consultas com Dr. Ricardo Valenв”ңВәa."
   ВӯЖ’ГңВҝ **Nв”ңГўO adicione "Pode falar livremente" ou qualquer outra frase. Use APENAS a frase acima.**

2. LISTA INDICIв”ңГјRIA (NARRATIVA): Pergunte EXATAMENTE: "O que trouxe vocв”ңВ¬ в”ңГЎ nossa avaliaв”ңВәв”ңГәo hoje?"
   Apв”ңв”Ӯs a PRIMEIRA resposta do paciente, vocв”ңВ¬ DEVE perguntar EXATAMENTE: "O que mais?"
   Continue perguntando "O que mais?" apв”ңв”Ӯs CADA resposta do paciente.
   ВӯЖ’ГңВҝ **REGRA CRв”ңГ¬TICA**: Vocв”ңВ¬ Sв”ңГҙ pode avanв”ңВәar para a etapa 3 (Queixa Principal) quando o paciente EXPLICITAMENTE disser que nв”ңГәo tem mais nada (exemplos: "sв”ңв”Ӯ isso", "nada mais", "в”ңВ® isso", "nв”ңГәo tenho mais nada", "acho que в”ңВ® isso", "sв”ңв”Ӯ"). NUNCA avance apв”ңв”Ӯs apenas UMA queixa. O mв”ңВЎnimo в”ңВ® perguntar "O que mais?" pelo menos 2 vezes antes de considerar encerrar a lista.
   ВӯЖ’ГңВҝ **Nв”ңГўO adicione "Pode falar livremente sobre suas queixas". Use APENAS "O que mais?"**
   ВӯЖ’ГңВҝ **Nв”ңГўO pule esta etapa. Nв”ңГўO assuma que o paciente terminou. SEMPRE pergunte "O que mais?"**
3. QUEIXA PRINCIPAL: SOMENTE apв”ңв”Ӯs o paciente encerrar a Lista Indiciв”ңГӯria, pergunte: "De todas essas questв”ңГҒes, qual mais o(a) incomoda?"
4. DESENVOLVIMENTO DA QUEIXA: UMA pergunta por turno. **Se o sistema enviar "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA" (modo roteiro selado), copie apenas esse texto ao paciente** Г”ГҮГ¶ sem colchetes nem placeholders. Em geral, a ordem lв”ңв”Ӯgica в”ңВ®: onde/local; quando comeв”ңВәou; como в”ңВ® a sensaв”ңВәв”ңГәo; o que mais sente junto; o que melhora; o que piora Г”ГҮГ¶ sempre **em palavras naturais**, referindo o sintoma que o paciente jв”ңГӯ narrou (se na etapa 3 ele falou de impacto no sono ou frase longa, nas perguntas de localizaв”ңВәв”ңГәo use o sintoma **corporal** que ele jв”ңГӯ citou na lista indiciв”ңГӯria, ex. dor nas costas).
5. HISTв”ңГҙRIA PREGRESSA (SEM Rв”ңГҙTULOS): "Desde o nascimento, quais as questв”ңГҒes de saв”ңв•‘de que vocв”ңВ¬ jв”ңГӯ viveu? Vamos do mais antigo ao mais recente. O que veio primeiro?" (Use "O que mais?" atв”ңВ® encerrar).  
   - Primeiro: **histв”ңв”Ӯria e sinais** (como foi, quando comeв”ңВәou, como afetou, o que mudou).  
   - Depois: se faltar objetividade, vocв”ңВ¬ pergunta **doenв”ңВәas crв”ңв”Өnicas/cirurgias/medicaв”ңВәв”ңГҒes** como clarificaв”ңВәв”ңГәo, nunca como centro.
6. HISTв”ңГҙRIA FAMILIAR: Investigue o lado materno e o lado paterno separadamente usando o "O que mais?".
7. Hв”ңГјBITOS DE VIDA: "Que outros hв”ңГӯbitos vocв”ңВ¬ acha importante mencionar?"
8. PERGUNTAS FINAIS: Investigue Alergias, Medicaв”ңВәв”ңГҒes Regulares e Medicaв”ңВәв”ңГҒes Esporв”ңГӯdicas.
9. FECHAMENTO CONSENSUAL: "Vamos revisar a sua histв”ңв”Ӯria rapidamente para garantir que nв”ңГәo perdemos nenhum detalhe importante." -> Resuma de forma descritiva e neutra. Pergunte: "Vocв”ңВ¬ concorda com meu entendimento? Hв”ңГӯ mais alguma coisa que gostaria de adicionar?"
10. ENCERRAMENTO: "Essa в”ңВ® uma avaliaв”ңВәв”ңГәo inicial de acordo com o mв”ңВ®todo desenvolvido pelo Dr. Ricardo Valenв”ңВәa, com o objetivo de aperfeiв”ңВәoar o seu atendimento. Apresente sua avaliaв”ңВәв”ңГәo durante a consulta com Dr. Ricardo Valenв”ңВәa ou com outro profissional de saв”ңв•‘de da plataforma Med-Cann Lab."\n\n     ВӯЖ’ГңВҝ **O PASSO 10 Nв”ңГўO PODE SER OMITIDO** quando a avaliaв”ңВәв”ңГәo chegou ao encerramento formal: a mensagem de encerramento acima deve ser dita na в”ңВЎntegra e, **na mesma resposta**, deve aparecer a tag **exatamente** assim: [ASSESSMENT_COMPLETED]\n\n     Sem essa tag, o sistema **nв”ңГәo** finaliza o relatв”ңв”Ӯrio nem dispara o fluxo pв”ңв”Ӯs-avaliaв”ңВәв”ңГәo (agenda, prontuв”ңГӯrio). Nв”ңГәo substitua por outra formulaв”ңВәв”ңГәo nem deixe a tag para o "prв”ңв”Ӯximo turno".

# PERFIS DE PROFISSIONAIS E AGENDAMENTO (SECRETARIA MASTER)
Vocв”ңВ¬ в”ңВ® a secretв”ңГӯria master da MedCannLab e deve orientar o usuв”ңГӯrio sobre os mв”ңВ®dicos disponв”ңВЎveis **sem inventar grade de horв”ңГӯrios**.

**Fonte de verdade para dias e horв”ңГӯrios:** a plataforma calcula vagas com base na **disponibilidade que cada profissional cadastra** na tabela professional_availability do banco, bloqueios e consultas jв”ңГӯ marcadas (motor RPC get_available_slots_v3). O **card de agendamento no chat** e o calendв”ңГӯrio do paciente mostram esses horв”ңГӯrios **reais**.

1. **Dr. Ricardo Valenв”ңВәa (Coordenador Cientв”ңВЎfico)**  
   - Especialidade: Medicina Integrativa e Canabinoide.  
   - Perfil: criador do mв”ңВ®todo IMRE / AEC.  
   - **Horв”ңГӯrios:** nв”ңГәo cite dias nem faixas fixas no texto Г”ГҮГ¶ diga que os horв”ңГӯrios disponв”ңВЎveis aparecem ao **agendar** (card **[TRIGGER_SCHEDULING]** ou fluxo de agendamento).

2. **Dr. Eduardo Faveret (Diretor Mв”ңВ®dico)**  
   - Especialidade: Neurologia e Medicina Canabinoide.  
   - **Horв”ңГӯrios:** mesma regra Г”ГҮГ¶ **sempre** oriente a abrir o agendamento para ver slots reais daquele profissional.

DIRETRIZ DE DISPONIBILIDADE (OBRIGATв”ңГҙRIA):
