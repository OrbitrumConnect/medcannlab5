                action: 'INTENT_SUGGESTION',
                decision_result: 'SIGNAL',
                source: 'SMART_TRIGGER',
                metadata: { suggested_intent: 'ENSINO', original_trigger: 'keyword_match' }
            });
            // currentIntent = 'ENSINO'; // REMOVED MUTATION (Frontend decides next cycle)
            // OBS: Se precisarmos reagir IMEDIATAMENTE, o frontend deve ler este evento ou a resposta deve conter metadados.
            // Por enquanto, seguimos a regra estrita de nв”ңГәo mutar.
        }

        // в”ңГңltima mensagem da assistente (contexto para confirmaв”ңВәв”ңГҒes curtas)
        const lastAssistantContent = (conversationHistory && Array.isArray(conversationHistory))
            ? (conversationHistory.filter((m: any) => m.role === 'assistant').pop()?.content || '')
            : ''
        const lastWasSchedulingOffer = typeof lastAssistantContent === 'string' && (
            lastAssistantContent.includes('agendamento') ||
            lastAssistantContent.includes('agendar') ||
            lastAssistantContent.includes('horв”ңГӯrio') ||
            lastAssistantContent.includes('horario') ||
            lastAssistantContent.includes('sistema de agendamento') ||
            lastAssistantContent.includes('escolher um horв”ңГӯrio')
        )
        const isShortSchedulingConfirmation = lastWasSchedulingOffer && /^(abrir|sim|pode abrir|ver|ok|quero ver|abre|mostra|mostrar|pode mostrar|manda|envia|quero|pode ser|por favor|claro|isso|pode|faca|faв”ңВәa|manda aв”ңВЎ|envia aв”ңВЎ)\s*\.?\!?$/i.test(norm.trim())

        // ВӯЖ’Г№ГҙВҙВ©Г… Heurв”ңВЎstica: agendar = Aв”ңГ§в”ңГўO (card no chat) vs agendamento/agenda = LUGAR (navegar para a aba do calendв”ңГӯrio daquele perfil).
        // "No chat" / "aqui no chat" = usuв”ңГӯrio quer o CARD para agendar no chat; "abrir agendamento"/"minha agenda" = ir para a tela.
        const wantsAgendaInChat =
            (norm.includes('no chat') || norm.includes('aqui no chat') || norm.includes('dentro do chat') ||
                norm.includes('ver aqui')) &&
            (norm.includes('agenda') || norm.includes('agendamento') || norm.includes('agendar') || norm.includes('horario'))

        // "ver agendamento", "me levar para agendamento", "agendamento" (lugar) = sв”ңв”Ӯ navegar, NUNCA card.
        const isAgendaPlacePhrase = /(ver agendamento|me levar para agendamento|levar para agendamento|quero ver agendamento|ir para agendamento|abrir agenda|minha agenda|ver agenda|agenda clinica|agenda da clinica|agenda da minha clinica|minha clinica|abrir agendamento)/.test(norm)
        const isAgendaNavigationOnly =
            !wantsAgendaInChat &&
            !isShortSchedulingConfirmation &&
            (isAgendaPlacePhrase || (norm.trim() === 'agendamento' || /^agendamento\s*\.?\!?$/i.test(norm.trim()))) &&
            !(
                norm.includes('agendar') ||
                norm.includes('marcar') ||
                norm.includes('horario') ||
                norm.includes('disponivel') ||
                norm.includes('disponibilidade') ||
                norm.includes('vaga')
            )

        // Regra estrita: widget sв”ңв”Ӯ com Aв”ңГ§в”ңГўO de agendar Г”ГҮГ¶ ampliado para cobrir mais formas de falar (append-only).
        const hasScheduleVerb =
            norm.includes('agendar') ||
            norm.includes('marcar') ||
            /(gostaria de marcar|gostaria de agendar|quero marcar|preciso marcar)/i.test(norm)

        const hasConsultIntent =
            /(queria uma consulta|quero uma consulta|preciso de consulta|gostaria de consulta|consulta com (o )?m[eв”ңВ®]dico|consulta com (o )?dr\.?|consulta com (a )?doutora|consulta com (o )?profissional|consulta com [a-zв”ңГЎ-в”ңв•‘]+|agendar com (o )?(dr\.?|m[eв”ңВ®]dico|doutor|profissional)|marcar com (o )?(dr\.?|m[eв”ңВ®]dico|doutor)|hor[aв”ңГӯ]rio com (o )?(dr\.?|m[eв”ңВ®]dico|doutor)|marcar consulta|agendar consulta)/i.test(norm)

        // Mensagem curta (< 10 palavras) em contexto de agendamento = confirmaв”ңВәв”ңГәo/continuaв”ңВәв”ңГәo (abrir card), salvo se for lugar ou negativa.
        const wordCount = (norm.match(/\S+/g) || []).length
        const isShortMessageInSchedulingContext =
            wordCount <= 10 &&
            lastWasSchedulingOffer &&
            !isAgendaPlacePhrase &&
            !/(\bn[aв”ңГә]o\b|nunca|cancelar|cancela|cancel)/i.test(norm.trim())

        const hasSlotsIntent =
            wantsAgendaInChat ||
            norm.includes('horario') ||
            norm.includes('disponivel') ||
            norm.includes('disponibilidade') ||
            norm.includes('vaga') ||
            norm.includes('vagas') ||
            (norm.includes('agenda') && (norm.includes('mandar') || norm.includes('enviar') || norm.includes('mostrar') || norm.includes('ver horario')))

        const shouldTriggerSchedulingWidget =
            !isAgendaNavigationOnly && (hasScheduleVerb || hasSlotsIntent || hasConsultIntent || isShortSchedulingConfirmation || isShortMessageInSchedulingContext)

        // ВӯЖ’Г№ГҙВҙВ©Г… GATILHO DE AGENDAMENTO (SMART WIDGET TRIGGER) - V3 ROBUST
        if (shouldTriggerSchedulingWidget) {
            console.log('Г”ГңГӯ [TRIGGER] Palavra-chave de agendamento detectada. Gerando Evento de Sugestв”ңГәo.');
            // AJUSTE 2: Triggers viram eventos
            await supabaseClient.from('cognitive_events').insert({
                intent: currentIntent,
                action: 'INTENT_SUGGESTION',
                decision_result: 'SIGNAL',
                source: 'SMART_TRIGGER',
                metadata: { suggested_intent: 'ADMIN', original_trigger: 'schedule_keyword' }
            });
            // currentIntent = 'ADMIN'; // REMOVED MUTATION
        }

        // ВӯЖ’ГҰВҝГ”ГҮГ¬Г”ГңГІВҙВ©Г… DETECв”ңГ§в”ңГўO DE PROFISSIONAL (DINв”ңГ©MICA Г”ГҮГ¶ consulta banco)
        let detectedProfessionalId = 'ricardo-valenca'; // Default fallback
        try {
            const { data: professionals } = await supabaseClient
                .from('users')
                .select('id, name, slug')
                .eq('type', 'professional')
                .eq('is_active', true)

            if (professionals && professionals.length > 0) {
                for (const prof of professionals) {
                    const nameNorm = (prof.name || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
                    const slugNorm = (prof.slug || '').toLowerCase()
                    // Match any part of the name or slug in the user message
                    const nameParts = nameNorm.split(/\s+/).filter((p: string) => p.length > 3)
                    const matched = nameParts.some((part: string) => norm.includes(part)) || (slugNorm && norm.includes(slugNorm))
                    if (matched) {
                        detectedProfessionalId = prof.slug || prof.id
                        console.log(`ВӯЖ’ГҰВҝГ”ГҮГ¬Г”ГңГІВҙВ©Г… [DOCTOR] Detectado dinamicamente: ${prof.name} Г”ГҘГҶ ${detectedProfessionalId}`)
                        break
                    }
                }
            }
        } catch (profErr) {
            console.warn('Г”ГңГЎВҙВ©Г… Fallback para detecв”ңВәв”ңГәo hardcoded de profissional:', profErr)
            // Fallback hardcoded original
            if (norm.includes('faveret') || norm.includes('eduardo')) {
                detectedProfessionalId = 'eduardo-faveret';
            } else if (norm.includes('ricardo') || norm.includes('valenca')) {
                detectedProfessionalId = 'ricardo-valenca';
            }
        }

        // ВӯЖ’Г¶Г¬ RAG: Busca na Base de Conhecimento (Knowledge Retrieval)
        let knowledgeBlock = ''
        if (message && message.length > 3) {
            const keywords = message.split(' ')
                .filter((w: string) => w.length > 3)
                .map((w: string) => w.toLowerCase().replace(/[^a-z0-9в”ңГӯв”ңГЎв”ңГів”ңГәв”ңВ®в”ңВҝв”ңВ¬в”ңВЎв”ңВ»в”ңв”Ӯв”ңв”Өв”ңГҒв”ңГӮв”ңв•‘в”ңВәв”ңв–’]/g, '')) // Sanitizaв”ңВәв”ңГәo leve
                .filter((w: string) => w.length > 0)
                .slice(0, 5); // Limit 5 keywords

            if (keywords.length > 0) {
                // Busca OR simples por keywords no conteudo
                const queryFilters = keywords.map((w: string) => `conteudo.ilike.%${w}%`).join(',');

                try {
                    const { data: knowledge, error: ragError } = await supabaseClient
                        .from('base_conhecimento')
                        .select('titulo, conteudo')
                        .or(queryFilters)
                        .limit(3);

                    if (!ragError && knowledge && knowledge.length > 0) {
                        knowledgeBlock = `\n\nВӯЖ’ГҙГң BASE DE CONHECIMENTO (FONTE PRIORITв”ңГјRIA):\n${knowledge.map((k: any) => `Г”ГҮГі [${k.titulo}]: ${k.conteudo}`).join('\n')}\nUtilize ESTRITAMENTE estas informaв”ңВәв”ңГҒes para responder se forem relevantes. Se a resposta estiver aqui, cite a fonte.`;
                        console.log(`ВӯЖ’ГҙГң [RAG] ${knowledge.length} artigos encontrados para keywords: [${keywords.join(', ')}]`);
                    }
                } catch (err) {
                    console.warn('Г”ГңГЎВҙВ©Г… [RAG] Falha na busca de conhecimento:', err);
                }
            }
        }

        // Mapear intenв”ңВәв”ңГҒes para modos
        // Mapear intenв”ңВәв”ңГҒes para modos
        const isTeachingMode = currentIntent === 'ENSINO';

        const systemPrompt = isTeachingMode ? TEACHING_PROMPT : CLINICAL_PROMPT;

        console.log('ВӯЖ’Г„ВЎ [PERSONA SELECTED]', {
            mode: isTeachingMode ? 'TEACHING (Patient Paula)' : 'CLINICAL (Doctor Noa)',
            intent: currentIntent,
            triggerKeyword: isTeachingMode
        });

        if (action === 'calculate_priority') {
            console.log('ВӯЖ’Г…Г‘ [ACTION] Calculating Clinical Priority...')

            // 1. COS v1.0: Gerar в”ңГјtomo de Decisв”ңГәo (PRE-AI/Logic)
            const { data: decData, error: decError } = await supabaseClient
                .from('cognitive_decisions')
                .insert({
                    decision_type: 'priority',
                    recommendation: { status: 'calculating' },
                    justification: 'Cв”ңГӯlculo de prioridade clв”ңВЎnica iniciado.',
                    confidence: 0,
                    autonomy_level: cosDecision.autonomy_level,
                    requires_human_confirmation: true,
                    policy_snapshot: {
                        intent: 'CLINICA',
                        version: policy?.version || 1,
                        autonomy_level: policy?.autonomy_level || 1,
                        frozen_at: new Date().toISOString()
                    },
                    model_version: CHAT_MODEL
                })
                .select()
                .single()

            if (decError) throw decError

            // 2. Lв”ңв”Ӯgica de Priorizaв”ңВәв”ңГәo (Core Logic)
            const priorityLevel = (patientData?.risk_level === 'high' || patientData?.urgency === 'immediate') ? 1 : 2
            const justification = `Prioridade nв”ңВЎvel ${priorityLevel} atribuв”ңВЎda com base no nв”ңВЎvel de risco ${patientData?.risk_level || 'nв”ңГәo informado'}.`

            // 3. Atualizar в”ңГјtomo de Decisв”ңГәo (Post-Logic)
            await supabaseClient.from('cognitive_decisions')
                .update({
                    recommendation: { priority_level: priorityLevel, clinical_context: patientData },
                    justification,
                    alternatives: [{ priority_level: priorityLevel + 1, reason: 'Aguardar exames complementares' }],
                    confidence: 0.9
                })
                .eq('id', decData.id)

            // 4. COS v1.0: Atualizar Metabolismo
            await supabaseClient.rpc('increment_metabolism', { p_id: professionalId })

            return new Response(JSON.stringify({
                success: true,
                decision_id: decData.id,
                priority: priorityLevel,
                justification
            }), { headers: corsHeaders })
        }

        // Bloqueio por polв”ңВЎtica explв”ңВЎcita ( forbidden_actions )
        if (policy?.forbidden_actions?.includes(action)) {
            console.warn(`ВӯЖ’ГңВҪ [POLICY BLOCK] Aв”ңВәв”ңГәo "${action}" proibida para intenв”ңВәв”ңГәo "${currentIntent}"`)
            return new Response(JSON.stringify({
                text: 'Esta aв”ңВәв”ңГәo nв”ңГәo в”ңВ® permitida pelas polв”ңВЎticas cognitivas atuais.',
                metadata: { policy_blocked: true, intent: currentIntent }
            }), { headers: corsHeaders })
        }

        // AJUSTE 4: READ_ONLY como guarda-mв”ңГәe
        // Se o modo operacional ou polв”ңВЎtica for READ_ONLY, bloquear writes
        if (cosDecision?.autonomy_level === 0 || policy?.autonomy_level === 0) { // Assuming level 0 implies READ_ONLY or similar restricted state if explicit string not avail.
            // OR check explicit mode if available. The prompt said "if (cosDecision.mode === 'READ_ONLY')"
            // Lets assume metadata or simulate it if typings missing, but sticking to prompt logic:
            // Checking if cosDecision has 'mode' property effectively.
        }

        // Better implementation based on USER Prompt:
        // "if (cosDecision.mode === 'READ_ONLY')"
        // We will assume cosDecision might have this prop or we check policy.

        // Since we don't have strict types for cosDecision here visible, we'll try to use a safe check
        // Assuming cosDecision comes from `cognitive_decisions` table logic locally or just added

        if ((cosDecision as any)?.mode === 'READ_ONLY') {
            const forbiddenInReadOnly = ['finalize_assessment', 'predict_scheduling_risk', 'calculate_priority'];
            if (forbiddenInReadOnly.includes(action)) {
                console.warn(`ВӯЖ’ГңВҪ [READ_ONLY BLOCK] Action ${action} blocked.`);
                return new Response(JSON.stringify({
                    text: 'Modo READ_ONLY ativo. Aв”ңВәв”ңГәo bloqueada pelo Protocolo de Governanв”ңВәa.',
                    metadata: { mode: 'READ_ONLY', block: true }
                }), { headers: corsHeaders })
            }
        }

        const CONTEXT_BLOCK = `
CONTEXTO DO USUв”ңГјRIO:
${JSON.stringify(patientData, null, 2)}
`;

        // 6. Preparar mensagens para OpenAI (incluindo histв”ңв”Ӯrico)
        // ======================================================
        // ВӯЖ’Г№ГҙВҙВ©Г… SMART SCHEDULING TRIGGER (COS 5.0)
        // ======================================================
        // Injeta lв”ңв”Ӯgica de agendamento se avaliaв”ңВәв”ңГәo acabou de ser finalizada ou se o paciente estв”ңГӯ sem mв”ңВ®dico

        let systemInjection: any[] = []

        // Verifica se в”ңВ® paciente e se estamos em contexto clв”ңВЎnico/admin
        if (patientData?.user?.id && (currentIntent === "CLINICA" || currentIntent === "ADMIN")) {

            // 1. Checar se avaliaв”ңВәв”ңГәo foi concluв”ңВЎda recentemente (ou se status jв”ңГӯ в”ңВ® 'completed')
            const { data: lastReport } = await supabaseClient
                .from("clinical_reports")
                .select("status, created_at")
                .eq("patient_id", patientData.user.id)
                .eq("status", "completed")
                .order("created_at", { ascending: false })
                .limit(1)
                .maybeSingle()


            // 2. Se tem avaliaв”ңВәв”ңГәo concluв”ңВЎda, rodar lв”ңв”Ӯgica de Trigger Pв”ңв”Ӯs-Avaliaв”ңВәв”ңГәo
            if (lastReport) {
                // AJUSTE 3: SYSTEM_TRIGGER passa pelo CEP (Audit)
                await supabaseClient.from('cognitive_events').insert({
                    intent: currentIntent,
                    action: 'SYSTEM_INJECTION',
                    decision_result: 'ALLOWED',
                    source: 'COS-5.0',
                    metadata: { reason: 'post_assessment_orchestration' }
                })

                // ... (Logic for completed assessment) ...
                // ... (Logic for completed assessment) ...
                // Verificar se jв”ңГӯ tem mв”ңВ®dico atribuв”ңВЎdo
                const { data: patientDoc } = await supabaseClient
                    .from("patient_doctors") // View criada
                    .select("doctor_name, is_official, doctor_id")
                    .eq("patient_id", patientData.user.id)
                    .maybeSingle()

                if (patientDoc) {
                    // Tem mв”ңВ®dico: Sugerir agendar com ele
                    if (message.includes("avaliacaocompleta") || message.length < 5) {
                        systemInjection.push({
                            role: "system",
                            content: `[SYSTEM_TRIGGER]: O paciente Jв”ңГј finalizou a avaliaв”ңВәв”ңГәo. O mв”ңВ®dico responsв”ңГӯvel в”ңВ® ${patientDoc.doctor_name}. Pergunte se ele deseja ver os horв”ңГӯrios disponв”ңВЎveis para agendamento AGORA.
                            
                            Se o paciente confirmar, responda algo como "Aqui estв”ңГәo os horв”ңГӯrios..." e ADICIONE A TAG [TRIGGER_SCHEDULING] ao final.
                            
                            Nв”ңГўO LISTE HORв”ңГјRIOS EM TEXTO. O WIDGET FARв”ңГј ISSO.
                            
                            METADADO CRв”ңГ¬TICO: ${patientDoc.doctor_id} (ID do Mв”ңВ®dico).`
                        })
                    }
                } else {
                    // Nв”ңГўO tem mв”ңВ®dico: Oferecer Oficiais vs Parceiros
                    const { data: officials } = await supabaseClient.from("doctors").select("name").eq("is_official", true).limit(5)
                    const { data: partners } = await supabaseClient.from("doctors").select("name").eq("is_official", false).limit(5)

                    const officialList = officials?.map((d: any) => d.name).join(", ") || "Dr. Ricardo Valenв”ңВәa, Dr. Eduardo Faveret"
                    const partnerList = partners?.map((d: any) => d.name).join(", ") || "Dr. Joв”ңГәo, Dra. Maria"

                    systemInjection.push({
                        role: "system",
                        content: `[SYSTEM_TRIGGER]: O paciente finalizou a avaliaв”ңВәв”ңГәo mas Nв”ңГўO tem mв”ңВ®dico vinculado.
                        VOCв”ңГЁ DEVE PERGUNTAR: "Para prosseguirmos com seu tratamento, vocв”ңВ¬ prefere ser atendido por um dos nossos Mв”ңВ®dicos Oficiais do App ou por um Profissional Parceiro?"
                        
                        OPв”ңГ§в”ңГІES:
                        - Mв”ңВ®dicos Oficiais (Alta Especializaв”ңВәв”ңГәo - Mв”ңВ®todo IMRE): ${officialList}
                        - Parceiros (Rede Credenciada): ${partnerList}
                        
                        AGUARDE A ESCOLHA DO USUв”ңГјRIO PARA MOSTRAR A AGENDA.
                        
                        CRв”ңГ¬TICO: Se o usuв”ңГӯrio aceitar ou escolher um mв”ңВ®dico, VOCв”ңГЁ DEVE ADICIONAR A TAG [TRIGGER_SCHEDULING] AO FINAL DA SUA RESPOSTA.
                        Isso abrirв”ңГӯ o WIDGET de agendamento no chat.
                        
                        Nв”ңГўO LISTE HORв”ңГјRIOS EM TEXTO (Nв”ңГўO INVENTE DATAS). APENAS ABRA O WIDGET.`
                    })
                }
            } else if (currentIntent === "ADMIN") {
                // 3. ВӯЖ’ГёГӯВҙВ©Г… PREREQUISITE GUARD: Agendamento solicitado SEM avaliaв”ңВәв”ңГәo prв”ңВ®via (lastReport в”ңВ® null e intenв”ңВәв”ңГәo в”ңВ® ADMIN)

                systemInjection.push({
                    role: "system",
                    content: `[SYSTEM_GUARD]: O usuв”ңГӯrio solicitou AGENDAMENTO, mas Nв”ңГўO possui avaliaв”ңВәв”ңГәo clв”ңВЎnica completa no sistema. 
                    
                    A POLв”ңГ¬TICA Mв”ңГ«DICA EXIGE QUE VOCв”ңГЁ DIGA:
                    "Para garantirmos um tratamento personalizado e preciso, в”ңВ® essencial realizar nossa Avaliaв”ңВәв”ңГәo Clв”ңВЎnica Inicial antes de agendar. Isso permite que o mв”ңВ®dico aproveite melhor o tempo da consulta com vocв”ңВ¬."
                    
                    PERGUNTE: "Gostaria de iniciar essa avaliaв”ңВәв”ңГәo agora? в”ңГ« rв”ңГӯpida e feita por aqui mesmo."
                    
                    Nв”ңГўO LISTE HORв”ңГјRIOS AINDA.`
                })
            }
        }

        const interactionStyleInstruction =
            interactionDepthLevel >= 60
                ? `\n\n[CAS:ESTILO] O usuв”ңГӯrio demonstrou linguagem meta-cognitiva (estado operacional). Use linguagem mais precisa, profunda e estruturada. Evite superficialidade.`
                : interactionDepthLevel >= 30
                    ? `\n\n[CAS:ESTILO] Use linguagem clara e bem estruturada, com passo-a-passo.`
                    : ''

        const docInChat = ui_context?.document_in_chat
        let contentExcerpt = (docInChat?.content_excerpt || docInChat?.content || '').trim()

        // DETECT RAW PDF BINARY: Se o conteв”ңв•‘do в”ңВ® lixo binв”ңГӯrio de PDF, tratar como nв”ңГәo-extraв”ңВЎdo
        const isRawPdfBinary = (text: string) => {
            if (!text || text.length < 100) return false
            const pdfIndicators = ['endstream', 'endobj', 'xref', '0000000', 'trailer', 'obj\n', '/Type', '/Page']
            const matchCount = pdfIndicators.filter(ind => text.includes(ind)).length
            return matchCount >= 3
        }

        if (isRawPdfBinary(contentExcerpt)) {
            console.log(`Г”ГңГЎВҙВ©Г… [DOC] Conteв”ңв•‘do в”ңВ® PDF binв”ңГӯrio raw (nв”ңГәo extraв”ңВЎdo). Limpando.`)
            contentExcerpt = ''
        }

        // AUTO-FETCH: Se o documento estв”ңГӯ aberto mas sem conteв”ңв•‘do extraв”ңВЎdo, buscar do banco
        if (docInChat?.id && contentExcerpt.length < 50) {
            console.log(`ВӯЖ’ГҙГӨ [DOC AUTO-FETCH] Conteв”ңв•‘do vazio para doc ${docInChat.id}, buscando do banco...`)
            try {
                const { data: dbDoc } = await supabaseClient
                    .from('documents')
                    .select('content, summary')
                    .eq('id', docInChat.id)
                    .maybeSingle()
                if (dbDoc?.content && dbDoc.content.length > 50 && !isRawPdfBinary(dbDoc.content)) {
                    contentExcerpt = dbDoc.content.slice(0, 4000)
                    if (!docInChat.summary && dbDoc.summary) {
                        docInChat.summary = dbDoc.summary
                    }
                    console.log(`Г”ВЈГ  [DOC AUTO-FETCH] Conteв”ңв•‘do recuperado: ${contentExcerpt.length} chars`)
                } else {
                    console.log(`Г”ГңГЎВҙВ©Г… [DOC AUTO-FETCH] Documento sem conteв”ңв•‘do vв”ңГӯlido no banco (id=${docInChat.id})`)
                }
            } catch (fetchErr) {
                console.warn(`Г”ГҳГ® [DOC AUTO-FETCH] Erro ao buscar documento:`, fetchErr)
            }
        }

        const documentBlock = docInChat && docInChat.title
            ? `\n\n[DOCUMENTO ABERTO NO CHAT Г”ГҮГ¶ INSTRUв”ңГ§в”ңГўO PRIORITв”ңГјRIA]
O usuв”ңГӯrio tem o seguinte documento aberto no chat. Quando ele pedir para analisar, resumir, avaliar, comentar ou interpretar, vocв”ңВ¬ DEVE responder com base NO CONTEв”ңГңDO REAL abaixo. Nв”ңГўO dв”ңВ¬ respostas genв”ңВ®ricas. Cite trechos, dados e pontos especв”ңВЎficos do documento.

Tв”ңВЎtulo: ${docInChat.title}
Resumo: ${docInChat.summary || 'N/A'}
Conteв”ңв•‘do (extrato):
${contentExcerpt || '(Texto nв”ңГәo disponв”ңВЎvel para este documento. O conteв”ңв•‘do ainda nв”ңГәo foi extraв”ңВЎdo do PDF. Informe ao usuв”ңГӯrio que este documento precisa ser reprocessado pela extraв”ңВәв”ңГәo de texto antes de poder ser analisado.)'}`
            : ''

        // STRIP ESPELHAMENTO from user message to avoid token duplication
        let cleanMessage = message
        const espelhoIdx = cleanMessage.indexOf('--- CONTEв”ңГңDO DO DOCUMENTO (ESPELHADO) ---')
        if (espelhoIdx > -1) {
            const fimIdx = cleanMessage.indexOf('--- FIM DO DOCUMENTO ---')
            if (fimIdx > -1) {
                cleanMessage = cleanMessage.substring(0, espelhoIdx).trim() + '\n' + cleanMessage.substring(fimIdx + '--- FIM DO DOCUMENTO ---'.length).trim()
            }
            // If message becomes too short after stripping, keep the original intent
            if (cleanMessage.trim().length < 10) {
                cleanMessage = 'Analise o documento que acabei de abrir no chat.'
            }
        }

        // TRUNCATE conversation history if total context is too large
        let trimmedHistory = conversationHistory || []
        const estimatedSystemTokens = (systemPrompt.length + (knowledgeBlock?.length || 0) + documentBlock.length + (JSON.stringify(patientData) || '').length) / 3
        if (estimatedSystemTokens > 80000) {
            // Too much context Г”ГҮГ¶ reduce history aggressively
            trimmedHistory = trimmedHistory.slice(-6)
            console.log(`Г”ГңГЎВҙВ©Г… [TOKEN MGMT] Context muito grande (~${Math.round(estimatedSystemTokens)} tokens estimados). Histв”ңв”Ӯrico reduzido para ${trimmedHistory.length} msgs.`)
        } else if (estimatedSystemTokens > 50000) {
            trimmedHistory = trimmedHistory.slice(-10)
        }

        // ВӯЖ’Г¶ГҶ PHASE LOCK: Reforв”ңВәo de fase como в”ңв•‘ltima mensagem de sistema (posiв”ңВәв”ңГәo mais influente para o modelo)
        // Isso impede que o GPT abandone o protocolo AEC quando o paciente dв”ңГӯ respostas curtas ou ambв”ңВЎguas.
        const phaseReinforcementMessages: Array<{role: string, content: string}> = []
        if (assessmentPhase && userRole === 'patient') {
            // clinicalAssessmentFlow.ts usa INITIAL_GREETING, IDENTIFICATION, etc. Г”ГҮГ¶ mapear para trilhos do Core (antes sв”ңв”Ӯ OPENING/COMPLAINT_* alinhavam).
            const phaseMap: Record<string, string> = {
                'OPENING': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na ABERTURA do protocolo AEC 001. Apresente-se com a frase exata do protocolo. Nв”ңГўO encerre a conversa.',
                'INITIAL_GREETING': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 1 Г”ГҮГ¶ ABERTURA. Se ainda nв”ңГәo usou, diga EXATAMENTE a frase de abertura do AEC 001. Depois aguarde apresentaв”ңВәв”ңГәo do paciente. Nв”ңГўO pule para "quando comeв”ңВәou" nem desenvolvimento de queixa.',
                'IDENTIFICATION': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 2 (inв”ңВЎcio da lista indiciв”ңГӯria). Pergunte EXATAMENTE: "O que trouxe vocв”ңВ¬ в”ңГЎ nossa avaliaв”ңВәв”ңГәo hoje?" Г”ГҮГ¶ Nв”ңГўO pergunte "quando comeв”ңВәou", localizaв”ңВәв”ңГәo ou queixa principal antes disso.',
                'COMPLAINT_LIST': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na LISTA INDICIв”ңГјRIA (Etapa 2). Vocв”ңВ¬ DEVE perguntar "O que mais?" apв”ңв”Ӯs CADA resposta do paciente. Nв”ңГўO avance para a Queixa Principal. Nв”ңГўO encerre a conversa. Nв”ңГўO diga "Se precisar de algo". O paciente estв”ңГӯ em avaliaв”ңВәв”ңГәo ativa. Pergunte "O que mais?" AGORA.',
                'MAIN_COMPLAINT': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na QUEIXA PRINCIPAL (Etapa 3). Pergunte EXATAMENTE: "De todas essas questв”ңГҒes, qual mais o(a) incomoda?" Nв”ңГўO encerre. Nв”ңГўO diga "estou aqui para ajudar". Continue a avaliaв”ңВәв”ңГәo.',
                'COMPLAINT_DETAILS': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 4 Г”ГҮГ¶ DESENVOLVIMENTO DA QUEIXA. Faв”ңВәa SOMENTE a pergunta indicada em "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA" neste turno. Leia o histв”ңв”Ӯrico: se o paciente jв”ңГӯ disse ONDE e QUANDO, Nв”ңГўO repita essas perguntas Г”ГҮГ¶ avance para a prв”ңв”Ӯxima do roteiro (como в”ңВ®, o que melhora/piora, etc.). Nв”ңГўO dв”ңВ¬ aula de anatomia no lugar da pergunta do protocolo. Nв”ңГўO diga "Se precisar".',
                'PAST_HISTORY': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na HISTв”ңГҙRIA PREGRESSA (Etapa 5). Pergunte sobre questв”ңГҒes de saв”ңв•‘de desde o nascimento. Use "O que mais?" atв”ңВ® encerrar. Nв”ңГўO encerre a avaliaв”ңВәв”ңГәo.',
                'MEDICAL_HISTORY': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na HISTв”ңГҙRIA PREGRESSA (Etapa 5). Pergunte sobre questв”ңГҒes de saв”ңв•‘de desde o nascimento. Use "O que mais?" atв”ңВ® encerrar.',
                'FAMILY_HISTORY': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ na HISTв”ңГҙRIA FAMILIAR (Etapa 6). Investigue lado materno e paterno. Nв”ңГўO encerre.',
                'FAMILY_HISTORY_MOTHER': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 6 Г”ГҮГ¶ histв”ңв”Ӯria familiar (lado materno). Use "O que mais?" atв”ңВ® encerrar este lado.',
                'FAMILY_HISTORY_FATHER': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 6 Г”ГҮГ¶ histв”ңв”Ӯria familiar (lado paterno). Use "O que mais?" atв”ңВ® encerrar.',
                'LIFESTYLE': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ em Hв”ңГјBITOS DE VIDA (Etapa 7). Pergunte sobre hв”ңГӯbitos. Nв”ңГўO encerre.',
                'LIFESTYLE_HABITS': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 7 Г”ГҮГ¶ hв”ңГӯbitos de vida. Use APENAS o texto da "PRв”ңГҙXIMA PERGUNTA OBRIGATв”ңГҙRIA" ou do protocolo, sem elogiar hв”ңГӯbitos (nada de "в”ңв”Ӯtimo", "excelente", "parabв”ңВ®ns"). Sem opiniв”ңГҒes sobre saв”ңв•‘de fora do roteiro. "O que mais?" sв”ңв”Ӯ quando o protocolo pedir lista.',
                'FINAL_QUESTIONS': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ nas PERGUNTAS FINAIS (Etapa 8). Investigue alergias, medicaв”ңВәв”ңГҒes regulares e esporв”ңГӯdicas. Nв”ңГўO encerre.',
                'OBJECTIVE_QUESTIONS': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 8 Г”ГҮГ¶ perguntas objetivas. Copie literalmente a pergunta indicada (alergias, medicaв”ңВәв”ңГҒes). Proibido alongar, exemplificar alв”ңВ®m do protocolo ou opinar. Uma pergunta por turno.',
                'CONSENSUS': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ no FECHAMENTO CONSENSUAL (Etapa 9). Resuma a histв”ңв”Ӯria e peв”ңВәa confirmaв”ңВәв”ңГәo. Nв”ңГўO encerre sem consenso.',
                'CONSENSUS_REVIEW': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 9 Г”ГҮГ¶ revisв”ңГәo consensual. Respeite o texto do protocolo.',
                'CONSENSUS_REPORT': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Etapa 9 Г”ГҮГ¶ apresente o entendimento e peв”ңВәa concordв”ңГіncia do paciente.',
                'CONSENT_COLLECTION': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Coleta de consentimento informado. Siga o roteiro aprovado; nв”ңГәo desvie para anamnese.',
                'CONSENSUS_CONFIRMATION': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Confirmaв”ңВәв”ңГәo de consenso. Seja clara e objetiva.',
                'FINAL_RECOMMENDATION': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Recomendaв”ңВәв”ңГәo final antes do encerramento formal.',
                'CLOSING': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Vocв”ңВ¬ estв”ңГӯ no ENCERRAMENTO (Etapa 10). Diga a frase de encerramento e inclua [ASSESSMENT_COMPLETED].',
                'CONFIRMING_EXIT': 'ВӯЖ’Г¶ГҶ PHASE LOCK: O paciente pediu para interromper. Vocв”ңВ¬ estв”ңГӯ na confirmaв”ңВәв”ңГәo (sim/nв”ңГәo). Nв”ңГўO continue a anamnese atв”ңВ® ele responder. Se confirmar saв”ңВЎda, aceite com empatia e encerre sem forв”ңВәar novas perguntas clв”ңВЎnicas.',
                'CONFIRMING_RESTART': 'ВӯЖ’Г¶ГҶ PHASE LOCK: O sistema perguntou se o paciente quer REINICIAR a avaliaв”ңВәв”ңГәo do zero. Responda sв”ңв”Ӯ em funв”ңВәв”ңГәo de sim/nв”ңГәo Г”ГҮГ¶ nв”ңГәo continue anamnese nem mude de assunto atв”ңВ® ele esclarecer.',
                'INTERRUPTED': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Avaliaв”ңВәв”ңГәo interrompida pelo paciente. Nв”ңГәo retome perguntas clв”ңВЎnicas a menos que ele peв”ңВәa para continuar a avaliaв”ңВәв”ңГәo.',
                'FOLLOW_UP': 'ВӯЖ’Г¶ГҶ PHASE LOCK: Avaliaв”ңВәв”ңГәo em andamento. Continue de onde parou. Nв”ңГўO encerre prematuramente.'
            }
            const lockMsg = phaseMap[assessmentPhase]
            if (lockMsg) {
                phaseReinforcementMessages.push({ role: 'system', content: lockMsg })
                console.log(`ВӯЖ’Г¶ГҶ [PHASE LOCK] Reforв”ңВәo injetado para fase: ${assessmentPhase}`)
            }
        }

        const messages = [
            { role: "system", content: systemPrompt + knowledgeBlock + phaseInstruction + interactionStyleInstruction + `\nPERFIL DO USUв”ңГјRIO: ${userRole} (${userRole === 'admin' || userRole === 'master' || userRole === 'professional' ? 'PROFISSIONAL/ADMIN Г”ГҮГ¶ modo executivo, Nв”ңГўO iniciar AEC 001 a menos que explicitamente solicitado' : 'PACIENTE Г”ГҮГ¶ seguir AEC 001 se aplicв”ңГӯvel'})\nCONTEXTO:\n${JSON.stringify(patientData)}` + documentBlock },
            ...systemInjection,
            ...trimmedHistory,
            ...phaseReinforcementMessages,
            { role: "user", content: cleanMessage }
        ]

        console.log(`ВӯЖ’ВәГЎ Contexto histв”ңв”Ӯrico de ${conversationHistory?.length || 0} mensagens adicionado`)

        // 7. Chamada в”ңГЎ OpenAI (GPT-4o)
        const completion = await openai.chat.completions.create({
            model: CHAT_MODEL,
            messages,
            temperature: isTeachingMode ? 0.7 : 0.2, // Ensino = 0.7 para atuaв”ңВәв”ңГәo mais natural da Paula
            max_tokens: 1500
        }).catch(async (openaiError) => {
            console.error('Г”ГңГЎВҙВ©Г… [OPENAI DOWN] Ativando Modo Determinв”ңВЎstico (Consciв”ңВ¬ncia Reduzida)...', openaiError);

            // --- DETERMINISTIC CORE MODE (Sovereignty Protocol v2) ---
            // O pipeline cognitivo continua intacto. Apenas a camada generativa в”ңВ® substituв”ңВЎda
            // por composiв”ңВәв”ңГәo textual determinв”ңВЎstica baseada em intent, role e knowledgeBlock.

            // 1. Log do Trauma
            await supabaseClient.from('institutional_trauma_log').insert({
                severity: 'HIGH',
                reason: 'Brain Disconnect (OpenAI API Failure)',
                affected_domain: currentIntent,
                metadata: { error: openaiError.message, mode: 'deterministic' }
            });

            // ============================================================
            // 2. MOTOR DETERMINв”ңГ¬STICO SEMв”ңГ©NTICO (5 Camadas)
            //    Composiв”ңВәв”ңГәo textual inteligente sem LLM. Respeita:
            //    - Triggers (imutв”ңГӯveis)
            //    - Governanв”ңВәa por role
            //    - Seguranв”ңВәa clв”ңВЎnica (nunca diagnostica)
            //    - Identidade da Nв”ңв”Өa
            // ============================================================

            // --- CAMADA 1: DETECв”ңГ§в”ңГўO SEMв”ңГ©NTICA DE CONCEITOS ---
            // Dicionв”ңГӯrios clв”ңВЎnicos controlados (nв”ңГәo NLP Г”ГҮГ¶ pattern matching expandido)
            const conceptDictionary: Record<string, string[]> = {
                dor: ['dor', 'doendo', 'dolorido', 'doi', 'dores', 'dolorosa', 'latejando', 'pontada', 'fisgada', 'incomodo'],
                sono: ['insonia', 'insв”ңв”Өnia', 'nao durmo', 'sono ruim', 'dormir mal', 'noite mal', 'acordo de madrugada', 'sem dormir', 'pesadelo'],
                ansiedade: ['ansioso', 'ansiedade', 'nervoso', 'palpitacao', 'apreensivo', 'agitado', 'inquieto', 'angustia', 'panico'],
                humor: ['triste', 'deprimido', 'sem animo', 'desanimado', 'melancolico', 'chorando', 'apatico', 'irritado'],
                cannabis: ['cannabis', 'cbd', 'thc', 'canabidiol', 'oleo de cannabis', 'canabinoide', 'flor', 'extrato'],
                medicacao: ['medicamento', 'remedio', 'receita', 'dose', 'dosagem', 'tomar', 'prescricao', 'capsulas'],
                exame: ['exame', 'resultado', 'laboratorio', 'hemograma', 'creatinina', 'sangue', 'urina'],
                agenda: ['agendar', 'marcar', 'consulta', 'retorno', 'horario', 'disponibilidade', 'encaixe'],
                documento: ['documento', 'arquivo', 'artigo', 'protocolo', 'manual', 'relatorio']
            }
            const detectedConcepts: string[] = []
            const normLower = (norm || '').toLowerCase()
            for (const [concept, patterns] of Object.entries(conceptDictionary)) {
                if (patterns.some(p => normLower.includes(p))) {
                    detectedConcepts.push(concept)
                }
            }
            console.log('ВӯЖ’ВәГЎ [DETERMINISTIC] Conceitos detectados:', detectedConcepts)

            // --- CAMADA 2: MEMв”ңГҙRIA CONVERSACIONAL ESTRUTURADA ---
            // Extrair contexto da conversa atual (conversationHistory jв”ңГӯ estв”ңГӯ no scope)
            let lastTopic = ''
            let lastAssistantMsg = ''
            let conversationDepth = 0
            if (conversationHistory && Array.isArray(conversationHistory)) {
                conversationDepth = conversationHistory.length
                const assistantMessages = conversationHistory
                    .filter((m: any) => m.role === 'assistant')
                    .map((m: any) => typeof m.content === 'string' ? m.content : '')
                if (assistantMessages.length > 0) {
                    lastAssistantMsg = assistantMessages[assistantMessages.length - 1]
                }
                // Extrair в”ңв•‘ltimo tema da conversa do usuв”ңГӯrio
                const userMessages = conversationHistory
                    .filter((m: any) => m.role === 'user')
                    .map((m: any) => typeof m.content === 'string' ? m.content.toLowerCase() : '')
                for (const um of userMessages.reverse()) {
                    for (const [concept, patterns] of Object.entries(conceptDictionary)) {
                        if (patterns.some(p => um.includes(p))) {
                            lastTopic = concept
                            break
                        }
                    }
                    if (lastTopic) break
                }
            }

            // --- CAMADA 3: MOTOR DE RELAв”ңГ§в”ңГўO DE FATORES ---
            // Correlaв”ңВәв”ңГҒes clв”ңВЎnicas mapeadas (determinв”ңВЎsticas, nв”ңГәo inferв”ңВ¬ncia)
            const factorRelations: Record<string, { related: string[], question: string }> = {
                sono: {
                    related: ['ansiedade', 'humor', 'dor'],
                    question: 'Vale observar se houve mudanв”ңВәa no nв”ңВЎvel de estresse ou na rotina que possa estar influenciando.'
                },
                dor: {
                    related: ['sono', 'medicacao', 'ansiedade'],
                    question: 'Fatores como hidrataв”ңВәв”ңГәo, tensв”ңГәo muscular e qualidade do sono podem influenciar. Podemos registrar esses detalhes para o profissional.'
                },
                ansiedade: {
                    related: ['sono', 'humor', 'medicacao'],
                    question: 'в”ңГ« importante acompanhar se hв”ңГӯ padrв”ңГҒes Г”ГҮГ¶ em que momentos isso costuma piorar ou melhorar?'
                },
                humor: {
                    related: ['sono', 'ansiedade', 'cannabis'],
                    question: 'Podemos registrar como vocв”ңВ¬ tem se sentido para que o profissional avalie com precisв”ңГәo na prв”ңв”Ӯxima consulta.'
                },
                cannabis: {
                    related: ['sono', 'dor', 'ansiedade'],
                    question: 'O acompanhamento do protocolo в”ңВ® fundamental. Hв”ңГӯ algo especв”ңВЎfico sobre o uso que gostaria de registrar?'
                },
                medicacao: {
                    related: ['dor', 'sono', 'cannabis'],
                    question: 'Posso registrar qualquer observaв”ңВәв”ңГәo sobre sua medicaв”ңВәв”ңГәo para que o profissional avalie no prв”ңв”Ӯximo encontro.'
                },
                exame: {
                    related: ['medicacao'],
                    question: 'Para uma anв”ңГӯlise completa dos seus exames, o profissional poderв”ңГӯ avaliar na prв”ңв”Ӯxima consulta. Posso abrir seu histв”ңв”Ӯrico.'
                }
            }

            // --- CAMADA 4: MOTOR DE REPHRASE (MICROVARIAв”ңГ§в”ңГўO DETERMINв”ңГ¬STICA) ---
            const msgHash = (norm || '').split('').reduce((a: number, c: string) => a + c.charCodeAt(0), 0)
            const variant = msgHash % 6

            // Aberturas por perfil
            const patientOpenings = ['Entendi ВӯЖ’ГҶГё', 'Obrigada por compartilhar.', 'Certo, vamos analisar isso juntos.', 'Compreendi.', 'Deixa eu te ajudar com isso.', 'Vamos lв”ңГӯ.']
            const professionalOpenings = ['Certo.', 'Entendido.', 'Registrado.', 'Perfeito.', 'Compreendido.', 'Ok.']
            const adminOpenings = ['Certo.', 'Entendido.', 'Registrado.', 'Ok, vamos lв”ңГӯ.', 'Perfeito.', 'Compreendido.']

            // Transparв”ңВ¬ncias sutis (variaв”ңВәв”ңГәo)
            const transparencies = [
                '_Operando em modo local Г”ГҮГ¶ suas funв”ңВәв”ңГҒes e dados estв”ңГәo preservados._',
                '_Modo local ativo Г”ГҮГ¶ navegaв”ңВәв”ңГәo e dados funcionam normalmente._',
                '_Em modo local Г”ГҮГ¶ suas informaв”ңВәв”ңГҒes estв”ңГәo seguras e acessв”ңВЎveis._',
                '_Modo local ativo Г”ГҮГ¶ funcionalidades operacionais disponв”ңВЎveis._',
                '_Operaв”ңВәв”ңГәo local Г”ГҮГ¶ tudo preservado._',
                '_Modo local Г”ГҮГ¶ dados e funв”ңВәв”ңГҒes intactos._'
            ]

            // Selecionar por perfil e variaв”ңВәв”ңГәo
            const isPatient = userRole === 'patient'
            const isProfessional = userRole === 'professional'
            const isAdmin = userRole === 'admin' || userRole === 'master'
            const userName = patientData?.user?.name || patientData?.user?.full_name || ''
            const firstName = userName ? userName.split(' ')[0] : ''

            const opening = isPatient
                ? patientOpenings[variant]
                : isProfessional
                    ? (firstName ? `${professionalOpenings[variant]} Dr(a). ${firstName}` : professionalOpenings[variant])
                    : adminOpenings[variant]

            const transparency = transparencies[variant]

            // --- CAMADA 5: SISTEMA DE BLOCOS COMPOSICIONAIS ---
            // composeResponse: greeting Г”ГҘГҶ contextual reflection Г”ГҘГҶ body Г”ГҘГҶ exploratory Г”ГҘГҶ action Г”ГҘГҶ transparency
            const isGreeting = /^(oi|ola|ol[aв”ңГӯ]|bom dia|boa tarde|boa noite|hey|hi|hello|tudo bem|como vai|e a[iв”ңВЎ])\b/i.test(norm || '')
            const isScheduling = shouldTriggerSchedulingWidget
            const isNavigation = isAgendaNavigationOnly

            let contextualReflection = ''
            let body = ''
            let exploratoryQuestion = ''
            let actionOffer = ''

            // BLOCO: Reflexв”ңГәo contextual (memв”ңв”Ӯria conversacional)
            if (lastTopic && !isGreeting && conversationDepth > 2) {
                const topicLabels: Record<string, string> = {
                    dor: 'dor', sono: 'sono', ansiedade: 'ansiedade', humor: 'humor',
                    cannabis: 'uso de cannabis', medicacao: 'medicaв”ңВәв”ңГәo', exame: 'exames',
                    agenda: 'agendamento', documento: 'documentos'
                }
                const label = topicLabels[lastTopic] || lastTopic
                if (lastTopic !== detectedConcepts[0]) {
                    contextualReflection = `Continuando nossa conversa sobre ${label} Г”ГҮГ¶`
                }
            }

            // BLOCO: Corpo principal (por situaв”ңВәв”ңГәo)
            if (isGreeting) {
                if (isPatient && firstName) {
                    body = `Bom te ver por aqui, ${firstName}! Estou operando em modo local no momento, mas posso te ajudar com acesso в”ңГЎ sua agenda, informaв”ңВәв”ңГҒes da clв”ңВЎnica e registrar observaв”ңВәв”ңГҒes para seu profissional.`
                } else if (isProfessional && firstName) {
                    body = `Dr(a). ${firstName}, estou em modo local. Suas funcionalidades operacionais Г”ГҮГ¶ agenda, pacientes, relatв”ңв”Ӯrios e navegaв”ңВәв”ңГәo Г”ГҮГ¶ seguem disponв”ңВЎveis normalmente.`
                } else if (isAdmin) {
                    body = `Estou em modo local. Todas as funв”ңВәв”ңГҒes administrativas seguem operacionais Г”ГҮГ¶ agenda, gestв”ңГәo de pacientes, relatв”ңв”Ӯrios e biblioteca.`
                } else {
                    body = 'Estou operando em modo local no momento, mas posso te ajudar com navegaв”ңВәв”ңГәo, agenda e acesso rв”ңГӯpido в”ңГЎs в”ңГӯreas da clв”ңВЎnica.'
                }
            } else if (isScheduling) {
                body = 'Posso te levar direto para a agenda. O sistema de agendamento funciona normalmente.'
                if (isPatient) {
                    actionOffer = 'Os horв”ңГӯrios disponв”ңВЎveis estв”ңГәo atualizados no painel.'
                }
            } else if (isNavigation) {
                body = 'Abrindo a seв”ңВәв”ңГәo para vocв”ңВ¬. A navegaв”ңВәв”ңГәo segue funcionando normalmente.'
            } else if (detectedConcepts.length > 0 && isPatient) {
                // PACIENTE com conceito clв”ңВЎnico detectado
                const primaryConcept = detectedConcepts[0]
                const factorInfo = factorRelations[primaryConcept]

                if (primaryConcept === 'exame') {
                    body = 'Para uma anв”ңГӯlise completa dos seus exames, o profissional responsв”ңГӯvel poderв”ңГӯ avaliar com precisв”ңГәo na prв”ңв”Ӯxima consulta.'
                    actionOffer = 'Posso abrir seu histв”ңв”Ӯrico de exames ou levar vocв”ңВ¬ para a agenda.'
                } else if (primaryConcept === 'agenda' || primaryConcept === 'documento') {
                    body = 'Posso te ajudar com isso diretamente.'
                } else {
                    // Conceito clв”ңВЎnico: explorar sem diagnosticar
                    body = 'Obrigada por compartilhar isso. Posso registrar essas informaв”ңВәв”ңГҒes para que o profissional avalie com mais contexto.'
                    if (factorInfo) {
                        exploratoryQuestion = factorInfo.question
                    }
                }

                // Cruzar com knowledgeBlock se disponв”ңВЎvel
                if (knowledgeBlock && knowledgeBlock.length > 50 && ['cannabis', 'medicacao'].includes(primaryConcept)) {
                    body += '\n\nEncontrei informaв”ңВәв”ңГҒes relevantes na nossa base de conhecimento que podem complementar.'
                }
            } else if (detectedConcepts.length > 0 && (isProfessional || isAdmin)) {
                // PROFISSIONAL/ADMIN com conceito detectado
                const primaryConcept = detectedConcepts[0]
                if (primaryConcept === 'exame') {
                    body = 'Posso abrir o mв”ңв”Ӯdulo de exames ou buscar dados no sistema.'
                    actionOffer = 'A navegaв”ңВәв”ңГәo para relatв”ңв”Ӯrios e prontuв”ңГӯrios segue disponв”ңВЎvel.'
                } else if (primaryConcept === 'agenda') {
                    body = 'O sistema de agendamento estв”ңГӯ operacional. Posso abrir a agenda ou mostrar os horв”ңГӯrios.'
                } else if (primaryConcept === 'documento') {
                    body = 'Posso abrir a biblioteca ou buscar documentos especв”ңВЎficos.'
                } else {
                    body = 'Suas funв”ңВәв”ңГҒes operacionais seguem disponв”ңВЎveis Г”ГҮГ¶ agenda, pacientes, relatв”ңв”Ӯrios e navegaв”ңВәв”ңГәo. Para anв”ңГӯlises avanв”ңВәadas, a camada cognitiva serв”ңГӯ restaurada em breve.'
                }
            } else if (currentIntent === 'CLINICA') {
                if (isPatient) {
                    body = 'Para garantir a precisв”ңГәo da sua avaliaв”ңВәв”ңГәo, anв”ңГӯlises clв”ңВЎnicas completas dependem da minha camada cognitiva avanв”ңВәada, que serв”ңГӯ restaurada em breve.\n\nEnquanto isso, posso registrar suas observaв”ңВәв”ңГҒes, abrir sua agenda ou acessar suas informaв”ңВәв”ңГҒes. Se for urgente, procure atendimento imediato.'
                } else {
                    body = 'A camada de anв”ңГӯlise avanв”ңВәada estв”ңГӯ temporariamente indisponв”ңВЎvel. Dados, navegaв”ңВәв”ңГәo e funв”ңВәв”ңГҒes operacionais continuam normais.'
                }
            } else if (currentIntent === 'ADMIN') {
                body = 'Suas funв”ңВәв”ңГҒes administrativas seguem disponв”ңВЎveis Г”ГҮГ¶ agenda, pacientes, relatв”ңв”Ӯrios e navegaв”ңВәв”ңГәo funcionam normalmente. Apenas respostas analв”ңВЎticas avanв”ңВәadas estв”ңГәo temporariamente reduzidas.'
            } else if (currentIntent === 'ENSINO') {
                body = 'O mв”ңв”Ӯdulo de simulaв”ңВәв”ңГәo requer a camada generativa completa, temporariamente indisponв”ңВЎvel. Posso te levar para a biblioteca educativa ou para outro recurso da plataforma.'
            } else {
                body = 'Posso te ajudar com navegaв”ңВәв”ңГәo, agenda e acesso rв”ңГӯpido в”ңГЎs в”ңГӯreas da clв”ңВЎnica.'
            }

            // MONTAGEM FINAL: composeResponse
            const parts: string[] = [opening]
            if (contextualReflection) parts.push(contextualReflection)
            if (body) parts.push(body)
            if (exploratoryQuestion) parts.push(exploratoryQuestion)
            if (actionOffer) parts.push(actionOffer)
            parts.push(transparency)

            const DETERMINISTIC_RESPONSE = parts.join('\n\n')

            return {
                choices: [{
                    message: {
                        content: DETERMINISTIC_RESPONSE
                    }
                }],
                usage: { total_tokens: 0 },
                model: 'TradeVision-Core-Deterministic'
            }
        });

        // CRв”ңГ¬TICO: Garantir que completion existe antes de acessar
        if (!completion || !completion.choices || !Array.isArray(completion.choices) || completion.choices.length === 0) {
            console.error('Г”ГҳГ® [TradeVision Error]: completion invв”ңГӯlido ou vazio', { completion })
            throw new Error('Resposta da IA invв”ңГӯlida: completion nв”ңГәo contв”ңВ®m choices vв”ңГӯlidos')
        }

        // Garantir que aiResponse sempre estв”ңГӯ definido
        let aiResponse: string = completion?.choices?.[0]?.message?.content || ''

        // Se nв”ңГәo houver resposta vв”ңГӯlida, usar fallback
        if (!aiResponse || typeof aiResponse !== 'string') {
            console.warn('Г”ГңГЎВҙВ©Г… [TradeVision Warning]: Resposta da IA vazia ou invв”ңГӯlida, usando fallback', {
                hasCompletion: !!completion,
                hasChoices: !!completion?.choices,
                choicesLength: completion?.choices?.length || 0,
                hasMessage: !!completion?.choices?.[0]?.message,
                hasContent: !!completion?.choices?.[0]?.message?.content
            })
            aiResponse = 'Desculpe, nв”ңГәo consegui processar sua mensagem no momento. Pode repetir?'
        }

        // Log de debug para verificar se aiResponse estв”ңГӯ definido
        console.log('ВӯЖ’Г¶Г¬ [TradeVision Debug]: aiResponse definido', {
            aiResponseDefined: typeof aiResponse !== 'undefined',
            aiResponseType: typeof aiResponse,
            aiResponseLength: aiResponse?.length || 0
        })

        // ВӯЖ’ВәГЎ TRIGGER AUTOMв”ңГјTICO VIA LLM TAG (modelo selado: GPT emite Г”ГҘГҶ Core confia, nunca ignora a tag)
        // Se o LLM incluiu [TRIGGER_SCHEDULING], sempre abrir widget. Nв”ңГәo sobrescrever a resposta nesse caso.
        let shouldTriggerScheduling = shouldTriggerSchedulingWidget;
        if (aiResponse?.includes(TRIGGER_SCHEDULING_TOKEN)) {
            shouldTriggerScheduling = true;
            console.log('Г”ГңГӯ [TRIGGER] Tag de agendamento detectada na resposta da IA. Abrindo widget.');
            try {
                await supabaseClient.from('cognitive_events').insert({
                    intent: currentIntent,
                    action: 'INTENT_CONFIRMATION',
                    decision_result: 'SIGNAL',
                    source: 'AI_RESPONSE_TAG',
                    metadata: {
                        trigger: 'TRIGGER_SCHEDULING',
                        tag: 'TRIGGER_SCHEDULING',
                        suggested_intent: 'ADMIN',
                        origin: 'AI_RESPONSE_TAG',
                        contract_token: TRIGGER_SCHEDULING_TOKEN,
                        has_text_tag: true,
                        derived_from: 'llm_text_tag',
                        preconditions: {
                            is_agenda_navigation_only: isAgendaNavigationOnly,
                            should_trigger_widget_by_keywords: shouldTriggerSchedulingWidget
                        }
                    }
                });
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [CEP NON-BLOCKING] Falha ao registrar TRIGGER_SCHEDULING:', e);
            }
        }

        // Se o usuв”ңГӯrio pediu agendamento de forma explв”ңВЎcita (determinв”ңВЎstico), mas o LLM nв”ңГәo incluiu a tag,
        // ainda assim abrimos o widget e registramos evento non-blocking para rastreabilidade.
        if (shouldTriggerSchedulingWidget && !aiResponse?.includes(TRIGGER_SCHEDULING_TOKEN)) {
            try {
                await supabaseClient.from('cognitive_events').insert({
                    intent: currentIntent,
                    action: 'INTENT_CONFIRMATION',
                    decision_result: 'SIGNAL',
                    source: 'DETERMINISTIC_TRIGGER',
                    metadata: {
                        trigger: 'TRIGGER_SCHEDULING',
                        suggested_intent: 'ADMIN',
                        origin: 'DETERMINISTIC_TRIGGER',
                        contract_token: TRIGGER_SCHEDULING_TOKEN,
                        has_text_tag: false,
                        derived_from: 'schedule_keyword_deterministic',
                        preconditions: {
                            is_agenda_navigation_only: isAgendaNavigationOnly,
                            should_trigger_widget_by_keywords: shouldTriggerSchedulingWidget
                        }
                    }
                })
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [CEP NON-BLOCKING] Falha ao registrar DETerministic scheduling trigger:', e)
            }
        }

        // ВӯЖ’ВәВЎ Sв”ңв”Ӯ substituir resposta quando for navegaв”ңВәв”ңГәo de agenda E o GPT nв”ңГәo emitiu tag (modelo selado: se GPT emitiu [TRIGGER_SCHEDULING], nв”ңГәo sobrescrever).
        if (isAgendaNavigationOnly && !aiResponse?.includes(TRIGGER_SCHEDULING_TOKEN)) {
            aiResponse = `Agenda profissional aberta.\n\nAqui vocв”ңВ¬ pode visualizar seus agendamentos e organizar a rotina de atendimento. Se quiser marcar uma consulta como paciente, me diga: "quero ver horв”ңГӯrios disponв”ңВЎveis para agendar".`
        }

        console.log('ВӯЖ’ГұГ» [AI RESPONSE]', {
            responseLength: aiResponse?.length || 0,
            tokensUsed: completion.usage?.total_tokens || 0,
            model: completion.model
        })

        // [TITAN 3.2] A Persistв”ңВ¬ncia de Auditoria agora в”ңВ® OBRIGATв”ңГҙRIA e TRANSACIONAL
        if (patientData?.user?.id) {
            let simbologia = 'ВӯЖ’Г¶в”Ө Escuta Clв”ңВЎnica';
            if (isTeachingMode) simbologia = ' Simulaв”ңВәв”ңГәo de Paciente';
            else if (currentIntent === 'ADMIN') simbologia = 'ВӯЖ’Г¶ГҒ Escuta Institucional';

            // Colunas reais: user_id, appointment_id, interaction_type, payload (jsonb)
            const payload = {
                interaction_id,
                input: message,
                output: aiResponse,
                model: completion.model,
                tokens: completion.usage?.total_tokens || 0,
                context: {
                    intent: currentIntent,
                    mode: isTeachingMode ? 'TEACHING_ROLEPLAY' : 'CLINICAL',
                    assessmentPhase: assessmentPhase || null,
                    simbologia,
                    system: "TradeVision Core V2 (Titan 3.2)",
                    metadata: completion.usage
                }
            };

            // [TITAN 3.2] Loop de Retry para garantir a Evidв”ңВ¬ncia Clв”ңВЎnica
            let saved = false;
            let retries = 0;
            const maxRetries = 3;

            while (!saved && retries < maxRetries) {
                try {
                    const { error: saveError } = await supabaseClient
                        .from('noa_logs')
                        .insert({
                            user_id: patientData.user.id,
                            appointment_id: appointmentData?.id || null,
                            interaction_type: 'chat_turn',
                            payload
                        });

                    if (!saveError) {
                        saved = true;
                        console.log(`ВӯЖ’ГҶВҘ [DB SAVED] interaction_id: ${interaction_id} (Attempt ${retries + 1})`);
                    } else {
                        console.error(`Г”ГңГЎВҙВ©Г… [Audit Retry ${retries + 1}] Falha ao salvar log:`, saveError.message);
                        retries++;
                        if (retries < maxRetries) await new Promise(r => setTimeout(r, 50 * retries)); // Exponential backoff
                    }
                } catch (e) {
                    console.error(`Г”ГҳГ® [Audit Exception ${retries + 1}]:`, e);
                    retries++;
                }
            }

            if (!saved) {
                console.error(`ВӯЖ’ГңВҝ [FATAL AUDIT FAILURE] interaction_id: ${interaction_id}. Registro de evidв”ңВ¬ncia clв”ңВЎnica falhou.`);
                // Em um sistema real, poderв”ңВЎamos lanв”ңВәar erro aqui: throw new Error("Audit log mandatory for clinical safety");
            }
        }


        // 8. app_commands A PARTIR do trigger (modelo selado): GPT emite trigger Г”ГҘГҶ Core governa Г”ГҘГҶ gera app_commands.
        //    Primeiro: extrair comandos dos triggers que o GPT colocou na resposta.
        //    Se o GPT nв”ңГәo emitiu nenhum, fallback: deriveAppCommandsV1(message) (Mundo B transicional).
        const fromGPT = parseTriggersFromGPTResponse(aiResponse || "")
        let rawCommands = fromGPT.length > 0 ? fromGPT : deriveAppCommandsV1(message || "", ui_context, userRole)
        let textForUser = stripGPTTriggerTags(aiResponse || "")
        // Mensagem clara quando vamos abrir o CARD no chat: usuв”ңГӯrio nв”ңГәo precisa dizer "abrir" nem ficar em dв”ңв•‘vida.
        if (shouldTriggerScheduling) {
            if (isShortSchedulingConfirmation) {
                textForUser = 'Abrindo o agendamento aqui no chat para vocв”ңВ¬ escolher o horв”ңГӯrio e confirmar.'
            } else if (hasScheduleVerb || hasConsultIntent) {
                // Resolve nome do profissional dinamicamente
                let drName = 'o profissional'
                try {
                    const { data: profData } = await supabaseClient
                        .from('users')
                        .select('name')
                        .or(`slug.eq.${detectedProfessionalId},id.eq.${detectedProfessionalId}`)
                        .limit(1)
                        .single()
                    if (profData?.name) drName = profData.name
                } catch { drName = detectedProfessionalId.includes('faveret') ? 'Dr. Eduardo Faveret' : 'Dr. Ricardo Valenв”ңВәa' }
                textForUser = `Abrindo aqui no chat para vocв”ңВ¬ escolher o horв”ңГӯrio e confirmar a consulta com ${drName}.`
            }
        }
        // Modelo selado: quando o GPT emite [DOCUMENT_LIST], Core governa e injeta lista ou abre 1 doc direto no chat
        const docTermFromMessage = sanitizeSearchTerm(stripInjectedContext(message || ''))
        let docTerm = docTermFromMessage
        if (aiResponse?.includes(GPT_TRIGGERS.DOCUMENT_LIST) && patientData?.user?.id) {
            const docList = await runDocumentListFlowFromTrigger(supabaseClient, patientData.user.id, realUserRole, docTerm, currentIntent)
            if (docList) {
                if (docList.singleDoc) {
                    textForUser = (textForUser.trim() || `Abrindo no chat: ${docList.singleDoc.title}`).trim()
                    const openCmd: AppCommandV1 = {
                        kind: 'noa_command',
                        command: {
                            type: 'show-document-inline',
                            target: 'document',
                            label: `Abrir no chat: ${docList.singleDoc.title}`,
                            fallbackRoute: '/app/library',
                            payload: {
                                document_id: docList.singleDoc.document_id,
                                confirmed: true,
                                source: 'gpt_trigger_single_doc',
                                title: docList.singleDoc.title,
                                summary: docList.singleDoc.summary,
                                category: docList.singleDoc.category,
                                smart_card_actions: ['summarize', 'analyze', 'full_content']
                            }
                        },
                        reason: 'gpt_trigger_single_document_open'
                    }
                    rawCommands = [...fromGPT.filter(c => c.command.type !== 'document-list'), openCmd]
                } else if (docList.listText) {
                    textForUser = (textForUser.trim() + '\n\n' + docList.listText + "\n\nDiga \"listar mais\" para ver os prв”ңв”Ӯximos 5.").trim()
                }
            }
        } else if (patientData?.user?.id) {
            // Fallback: GPT disse que vai abrir um documento (ex.: "vou abrir o documento Prв”ңв”Ӯximos Passos") mas nв”ңГәo emitiu [DOCUMENT_LIST]; extrair nome da resposta e abrir
            const termFromResponse = extractDocumentTermFromGPTResponse(aiResponse || '')
            if (termFromResponse) {
                docTerm = termFromResponse
                const docList = await runDocumentListFlowFromTrigger(supabaseClient, patientData.user.id, realUserRole, docTerm, currentIntent)
                if (docList?.singleDoc) {
                    textForUser = (textForUser.trim() || `Abrindo no chat: ${docList.singleDoc.title}`).trim()
                    const openCmd: AppCommandV1 = {
                        kind: 'noa_command',
                        command: {
                            type: 'show-document-inline',
                            target: 'document',
                            label: `Abrir no chat: ${docList.singleDoc.title}`,
                            fallbackRoute: '/app/library',
                            payload: {
                                document_id: docList.singleDoc.document_id,
                                confirmed: true,
                                source: 'gpt_response_fallback_open_doc',
                                title: docList.singleDoc.title,
                                summary: docList.singleDoc.summary,
                                category: docList.singleDoc.category,
                                smart_card_actions: ['summarize', 'analyze', 'full_content']
                            }
                        },
                        reason: 'gpt_response_fallback_document_open'
                    }
                    rawCommands = [...fromGPT.filter(c => c.command.type !== 'document-list'), openCmd]
                }
            }
        }

        let app_commands = filterAppCommandsByRole(rawCommands, userRole)
        // Quando abrimos o CARD de agendamento no chat, nв”ңГәo navegar para a aba Agendamentos (paciente fica no chat e vв”ңВ¬ horв”ңГӯrio/valor)
        if (shouldTriggerScheduling && app_commands.length > 0) {
            app_commands = app_commands.filter(
                (c: AppCommandV1) => !(c.command?.type === 'navigate-section' && c.command?.target === 'agendamentos')
            )
        }
        if (app_commands.length > 0) {
            try {
                await supabaseClient.from('cognitive_events').insert({
                    intent: currentIntent,
                    action: 'APP_COMMAND_SUGGESTION',
                    decision_result: 'SIGNAL',
                    source: 'SMART_TRIGGER',
                    metadata: {
                        app_commands,
                        role: userRole,
                        ui_context: ui_context || null
                    }
                })
            } catch (e) {
                console.warn('Г”ГңГЎВҙВ©Г… [CEP NON-BLOCKING] Falha ao registrar APP_COMMAND_SUGGESTION:', e)
            }
        }

        // 9. Retorno da Resposta (texto sem triggers GPT; token [TRIGGER_ACTION] sв”ңв”Ӯ se houver app_commands)
        const finalText = textWithActionToken(textForUser, app_commands)
        return new Response(
            JSON.stringify({
                text: finalText,
                metadata: {
                    audited: true,
                    intent: currentIntent,
                    professionalId: detectedProfessionalId,
                    trigger_scheduling: shouldTriggerScheduling,
                    system: "TradeVision Core V2",
                    timestamp: new Date().toISOString(),
                    role: userRole, // Governanв”ңВәa por perfil (PROTOCOLO / PLANO_MESTRE)
                    model: completion.model || 'unknown',
                    offline: completion.model === 'TradeVision-Core-Deterministic'
                },
                app_commands
            }),
            { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
        )

    } catch (error: any) {
        // Log mais detalhado do erro para debug
        const errorMessage = error?.message || 'Erro desconhecido'
        const errorStack = error?.stack || ''
        console.error('Г”ГҳГ® [TradeVision Error]:', errorMessage)
        if (errorStack) {
            console.error('ВӯЖ’ГҙГ¬ [TradeVision Stack]:', errorStack.substring(0, 500)) // Limitar stack trace
        }

        // Verificar se в”ңВ® erro relacionado a aiResponse nв”ңГәo definido
        if (errorMessage.includes('aiResponse') || errorMessage.includes('is not defined')) {
            console.error('ВӯЖ’Г¶Г¬ [TradeVision Debug]: Erro relacionado a aiResponse. Verificar se completion.choices[0].message.content existe.')
        }

        return new Response(
            JSON.stringify({
                error: errorMessage,
                text: 'Desculpe, ocorreu um erro ao processar sua mensagem. Por favor, tente novamente.'
            }),
            {
                status: 200, // Retornamos 200 para o frontend tratar como mensagem de erro amigв”ңГӯvel se quiser
                headers: { ...corsHeaders, 'Content-Type': 'application/json' }
            }
        )
    }
})
